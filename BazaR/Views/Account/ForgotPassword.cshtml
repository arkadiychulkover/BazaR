@model string
@{
    ViewData["Title"] = "Відновлення пароля";
}

<div class="rp-page">
    <div class="rp-card">
        <div class="rp-card__icon">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
                <circle cx="24" cy="24" r="23" stroke="#3E77AA" stroke-width="1.5" />
                <path d="M32 22H16C14.9 22 14 22.9 14 24V34C14 35.1 14.9 36 16 36H32C33.1 36 34 35.1 34 34V24C34 22.9 33.1 22 32 22Z" stroke="#3E77AA" stroke-width="1.5" stroke-linejoin="round" />
                <path d="M18 22V18C18 15.8 19.8 14 22 14H26C28.2 14 30 15.8 30 18V22" stroke="#3E77AA" stroke-width="1.5" stroke-linecap="round" />
                <circle cx="24" cy="29" r="2" fill="#3E77AA" />
            </svg>
        </div>
        <h1 class="rp-card__title">Відновлення пароля</h1>
        <p class="rp-card__subtitle">Введіть email вашого акаунту — ми надішлемо посилання для скидання пароля.</p>

        @if (TempData["Ok"] != null)
        {
            <div class="rp-alert rp-alert--success">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <circle cx="8" cy="8" r="7" stroke="#2e7d32" stroke-width="1.2" />
                    <path d="M5 8l2 2 4-4" stroke="#2e7d32" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                @TempData["Ok"]
            </div>
        }

        <form asp-action="ForgotPassword" asp-controller="Account" method="post" class="rp-form">
            @Html.AntiForgeryToken()
            <div class="rp-form__group">
                <label class="rp-form__label">Email адреса</label>
                <input name="email" type="email" class="rp-form__input" placeholder="example@email.com" value="@Model" />
            </div>
            <button class="rp-form__submit" type="submit">Надіслати посилання</button>
        </form>

        <div class="rp-card__footer">
            <a asp-controller="Site" asp-action="Index" class="rp-back-link">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M10 12L6 8l4-4" stroke="#3E77AA" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                Повернутись на головну
            </a>
        </div>
    </div>
</div>