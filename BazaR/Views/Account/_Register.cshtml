@{
    var regFirstName = TempData["RegFirstName"]?.ToString() ?? "";
    var regLastName = TempData["RegLastName"]?.ToString() ?? "";
    var regPhone = TempData["RegPhone"]?.ToString() ?? "";
    var regEmail = TempData["RegEmail"]?.ToString() ?? "";

    var regFirstNameError = TempData["RegFirstNameError"]?.ToString() ?? "";
    var regLastNameError = TempData["RegLastNameError"]?.ToString() ?? "";
    var regPhoneError = TempData["RegPhoneError"]?.ToString() ?? "";
    var regEmailError = TempData["RegEmailError"]?.ToString() ?? "";
    var regPasswordError = TempData["RegPasswordError"]?.ToString() ?? "";

    bool regFirstNameInvalid = false;
    bool regLastNameInvalid = false;
    bool regPhoneInvalid = false;
    bool regEmailInvalid = false;
    bool regPasswordInvalid = false;

    if (TempData["RegFirstNameInvalid"] != null)
        bool.TryParse(TempData["RegFirstNameInvalid"]!.ToString(), out regFirstNameInvalid);

    if (TempData["RegLastNameInvalid"] != null)
        bool.TryParse(TempData["RegLastNameInvalid"]!.ToString(), out regLastNameInvalid);

    if (TempData["RegPhoneInvalid"] != null)
        bool.TryParse(TempData["RegPhoneInvalid"]!.ToString(), out regPhoneInvalid);

    if (TempData["RegEmailInvalid"] != null)
        bool.TryParse(TempData["RegEmailInvalid"]!.ToString(), out regEmailInvalid);

    if (TempData["RegPasswordInvalid"] != null)
        bool.TryParse(TempData["RegPasswordInvalid"]!.ToString(), out regPasswordInvalid);

    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<div class="auth-modal" id="registerModal" role="dialog" aria-modal="true" aria-hidden="true">
    <div class="auth-modal__backdrop" data-auth-close></div>

    <div class="auth-modal__panel">

        <div class="auth-modal__brand auth-modal__brand--navbar">
            <span class="auth-modal__brand-slot auth-modal__brand-slot--ghost" aria-hidden="true"><i class="bi bi-list"></i></span>
            <a class="auth-modal__navbar-brand" asp-controller="Site" asp-action="Index">
                <i class="bi bi-shop"></i> BazaR
            </a>
            <button type="button" class="auth-modal__brand-slot auth-modal__brand-slot--close" data-auth-close aria-label="Закрити">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="auth-modal__content">
            <div class="auth-modal__col auth-modal__col--left">
                <h3 class="auth-modal__title">Реєстрація</h3>

                <div class="auth-modal__register-flow">
                    <form asp-controller="Account" asp-action="Register" method="post" class="auth-form auth-form--register">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="returnUrl" value="@returnUrl" />

                        <div class="auth-rf auth-rf--fields">

                    <div class="auth-field">
                        <div class="auth-input-wrap">
                            <input name="firstName"
                                   type="text"
                                   autocomplete="given-name"
                                   placeholder="Ім’я"
                                   class="auth-input @(regFirstNameInvalid ? "is-invalid" : "")"
                                   value="@regFirstName" />

                            <span class="auth-error @(regFirstNameInvalid ? "" : "hidden")" aria-hidden="true">
                                @Html.Partial("_ErrorIcon")
                            </span>
                        </div>

                        <div class="field-validation">
                            @regFirstNameError
                        </div>
                    </div>

                    <div class="auth-field">
                        <div class="auth-input-wrap">
                            <input name="lastName"
                                   type="text"
                                   autocomplete="family-name"
                                   placeholder="Прізвище"
                                   class="auth-input @(regLastNameInvalid ? "is-invalid" : "")"
                                   value="@regLastName" />

                            <span class="auth-error @(regLastNameInvalid ? "" : "hidden")" aria-hidden="true">
                                @Html.Partial("_ErrorIcon")
                            </span>
                        </div>

                        <div class="field-validation">
                            @regLastNameError
                        </div>
                    </div>

                    <div class="auth-field">
                        <div class="auth-input-wrap">
                            <input name="phoneNumber"
                                   type="text"
                                   inputmode="tel"
                                   autocomplete="tel"
                                   placeholder="Номер телефону"
                                   class="auth-input @(regPhoneInvalid ? "is-invalid" : "")"
                                   value="@regPhone" />

                            <span class="auth-error @(regPhoneInvalid ? "" : "hidden")" aria-hidden="true">
                                @Html.Partial("_ErrorIcon")
                            </span>
                        </div>

                        <div class="field-validation">
                            @regPhoneError
                        </div>
                    </div>

                    <div class="auth-field">
                        <div class="auth-input-wrap">
                            <input name="email"
                                   type="text"
                                   inputmode="email"
                                   autocomplete="email"
                                   placeholder="Ел. пошта"
                                   class="auth-input @(regEmailInvalid ? "is-invalid" : "")"
                                   value="@regEmail" />

                            <span class="auth-error @(regEmailInvalid ? "" : "hidden")" aria-hidden="true">
                                @Html.Partial("_ErrorIcon")
                            </span>
                        </div>

                        <div class="field-validation">
                            @regEmailError
                        </div>
                    </div>

                    <div class="auth-field auth-field--password">
                        <div class="auth-input-wrap auth-input-wrap--password">
                            <input name="password"
                                   type="password"
                                   autocomplete="new-password"
                                   placeholder="Придумайте пароль"
                                   class="auth-input @(regPasswordInvalid ? "is-invalid" : "")"
                                   value="" />

                            <button type="button" class="@(regPasswordInvalid ? "auth-pass-toggle" : "auth-pass-toggle-noterror")" aria-label="Показати пароль">
                                <svg width="21" height="20" viewBox="0 0 21 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M1.11102 0.175958C1.05059 0.120172 0.978841 0.0759209 0.899879 0.04573C0.820918 0.0155391 0.736288 5.87796e-10 0.650821 0C0.565354 -5.87796e-10 0.480724 0.0155391 0.401763 0.04573C0.322801 0.0759209 0.251055 0.120172 0.190621 0.175958C0.130187 0.231743 0.0822477 0.297971 0.0495409 0.370858C0.016834 0.443745 -6.36779e-10 0.521865 0 0.600758C6.36779e-10 0.679651 0.016834 0.757771 0.0495409 0.830658C0.0822477 0.903545 0.130187 0.969773 0.190621 1.02556L4.74062 5.22316C2.48716 6.64196 0.918371 8.81284 0.364821 11.2784C0.347408 11.3556 0.346641 11.4352 0.362566 11.5127C0.37849 11.5902 0.410794 11.664 0.457632 11.73C0.504469 11.796 0.564924 11.8528 0.635545 11.8972C0.706166 11.9416 0.785569 11.9727 0.869221 11.9888C0.952873 12.0048 1.03914 12.0055 1.12308 11.9908C1.20703 11.9761 1.28702 11.9463 1.35849 11.9031C1.42995 11.8599 1.49149 11.804 1.53959 11.7389C1.58769 11.6737 1.62141 11.6004 1.63882 11.5232C1.88682 10.415 2.37178 9.36372 3.06533 8.43073C3.75887 7.49774 4.64707 6.70182 5.67792 6.08956L7.73972 7.99276C7.20512 8.34859 6.76065 8.80739 6.43706 9.3374C6.11347 9.86742 5.91849 10.456 5.8656 11.0624C5.81271 11.6689 5.90318 12.2786 6.13075 12.8496C6.35831 13.4206 6.71755 13.9391 7.18359 14.3693C7.64964 14.7995 8.21137 15.1311 8.82992 15.3412C9.44848 15.5512 10.1091 15.6347 10.766 15.5859C11.423 15.5371 12.0606 15.3571 12.6348 15.0584C13.209 14.7597 13.706 14.3494 14.0915 13.856L19.6906 19.0256C19.8127 19.1382 19.9782 19.2015 20.1508 19.2015C20.3234 19.2015 20.489 19.1382 20.611 19.0256C20.7331 18.9129 20.8016 18.7601 20.8016 18.6008C20.8016 18.4414 20.7331 18.2886 20.611 18.176L1.11102 0.175958ZM13.1555 12.992C12.8961 13.3741 12.5466 13.6973 12.1332 13.9376C11.7197 14.1778 11.2529 14.3289 10.7674 14.3797C10.282 14.4304 9.79036 14.3795 9.32917 14.2307C8.86799 14.0818 8.44908 13.8389 8.10362 13.5201C7.75816 13.2012 7.49502 12.8145 7.33379 12.3888C7.17256 11.9631 7.11738 11.5093 7.17236 11.0612C7.22733 10.613 7.39105 10.1821 7.65133 9.80049C7.91161 9.41884 8.26175 9.09626 8.67572 8.85676L13.1555 12.9932V12.992Z" fill="#2D2323" />
                                    <path d="M10.5605 7.20312L14.948 11.2519C14.9073 10.1901 14.4321 9.18195 13.6182 8.43065C12.8043 7.67934 11.7122 7.24071 10.5618 7.20312H10.5605Z" fill="#2D2323" />
                                    <path d="M10.4011 4.80071C9.66011 4.80071 8.93341 4.88951 8.23531 5.05631L7.19141 4.09271C8.22478 3.76713 9.3092 3.6009 10.4011 3.60071C15.202 3.60071 19.4257 6.80831 20.4371 11.2783C20.4723 11.4343 20.4389 11.5967 20.3443 11.7299C20.2497 11.8632 20.1017 11.9562 19.9327 11.9887C19.7638 12.0212 19.5878 11.9904 19.4434 11.903C19.2991 11.8157 19.1983 11.6791 19.1631 11.5231C18.2765 7.59311 14.5702 4.80071 10.4011 4.80071Z" fill="#2D2323" />
                                </svg>
                            </button>

                            <span class="auth-error @(regPasswordInvalid ? "" : "hidden")" aria-hidden="true">
                                @Html.Partial("_ErrorIcon")
                            </span>
                        </div>

                        <div class="field-validation">
                            @regPasswordError
                        </div>
                    </div>

                        </div>

                    <div class="auth-hint auth-rf auth-rf--hint">
                        Пароль повинен складатися з не менші ніж 6 символів, містити цифри та латинські літери, у тому числі великі,
                        і не повинен збігатися з ім’ям та ел. поштою
                    </div>

                    <div class="auth-terms auth-rf auth-rf--terms">
                        Реєструючись, ви погоджуєтеся з <a asp-controller="Site" asp-action="Privacy">угодою користувача</a>
                    </div>

                    <button type="submit" class="auth-btn auth-btn--primary auth-rf auth-rf--submit">Зареєструватись</button>

                    <button type="button"
                            class="auth-btn auth-btn--link auth-rf auth-rf--switch"
                            data-auth-switch="login">
                        Я вже зареєстрований
                    </button>
                    </form>

                    <div class="auth-modal__social--mobile">
                        @{ ViewData["AuthExternalReturnUrl"] = returnUrl; }
                        @await Html.PartialAsync("_AuthExternalLogins")
                    </div>
                </div>
            </div>

            <div class="auth-modal__divider">
                <span class="auth-modal__divider--text">або</span>
            </div>

            <div class="auth-modal__col auth-modal__col--right auth-modal__social--desktop">
                @{ ViewData["AuthExternalReturnUrl"] = returnUrl; }
                @await Html.PartialAsync("_AuthExternalLogins")
            </div>
        </div>
    </div>
</div>