@{
    ViewData["Title"] = "Пароль змінено";
}

<div class="rp-page">
    <div class="rp-card">
        <div class="rp-card__icon">
            <svg width="64" height="64" viewBox="0 0 64 64" fill="none">
                <circle cx="32" cy="32" r="31" stroke="#2e7d32" stroke-width="1.5" />
                <path d="M20 32l9 9 15-15" stroke="#2e7d32" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
        </div>
        <h1 class="rp-card__title">Пароль успішно змінено!</h1>
        <p class="rp-card__subtitle">Тепер ви можете увійти до свого акаунту з новим паролем.</p>
        <a asp-controller="Site" asp-action="Index" class="rp-form__submit" style="display:block; text-align:center; text-decoration:none;">
            Увійти до акаунту
        </a>
    </div>
</div>