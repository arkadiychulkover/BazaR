@model BazaR.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Новий пароль";
}

<div class="rp-page">
    <div class="rp-card">
        <div class="rp-card__icon">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
                <circle cx="24" cy="24" r="23" stroke="#3E77AA" stroke-width="1.5" />
                <path d="M32 22H16C14.9 22 14 22.9 14 24V34C14 35.1 14.9 36 16 36H32C33.1 36 34 35.1 34 34V24C34 22.9 33.1 22 32 22Z" stroke="#3E77AA" stroke-width="1.5" stroke-linejoin="round" />
                <path d="M18 22V18C18 15.8 19.8 14 22 14H26C28.2 14 30 15.8 30 18V22" stroke="#3E77AA" stroke-width="1.5" stroke-linecap="round" />
                <circle cx="24" cy="29" r="2" fill="#3E77AA" />
            </svg>
        </div>
        <h1 class="rp-card__title">Новий пароль</h1>
        <p class="rp-card__subtitle">Придумайте надійний пароль для вашого акаунту.</p>


        <form asp-action="ResetPassword" asp-controller="Account" method="post" class="rp-form">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Email" />
            <input type="hidden" asp-for="Token" />

            <div class="rp-form__group">
                <label class="rp-form__label" asp-for="Password">Новий пароль</label>
                <div class="rp-form__input-wrap">
                    <input asp-for="Password" type="password" class="rp-form__input" placeholder="Мінімум 6 символів" />
                    <button type="button" class="rp-form__eye" onclick="rpTogglePassword(this)">
                        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                            <path d="M1 9s3-5 8-5 8 5 8 5-3 5-8 5-8-5-8-5z" stroke="#999" stroke-width="1.2" />
                            <circle cx="9" cy="9" r="2.5" stroke="#999" stroke-width="1.2" />
                        </svg>
                    </button>
                </div>
            </div>

            <div class="rp-form__group">
                <label class="rp-form__label" asp-for="ConfirmPassword">Підтвердження пароля</label>
                <div class="rp-form__input-wrap">
                    <input asp-for="ConfirmPassword" type="password" class="rp-form__input" placeholder="Повторіть пароль" />
                    <button type="button" class="rp-form__eye" onclick="rpTogglePassword(this)">
                        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                            <path d="M1 9s3-5 8-5 8 5 8 5-3 5-8 5-8-5-8-5z" stroke="#999" stroke-width="1.2" />
                            <circle cx="9" cy="9" r="2.5" stroke="#999" stroke-width="1.2" />
                        </svg>
                    </button>
                </div>
            </div>

            <button class="rp-form__submit" type="submit">Зберегти пароль</button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function rpTogglePassword(btn) {
            const input = btn.previousElementSibling;
            input.type = input.type === 'password' ? 'text' : 'password';
        }
    </script>
}