@{
    ViewData["Title"] = "Лист надіслано";
}

<div class="rp-page">
    <div class="rp-card">
        <div class="rp-card__icon">
            <svg width="64" height="64" viewBox="0 0 64 64" fill="none">
                <circle cx="32" cy="32" r="31" stroke="#3E77AA" stroke-width="1.5" />
                <path d="M14 24l18 12 18-12" stroke="#3E77AA" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                <rect x="14" y="22" width="36" height="24" rx="2" stroke="#3E77AA" stroke-width="1.5" />
            </svg>
        </div>
        <h1 class="rp-card__title">Лист надіслано!</h1>
        <p class="rp-card__subtitle">
            Перевірте вашу електронну пошту — ми надіслали посилання для відновлення пароля.
            Якщо лист не надійшов, перевірте папку «Спам».
        </p>
        <a asp-controller="Site" asp-action="Index" class="rp-form__submit" style="display:block; text-align:center; text-decoration:none;">
            На головну
        </a>
        <div class="rp-card__footer">
            <a asp-action="ForgotPassword" asp-controller="Account" class="rp-back-link">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M10 12L6 8l4-4" stroke="#3E77AA" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                Надіслати повторно
            </a>
        </div>
    </div>
</div>