
@{
    var error = TempData["Error"] as string;
    var ok = TempData["Ok"] as string;
}

<div class="auth-modal" id="loginModal" role="dialog" aria-modal="true">
    <div class="auth-modal__backdrop" data-auth-close="true"></div>

    <div class="auth-modal__panel">
        <button class="auth-modal__close" type="button" aria-label="Close" data-auth-close="true">×</button>

        <div class="auth-modal__content">
            <div class="auth-modal__col auth-modal__col--left">
                <h3 class="auth-modal__title">Вхід</h3>

                <form asp-controller="Site" asp-action="Login" method="post" class="auth-form">
                    @Html.AntiForgeryToken()

                    <div class="auth-field">
                        <div class="auth-input-wrap">
                            <input name="email"
                                   type="text"
                                   inputmode="email"
                                   autocomplete="username"
                                   placeholder="Ел. пошта або телефон"
                                   class="auth-input @(ViewBag.LoginEmailInvalid == true ? "is-invalid" : "")"
                                   value="@(ViewBag.LoginEmail ?? "")" />

                            <span class="auth-error @(ViewBag.LoginEmailInvalid == true ? "" : "hidden")" aria-hidden="true">
                                @Html.Partial("_ErrorIcon")
                            </span>
                        </div>

                        <div class="field-validation">
                            @(ViewBag.LoginEmailError ?? "")
                        </div>
                    </div>

                    <div class="auth-field auth-field--password">
                        <input name="password"
                               type="password"
                               autocomplete="current-password"
                               placeholder="Пароль"
                               class="auth-input @(ViewBag.LoginPasswordInvalid == true ? "is-invalid" : "")"
                               value="" />
                        <button type="button" class="auth-pass-toggle" data-pass-toggle="true" aria-label="Показати пароль">
