@functions {
    public string GetFilterQueryString(Dictionary<string, List<string>> filters)
    {
        if (filters == null || !filters.Any()) return "";
        
        var queryString = "";
        foreach (var filter in filters)
        {
            foreach (var value in filter.Value)
            {
                queryString += $"&filter_{filter.Key}={value}";
            }
        }
        return queryString;
    }
}