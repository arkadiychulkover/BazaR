@model ItemCardVm

<article class="product-card">
    <!-- Image Container with Adaptive Aspect Ratio -->
    <div class="product-card__image-wrapper">
        <img class="product-card__img"
             src="@Model.ImageUrl"
             alt="@Model.Name"
             loading="lazy" />
        
        <!-- Wishlist Button -->
        <button class="product-card__wish @(Model.InWishlist ? "is-active" : "")"
                type="button"
                aria-label="@(Model.InWishlist ? "Remove from wishlist" : "Add to wishlist")"
                data-id="@Model.Id">

            <svg width="24" height="22" viewBox="0 -2 26 27">
                <path d="M23.4193 4.50846C23.047 3.62621 22.51 2.82672 21.8386 2.15475C21.1667 1.48077 20.3745 0.945175 19.505 0.577078C18.6035 0.193869 17.6365 -0.0022792 16.6602 1.99806e-05C15.2906 1.99806e-05 13.9544 0.383778 12.7931 1.10865C12.5153 1.28206 12.2514 1.47251 12.0014 1.68003C11.7513 1.47251 11.4874 1.28206 11.2096 1.10865C10.0484 0.383778 8.71211 1.99806e-05 7.34251 1.99806e-05C6.35628 1.99806e-05 5.40062 0.19332 4.49774 0.577078C3.62541 0.946622 2.83921 1.4782 2.16414 2.15475C1.49183 2.82596 0.95477 3.62564 0.5834 4.50846C0.197245 5.42664 0 6.40167 0 7.40512C0 8.35173 0.188911 9.33812 0.563954 10.3416C0.877878 11.1802 1.32793 12.05 1.903 12.9284C2.81421 14.3184 4.06713 15.7682 5.62287 17.2379C8.20094 19.674 10.754 21.3568 10.8624 21.4251L11.5208 21.8572C11.8125 22.0476 12.1875 22.0476 12.4792 21.8572L13.1376 21.4251C13.246 21.354 15.7963 19.674 18.3771 17.2379C19.9328 15.7682 21.1858 14.3184 22.097 12.9284C22.672 12.05 23.1249 11.1802 23.436 10.3416C23.8111 9.33812 24 8.35173 24 7.40512C24.0027 6.40167 23.8055 5.42664 23.4193 4.50846Z" />
            </svg>
        </button>
    </div>

    <!-- Content Section -->
    <div class="product-card__content">
        <!-- Product Title -->
        <h3 class="product-card__title">@Model.Name</h3>

        <!-- Price Section -->
        <div class="product-card__pricing">
            @if (Model.OldPrice > 0 && Model.OldPrice > Model.Price)
            {
                <span class="product-card__oldprice">@String.Format("{0:N0}", Model.OldPrice) ₴</span>
            }
            <span class="product-card__price">@String.Format("{0:N0}", Model.Price) ₴</span>
        </div>
    </div>
</article>
<form id="antiForgeryForm" method="post">
    @Html.AntiForgeryToken()
</form>

<script>
    document.addEventListener("click", async (e) => {
      const btn = e.target.closest(".product-card__wish");
      if (!btn) return;

      const id = btn.dataset.id;
      const token = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]').value;

      const res = await fetch("@Url.Action("ToggleWishlist", "Site")", {
        method: "POST",
        headers: {
          "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8"
        },
        body: new URLSearchParams({
          "__RequestVerificationToken": token,
          "id": id
        })
      });

      const data = await res.json();

      if (!data.success && data.requireLogin) {
        // если у тебя есть модалка логина:
        // открыть её, либо редирект
        window.location.href = "@Url.Action("Index", "Site")";
        return;
      }

      if (data.success) {
        btn.classList.toggle("is-active", data.inWishlist);

        // если есть счетчик в шапке (пример: #wishlistCount)
        const counter = document.querySelector("#wishlistCount");
        if (counter) counter.textContent = data.wishlistCount;
      }
    });
</script>