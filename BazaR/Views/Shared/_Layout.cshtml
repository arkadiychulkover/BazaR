<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BazaR</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        /* Дополнительные стили для корзины и избранного */
        .badge-count {
            position: absolute;
            top: 0;
            right: -8px;
            font-size: 0.6rem;
            padding: 0.25rem 0.4rem;
        }

        .nav-link {
            position: relative;
        }

        .wishlist-btn.active {
            color: red;
        }

        .sale-banner {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border-radius: 10px;
            min-height: 200px;
            padding: 2rem;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4">
            <div class="container">
                <a class="navbar-brand fw-bold" href="@Url.Action("Index", "Site")">
                    <i class="bi bi-shop"></i> BazaR
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarMain">
                    <div class="d-flex flex-grow-1 me-3">
                        <a href="@Url.Action("Browse", "Site")" class="btn btn-light me-2">
                            <i class="bi bi-grid"></i> Категории
                        </a>
                        <div class="flex-grow-1">
                            @await Html.PartialAsync("_SearchBar", (string?)ViewBag.Query ?? "")
                        </div>
                    </div>

                    <!-- Правая часть навигации -->
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link position-relative" href="@Url.Action("Wishlist", "Site")">
                                <i class="bi bi-heart"></i> Избранное
                                @if (ViewBag.WishlistCount > 0)
                                {
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                        @ViewBag.WishlistCount
                                    </span>
                                }
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link position-relative" href="@Url.Action("Cart", "Site")">
                                <i class="bi bi-cart"></i> Корзина
                                @if (ViewBag.CartCount > 0)
                                {
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                        @ViewBag.CartCount
                                    </span>
                                }
                            </a>
                        </li>

                        @if (ViewBag.User != null)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-person-circle"></i> @ViewBag.User.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" href="@Url.Action("Profile", "Site")">Профиль</a></li>
                                    <li><a class="dropdown-item" href="@Url.Action("Orders", "Site")">Мои заказы</a></li>
                                    @if (ViewBag.User.IsAdmin)
                                    {
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" href="#">Админ панель</a></li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-action="Logout" asp-controller="Site" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item">Выйти</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="#" data-bs-toggle="modal" data-bs-target="#loginModal">
                                    <i class="bi bi-box-arrow-in-right"></i> Вход
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="#" data-bs-toggle="modal" data-bs-target="#registerModal">
                                    <i class="bi bi-person-plus"></i> Регистрация
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- Модальные окна для входа и регистрации -->
    <div class="modal fade" id="loginModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                @await Html.PartialAsync("LoginModal")
            </div>
        </div>
    </div>

    <div class="modal fade" id="registerModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                @await Html.PartialAsync("RegisterModal")
            </div>
        </div>
    </div>

    <!-- Скрытое поле для anti-forgery token (для AJAX запросов) -->
    @Html.AntiForgeryToken()

    <main class="container">
        @if (TempData["Ok"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Ok"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </main>

    <footer class="border-top footer text-muted mt-5">
        <div class="container text-center py-3">
            &copy; 2024 - BazaR - Лучший магазин для покупок
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        // Глобальная функция для добавления в избранное
        function addToWishlist(button) {
            const itemId = button.getAttribute('data-item-id');
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            fetch('@Url.Action("AddToWishlist", "Site")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: 'id=' + itemId
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Обновить счетчик в избранном
                    const wishlistLink = document.querySelector('a[href*="Wishlist"]');
                    if (wishlistLink) {
                        let badge = wishlistLink.querySelector('.badge');
                        if (data.wishlistCount > 0) {
                            if (!badge) {
                                badge = document.createElement('span');
                                badge.className = 'position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger';
                                wishlistLink.appendChild(badge);
                            }
                            badge.textContent = data.wishlistCount;
                        } else if (badge) {
                            badge.remove();
                        }
                    }

                    // Визуально отметить кнопку
                    button.classList.add('active');

                    // Показать уведомление
                    showNotification('Товар добавлен в избранное', 'success');
                } else if (data.requireLogin) {
                    // Показать модальное окно входа
                    new bootstrap.Modal(document.getElementById('loginModal')).show();
                }
            })
            .catch(error => console.error('Error:', error));
        }

        // Функция для показа уведомлений
        function showNotification(message, type) {
            const alertDiv = document.createElement('div');
            alertDiv.className = `alert alert-${type} alert-dismissible fade show position-fixed top-0 end-0 m-3`;
            alertDiv.style.zIndex = '9999';
            alertDiv.innerHTML = `
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;
            document.body.appendChild(alertDiv);
            setTimeout(() => alertDiv.remove(), 3000);
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>