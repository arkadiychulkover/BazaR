                <button class="navbar-toggler layout-header__navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-label="Відкрити меню">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <button type="button"
                        class="btn btn-dark border-0 layout-header__mobile-cart position-relative ms-auto"
                        onclick="openCartModal(); return false;"
                        aria-label="Кошик">
                    <i class="bi bi-cart3" style="font-size:1.25rem;" aria-hidden="true"></i>
                    <span class="cart-header-badge layout-header__mobile-cart-badge position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                          style="@(((int)(ViewBag.CartCount ?? 0)) == 0 ? "display:none" : "")">
                        @(ViewBag.CartCount ?? 0)
                    </span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">

                    <!-- Search Bar с мега-меню -->
                    <div class="mx-auto w-50">
                        @await Html.PartialAsync("_SearchBar", categories)
                    </div>
                    <li class="nav-item" style="list-style: none;">
