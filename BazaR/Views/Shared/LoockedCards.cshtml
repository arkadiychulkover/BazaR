@model AccountProductsViewModel

@{
    ViewData["Title"] = "Особисті данні";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600&display=swap" rel="stylesheet">

<div class="profile-page">
    <div class="profile-page__layout">
        @await Html.PartialAsync("_ProfileSidebar", Model.Profile)

        <section class="products-section">
            <div class="container-fluid">
                <h2 class="products-section__title">Featured Products</h2>

                @if (Model.Items.Any())
                {
                    <div class="products-grid">
                        @foreach (var item in Model.Items)
                        {
                            @await Html.PartialAsync("~/Views/Shared/_Card.cshtml", item)
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <p>You dont't look for any item</p>
                    </div>
                }
            </div>
        </section>
    </div>
</div>