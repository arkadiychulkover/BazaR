@{
    ViewData["Title"] = "Розсилки";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">

<div class="profile-page">
    <div class="profile-card">
        <h1 class="profile-title">Розсилки</h1>
        <p class="profile-subtitle">Керуйте підписками на новини, акції та персональні пропозиції.</p>

        <form method="post">
            <div class="settings-list">
                <div class="settings-item">
                    <div class="settings-item__top">
                        <div>
                            <h3 class="settings-item__title">Новини та оновлення</h3>
                            <p class="settings-item__text">Отримуйте важливі новини про сервіс та нові можливості.</p>
                        </div>
                        <label class="switch">
                            <input type="checkbox" checked>
                            <span class="slider"></span>
                        </label>
                    </div>
                </div>

                <div class="settings-item">
                    <div class="settings-item__top">
                        <div>
                            <h3 class="settings-item__title">Акції та знижки</h3>
                            <p class="settings-item__text">Інформація про спеціальні пропозиції та розпродажі.</p>
                        </div>
                        <label class="switch">
                            <input type="checkbox">
                            <span class="slider"></span>
                        </label>
                    </div>
                </div>

                <div class="settings-item">
                    <div class="settings-item__top">
                        <div>
                            <h3 class="settings-item__title">Персональні рекомендації</h3>
                            <p class="settings-item__text">Добірки товарів і пропозицій саме для вас.</p>
                        </div>
                        <label class="switch">
                            <input type="checkbox" checked>
                            <span class="slider"></span>
                        </label>
                    </div>
                </div>
            </div>

            <button type="submit" class="save-btn">Зберегти зміни</button>
        </form>
    </div>
</div>