@using System.Security.Claims

@{
    var isAuth = User.Identity?.IsAuthenticated ?? false;
    var userName = User.Identity?.Name ?? "";
}

<div class="sidebar-overlay" id="sidebarOverlay"></div>

<aside class="sidebar-drawer" id="sidebarDrawer" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Меню">

    <div class="sidebar-head">
        <div class="sidebar-head-inner">
            @if (isAuth)
            {
                <div class="sidebar-user">
                    <div class="sidebar-user-avatar">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                            <path d="M12 12C14.7614 12 17 9.76142 17 7C17 4.23858 14.7614 2 12 2C9.23858 2 7 4.23858 7 7C7 9.76142 9.23858 12 12 12Z" fill="white"/>
                            <path d="M12 14C7.03 14 3 16.686 3 20V22H21V20C21 16.686 16.97 14 12 14Z" fill="white"/>
                        </svg>
                    </div>
                    <div class="sidebar-user-info">
                        <span class="sidebar-user-name">@userName</span>
                        <a asp-controller="Profile" asp-action="Profile" class="sidebar-user-link">Мій профіль</a>
                    </div>
                </div>
            }
            else
            {
                <div class="sidebar-auth-block">
                    <div class="sidebar-auth-icon">
                        <svg width="45" height="45" viewBox="0 0 45 45" fill="none">
                            <circle cx="22.5" cy="22.5" r="22.5" fill="white" fill-opacity="0.15"/>
                            <path d="M22.5 22.5C25.2614 22.5 27.5 20.2614 27.5 17.5C27.5 14.7386 25.2614 12.5 22.5 12.5C19.7386 12.5 17.5 14.7386 17.5 17.5C17.5 20.2614 19.7386 22.5 22.5 22.5Z" fill="white"/>
                            <path d="M22.5 25C17.53 25 13.5 27.686 13.5 31V33H31.5V31C31.5 27.686 27.47 25 22.5 25Z" fill="white"/>
                        </svg>
                    </div>
                    <div class="sidebar-auth-text">
                        <p>Авторизуйтесь для отримання розширених можливостей</p>
                        <div class="sidebar-auth-links">
                            <button type="button" class="sidebar-auth-btn" data-auth-open="login">Вхід</button>
                            <span class="sidebar-auth-sep"></span>
                            <button type="button" class="sidebar-auth-btn" data-auth-open="register">Реєстрація</button>
                        </div>
                    </div>
                </div>
            }
        </div>
        <button class="sidebar-close" id="sidebarClose" aria-label="Закрити меню">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M1 1L17 17M17 1L1 17" stroke="white" stroke-width="2" stroke-linecap="round" />
            </svg>
        </button>
    </div>

    <div class="sidebar-premium">
        <a asp-controller="Profile" asp-action="Premium" class="sidebar-premium__a">
            <div class="sidebar-premium-text">
                <span class="sidebar-premium-title">PREMIUM</span>
                <span class="sidebar-premium-sub">Безкоштовна доставка весь рік</span>
            </div>
            <svg class="sidebar-premium-arrow" width="33" height="33" viewBox="0 0 33 33" fill="none">
                <path d="M7 16.5H26M26 16.5L18 8.5M26 16.5L18 24.5" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </a>
    </div>

    <div class="sidebar-body">

        <div class="sidebar-card">
            <a asp-action="SiteController" asp-controller="Index" class="sidebar-nav-item">
                <span class="sidebar-nav-icon">
                    <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                        <rect x="1" y="1" width="8" height="8" rx="1.5" stroke="#000" stroke-width="1.2"/>
                        <rect x="13" y="1" width="8" height="8" rx="1.5" stroke="#000" stroke-width="1.2"/>
                        <rect x="1" y="13" width="8" height="8" rx="1.5" stroke="#000" stroke-width="1.2"/>
                        <rect x="13" y="14.5" width="8" height="6" rx="1.5" stroke="#000" stroke-width="1.2" transform="rotate(-45 13 14.5)" style="display:none"/>
                        <path d="M14 13L21 20M21 13L14 20" stroke="#000" stroke-width="1.2" stroke-linecap="round"/>
                    </svg>
                </span>
                <span>Каталог товарів</span>
            </a>

            <a asp-action ="Index" asp-controller="CarController" class="sidebar-nav-item">
                <span class="sidebar-nav-icon">
                    <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                        <path d="M1 1H4L6.68 13.39C6.77 13.83 7.21 14.16 7.67 14.16H17.5C17.96 14.16 18.4 13.83 18.49 13.39L20 5H5" stroke="#000" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                        <circle cx="8.5" cy="18.5" r="1.5" stroke="#000" stroke-width="1.2"/>
                        <circle cx="16.5" cy="18.5" r="1.5" stroke="#000" stroke-width="1.2"/>
                    </svg>
                </span>
                <span>Кошик</span>
            </a>

            <a asp-action="" asp-controller="" class="sidebar-nav-item">
                <span class="sidebar-nav-icon">
                    <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                        <circle cx="11" cy="11" r="10" stroke="#000" stroke-width="1.2"/>
                        <path d="M11 7V11.5L14 13.5" stroke="#000" stroke-width="1.2" stroke-linecap="round"/>
                        <path d="M11 7C11 7 8 8.5 8 11" stroke="#000" stroke-width="0" />
                        <path d="M10 6C10 6 10 10 10 11H12" stroke="#000" stroke-width="1.2" stroke-linecap="round" style="display:none"/>
                        <circle cx="11" cy="8" r="1" fill="#000"/>
                        <path d="M9.5 12.5C9.5 12.5 9.5 15.5 11 15.5C12.5 15.5 12.5 12.5 12.5 12.5" stroke="#000" stroke-width="0"/>
                        <path d="M11 6V12L14.5 14" stroke="#000" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </span>
                <span>Довідковий центр</span>
            </a>

            <a href="tel:+380442221100" class="sidebar-nav-item">
                <span class="sidebar-nav-icon">
                    <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                        <path d="M3 2H7.5L9.5 7L7.5 8.5C8.5 10.5 11.5 13.5 13.5 14.5L15 12.5L20 14.5V19C20 19 17 21 13 19C9 17 5 13 3 9C1 5 3 2 3 2Z" stroke="#000" stroke-width="1.2" stroke-linejoin="round"/>
                    </svg>
                </span>
                <span>+38 044 222 11 00</span>
            </a>
        </div>

        <div class="sidebar-card sidebar-card-city">
            <label class="sidebar-city-label" for="citySelect">Місто</label>

            <div class="sidebar-city-right">
                <select id="citySelect" class="sidebar-city-select">
                    <option>Київ</option>
                    <option selected>Одеса</option>
                    <option>Харків</option>
                    <option>Дніпро</option>
                    <option>Львів</option>
                    <option>Запоріжжя</option>
                    <option>Миколаїв</option>
                    <option>Чернігів</option>
                    <option>Полтава</option>
                    <option>Суми</option>
                    <option>Черкаси</option>
                    <option>Житомир</option>
                    <option>Вінниця</option>
                    <option>Івано-Франківськ</option>
                    <option>Тернопіль</option>
                    <option>Хмельницький</option>
                    <option>Чернівці</option>
                    <option>Ужгород</option>
                    <option>Рівне</option>
                    <option>Луцьк</option>
                </select>

                <svg class="sidebar-city-arrow" width="10" height="10" viewBox="0 0 10 10" fill="none">
                    <path d="M2 3.5L5 6.5L8 3.5" stroke="#000" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            </div>
        </div>

        <div class="sidebar-card sidebar-card-links">
            <p class="sidebar-card-title">Інформація про компанію</p>
            <div class="sidebar-links-grid">
                <a href="#">Про нас</a>
                <a href="#">Доставка та оплата</a>
                <a href="#">Контакти</a>
                <a href="#">Вакансії</a>
            </div>
        </div>

        <div class="sidebar-card sidebar-card-links">
            <p class="sidebar-card-title">Допомога</p>
            <div class="sidebar-links-grid">
                <a href="#">Як зробити замовлення</a>
                <a href="#">Повернення</a>
                <a href="#">Гарантія</a>
                <a href="#">Публічна оферта</a>
                <a href="#">Захист персональних даних</a>
            </div>
        </div>

        <div class="sidebar-card sidebar-card-toggle">
            <button class="sidebar-accordion" type="button">
                <span>Сервіси</span>
                <svg width="15" height="15" viewBox="0 0 15 15" fill="none">
                    <path d="M2 5L7.5 10L13 5" stroke="#000" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </button>
        </div>

        <div class="sidebar-card sidebar-card-toggle">
            <button class="sidebar-accordion" type="button">
                <span>Партнерам</span>
                <svg width="15" height="15" viewBox="0 0 15 15" fill="none">
                    <path d="M2 5L7.5 10L13 5" stroke="#000" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </button>
        </div>

        
        @await Html.PartialAsync("_LoadOurApp")
        @await Html.PartialAsync("_SocialMedia")

        @if (isAuth)
        {
            <div class="sidebar-card sidebar-card-logout">
                <form asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="sidebar-logout-btn">
                        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                            <path d="M8 3H4C3.45 3 3 3.45 3 4V16C3 16.55 3.45 17 4 17H8" stroke="#c0392b" stroke-width="1.4" stroke-linecap="round"/>
                            <path d="M13 7L17 10L13 13M17 10H8" stroke="#c0392b" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        Вийти
                    </button>
                </form>
            </div>
        }

    </div>
</aside>
