@using System.Security.Claims
@using BazaR.Helpers
@inject BazaR.Interfaces.IItemRepository ItemRepository

@{
    var isAuth = User.Identity?.IsAuthenticated ?? false;
    var userName = User.Identity?.Name ?? "";
    var allCategories = ItemRepository.GetAllCategories();
    var mainCategories = SidebarCatalogHelper.GetSidebarRootCategories(allCategories ?? Enumerable.Empty<BazaR.Models.Category>());
}

<div class="sidebar-overlay" id="sidebarOverlay"></div>

<aside class="sidebar-drawer" id="sidebarDrawer" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Меню">

    <div class="sidebar-head">
        <div class="sidebar-head-inner">
            @if (isAuth)
            {
                <div class="sidebar-user">
                    <div class="sidebar-user-avatar">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                            <path d="M12 12C14.7614 12 17 9.76142 17 7C17 4.23858 14.7614 2 12 2C9.23858 2 7 4.23858 7 7C7 9.76142 9.23858 12 12 12Z" fill="white"/>
                            <path d="M12 14C7.03 14 3 16.686 3 20V22H21V20C21 16.686 16.97 14 12 14Z" fill="white"/>
                        </svg>
                    </div>
                    <div class="sidebar-user-info">
                        <span class="sidebar-user-name">@userName</span>
                        <a asp-controller="Profile" asp-action="Profile" class="sidebar-user-link">Мій профіль</a>
                    </div>
                </div>
            }
            else
            {
                <div class="sidebar-auth-block">
                    <div class="sidebar-auth-icon">
                        <svg width="45" height="45" viewBox="0 0 45 45" fill="none">
                            <circle cx="22.5" cy="22.5" r="22.5" fill="white" fill-opacity="0.15"/>
                            <path d="M22.5 22.5C25.2614 22.5 27.5 20.2614 27.5 17.5C27.5 14.7386 25.2614 12.5 22.5 12.5C19.7386 12.5 17.5 14.7386 17.5 17.5C17.5 20.2614 19.7386 22.5 22.5 22.5Z" fill="white"/>
                            <path d="M22.5 25C17.53 25 13.5 27.686 13.5 31V33H31.5V31C31.5 27.686 27.47 25 22.5 25Z" fill="white"/>
                        </svg>
                    </div>
                    <div class="sidebar-auth-text">
                        <p>Авторизуйтесь для отримання розширених можливостей</p>
                        <div class="sidebar-auth-links">
                            <button type="button" class="sidebar-auth-btn" data-auth-open="login">Вхід</button>
                            <span class="sidebar-auth-sep"></span>
                            <button type="button" class="sidebar-auth-btn" data-auth-open="register">Реєстрація</button>
                        </div>
                    </div>
                </div>
            }
        </div>
        <button class="sidebar-close" id="sidebarClose" aria-label="Закрити меню">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M1 1L17 17M17 1L1 17" stroke="white" stroke-width="2" stroke-linecap="round" />
            </svg>
        </button>
    </div>

    <div class="sidebar-premium">
        <a asp-controller="Profile" asp-action="Premium" class="sidebar-premium__a">
            <div class="sidebar-premium-text">
                <span class="sidebar-premium-title">PREMIUM</span>
                <span class="sidebar-premium-sub">Безкоштовна доставка весь рік</span>
            </div>
            <svg class="sidebar-premium-arrow" width="33" height="33" viewBox="0 0 33 33" fill="none">
                <path d="M7 16.5H26M26 16.5L18 8.5M26 16.5L18 24.5" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </a>
    </div>

    <div class="sidebar-body">

        @* 1. Велика картка: категорії (як у макеті) *@
        <nav class="sidebar-card sidebar-card--catalog" aria-label="Каталог категорій">
            <ul class="sidebar-cat-list">
                @foreach (var category in mainCategories)
                {
                    <li class="sidebar-cat-item">
                        <a href="@SidebarCatalogHelper.GetSidebarCategoryHref(Url, category)" class="sidebar-cat-link">
                            <span class="sidebar-cat-icon" aria-hidden="true">
                                @if (!string.IsNullOrEmpty(category.IconUrl))
                                {
                                    if (CategoryDisplayHelper.IsWebImagePath(category.IconUrl))
                                    {
                                        <img src="@category.IconUrl" alt="" width="22" height="22" loading="lazy" />
                                    }
                                    else
                                    {
                                        <i class="bi @category.IconUrl"></i>
                                    }
                                }
                                else
                                {
                                    <i class="bi bi-grid"></i>
                                }
                            </span>
                            <span class="sidebar-cat-text">@SidebarCatalogHelper.GetSidebarRootDisplayName(category)</span>
                        </a>
                    </li>
                }
            </ul>
        </nav>

        @* 2. Окрема тонка картка одразу під категоріями (макет) *@
        <div class="sidebar-card sidebar-card--help-row">
            <a asp-controller="Site" asp-action="Privacy" class="sidebar-help-center-link">
                <span class="sidebar-help-center-link__icon" aria-hidden="true"><i class="bi bi-question-circle"></i></span>
                <span>Довідковий центр</span>
            </a>
        </div>

        @* 3. Ласкаво просимо (гість) *@
        @if (!isAuth)
        {
            <div class="sidebar-card sidebar-card--welcome">
                <h3 class="sidebar-welcome-title">Ласкаво просимо!</h3>
                <p class="sidebar-welcome-text">Увійдіть, щоб отримувати рекомендації, персональні бонуси та знижки.</p>
                <button type="button" class="sidebar-welcome-btn" data-auth-open="login">Увійдіть до особистого кабінету</button>
            </div>
        }

        @* 4. Окрема картка: додатки *@
        <div class="sidebar-card sidebar-card--app-panel">
            @await Html.PartialAsync("_LoadOurApp")
        </div>

        @* 5. Окрема картка: соцмережі *@
        <div class="sidebar-card sidebar-card--social-wrap">
            @await Html.PartialAsync("_SocialMedia")
        </div>

        @* 6. Одна картка: Допомога + Компанія + Сервіси + Партнерам + платіжний рядок унизу (як у макеті) *@
        <div class="sidebar-card sidebar-card--link-groups">
            <section class="sidebar-link-group">
                <h4 class="sidebar-link-group__title">Допомога</h4>
                <div class="sidebar-link-group__list">
                    <a asp-controller="Site" asp-action="Privacy">Доставка та оплата</a>
                    <a href="#">Кредит</a>
                    <a href="#">Гарантія</a>
                    <a href="#">Повернення товару</a>
                    <a href="#">Сервісні центри</a>
                    <a asp-controller="Profile" asp-action="Orders">Відстежити замовлення</a>
                </div>
            </section>
            <section class="sidebar-link-group">
                <h4 class="sidebar-link-group__title">Інформація про компанію</h4>
                <div class="sidebar-link-group__list">
                    <a href="#">Про нас</a>
                    <a asp-controller="Site" asp-action="Privacy">Умови використання сайту</a>
                    <a href="#">Вакансії</a>
                    <a href="#">Контакти</a>
                </div>
            </section>
            <section class="sidebar-link-group">
                <h4 class="sidebar-link-group__title">Сервіси</h4>
                <div class="sidebar-link-group__list">
                    <a asp-controller="Profile" asp-action="BonusAccount">Бонусний рахунок</a>
                    <a asp-controller="Profile" asp-action="Premium">Premium</a>
                    <a href="#">Подарункові сертифікати</a>
                    <a href="#">Обмін</a>
                    <a href="#">BazaR Travel</a>
                </div>
            </section>
            <section class="sidebar-link-group">
                <h4 class="sidebar-link-group__title">Партнерам</h4>
                <div class="sidebar-link-group__list">
                    <a href="#">Франчайзинг</a>
                    <a href="#">Продавати на BazaR</a>
                    <a href="#">Співпраця з нами</a>
                </div>
            </section>
            <div class="sidebar-pay-logos sidebar-pay-logos--in-card" aria-hidden="true">
                <span class="sidebar-pay-fake">Mastercard SecureCode</span>
                <span class="sidebar-pay-fake">Verified by VISA</span>
            </div>
        </div>

        @if (isAuth)
        {
            <div class="sidebar-card sidebar-card-logout">
                <form asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="sidebar-logout-btn">
                        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                            <path d="M8 3H4C3.45 3 3 3.45 3 4V16C3 16.55 3.45 17 4 17H8" stroke="#c0392b" stroke-width="1.4" stroke-linecap="round"/>
                            <path d="M13 7L17 10L13 13M17 10H8" stroke="#c0392b" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        Вийти
                    </button>
                </form>
            </div>
        }

    </div>
</aside>
