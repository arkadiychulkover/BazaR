@model BazaR.Models.Item

@{
    // Проверяем наличие изображения
    var imageUrl = !string.IsNullOrEmpty(Model.ImageUrl) ? Model.ImageUrl : "/images/no-image.png";

    // Проверяем наличие бренда
    var brandName = Model.Brand?.Name ?? "Бренд не вказано";

    // Вычисляем средний рейтинг
    var avgRating = Model.Reviews != null && Model.Reviews.Any()
        ? Model.Reviews.Average(r => r.Rating)
        : 0;
    var reviewsCount = Model.Reviews?.Count ?? 0;

    var isInCart = ViewBag.IsInCart != null && (bool)ViewBag.IsInCart;
    var isInWishlist = ViewBag.IsInWishlist != null && (bool)ViewBag.IsInWishlist;
    var user = ViewBag.User as BazaR.Models.User;
}

<div class="item-card h-100">
    <div class="card h-100 shadow-sm position-relative">
        <!-- Бейдж скидки (если есть) -->
        @if (ViewBag.HasDiscount != null && ViewBag.HasDiscount)
        {
            <div class="position-absolute top-0 start-0 m-2 badge bg-danger z-index-1">
                -@ViewBag.DiscountPercentage%
            </div>
        }

        <!-- Изображение товара -->
        <div class="item-card-img position-relative overflow-hidden" style="height: 200px;">
            <a asp-controller="Site" asp-action="ItemDetails" asp-route-id="@Model.Id">
                <img src="@imageUrl"
                     class="card-img-top w-100 h-100"
                     alt="@Model.Name"
                     style="object-fit: cover; transition: transform 0.3s;"
                     onerror="this.onerror=null; this.src='/images/no-image.png';">
            </a>

            <!-- Кнопка избранного -->
            @if (user != null)
            {
                <button class="wishlist-btn position-absolute top-0 end-0 m-2 btn btn-light rounded-circle p-0"
                        style="width: 35px; height: 35px;"
                        data-item-id="@Model.Id"
                        onclick="addToWishlist(this)"
                        title="Додати до обраного">
                    <i class="bi bi-heart @(isInWishlist ? "text-danger" : "")" style="font-size: 1.2rem;"></i>
                </button>
            }
            else
            {
                <button class="wishlist-btn position-absolute top-0 end-0 m-2 btn btn-light rounded-circle p-0"
                        style="width: 35px; height: 35px;"
                        data-bs-toggle="modal"
                        data-bs-target="#loginModal"
                        title="Увійдіть, щоб додати до обраного">
                    <i class="bi bi-heart" style="font-size: 1.2rem;"></i>
                </button>
            }

            <!-- Бейдж наличия -->
            @if (!Model.IsAvailable)
            {
                <div class="position-absolute top-0 start-0 m-2 badge bg-danger">
                    Немає в наявності
                </div>
            }

            <!-- Бейдж новинки (если товар новый) -->
            @if (Model.Id > 1000)
            {
                <div class="position-absolute bottom-0 start-0 m-2 badge bg-success">
                    Новинка
                </div>
            }
        </div>

        <!-- Информация о товаре -->
        <div class="card-body d-flex flex-column">
            <!-- Бренд и код -->
            <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="badge bg-secondary text-truncate" style="max-width: 120px;" title="@brandName">
                    @brandName
                </span>
                <small class="text-muted">#@Model.Id</small>
            </div>

            <!-- Название товара -->
            <h6 class="card-title item-title mb-2" style="height: 40px;">
                <a asp-controller="Site"
                   asp-action="ItemDetails"
                   asp-route-id="@Model.Id"
                   class="text-decoration-none text-dark fw-normal stretched-link">
                    @Model.Name
                </a>
            </h6>

            <!-- Рейтинг -->
            @if (reviewsCount > 0)
            {
                <div class="mb-2">
                    <small class="text-warning">
                        @for (int i = 1; i <= 5; i++)
                        {
                            if (i <= Math.Round(avgRating))
                            {
                                <i class="bi bi-star-fill"></i>
                            }
                            else if (i - 0.5 <= avgRating)
                            {
                                <i class="bi bi-star-half"></i>
                            }
                            else
                            {
                                <i class="bi bi-star"></i>
                            }
                        }
                        <span class="text-muted ms-1">(@reviewsCount)</span>
                    </small>
                </div>
            }
            else
            {
                <div class="mb-2">
                    <small class="text-muted">
                        <i class="bi bi-star"></i>
                        <i class="bi bi-star"></i>
                        <i class="bi bi-star"></i>
                        <i class="bi bi-star"></i>
                        <i class="bi bi-star"></i>
                        <span class="ms-1">(0)</span>
                    </small>
                </div>
            }

            <!-- Цена -->
            <div class="item-price mt-auto">
                <span class="price-current fw-bold fs-5 text-primary">
                    @Model.Price.ToString("N0") ₴
                </span>
                @if (Model.Garantia > 0)
                {
                    <small class="text-muted d-block">
                        <i class="bi bi-shield-check"></i> Гарантія: @Model.Garantia міс.
                    </small>
                }
            </div>
        </div>

        <!-- Кнопки действий -->
        <div class="card-footer bg-transparent border-0 pt-0">
            <div class="d-grid gap-2">
                @if (Model.IsAvailable)
                {
                    <button class="btn @(isInCart ? "btn-success" : "btn-primary") btn-sm add-to-cart"
                            data-item-id="@Model.Id"
                            onclick="addToCart(this, @Model.Id)"
                            @(isInCart ? "disabled" : "")>
                        @if (isInCart)
                        {
                            <i class="bi bi-check-lg">Вже в кошику</i>
                            
                                            }
                        else
                        {
                            <i class="bi bi-cart-plus">В кошик</i>
                            
                                        }
                    </button>
                }
                else
                {
                    <button class="btn btn-secondary btn-sm" disabled>
                        <i class="bi bi-cart-x"></i> Немає в наявності
                    </button>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .item-card {
        transition: all 0.3s ease;
        opacity: 1 !important;
    }

        .item-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.15) !important;
        }

            .item-card:hover .card-img-top {
                transform: scale(1.05);
            }

    .wishlist-btn {
        transition: all 0.2s;
        z-index: 10;
        border: 1px solid #dee2e6;
        background-color: rgba(255, 255, 255, 0.9);
    }

        .wishlist-btn:hover {
            background-color: #dc3545 !important;
            border-color: #dc3545 !important;
        }

            .wishlist-btn:hover i {
                color: white !important;
            }

        .wishlist-btn .bi-heart.text-danger {
            color: #dc3545 !important;
        }

    .item-title {
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        line-height: 1.4;
    }

        .item-title a:hover {
            color: #0d6efd !important;
        }

    .price-current {
        font-size: 1.25rem;
    }

    .badge {
        font-weight: 500;
        z-index: 5;
    }

    .z-index-1 {
        z-index: 15;
    }
</style>

<script>
    function addToCart(button, itemId) {
        // Показываем индикатор загрузки
        var originalText = button.innerHTML;
        button.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>';
        button.disabled = true;

        // Получаем токен
        var token = $('input[name="__RequestVerificationToken"]').val();

        $.ajax({
            url: '@Url.Action("AddToCart", "Site")',
            type: 'POST',
            data: {
                itemId: itemId,
                __RequestVerificationToken: token
            },
            success: function(response) {
                if (response.success) {
                    // Обновляем счетчик корзины
                    $('#cartCount').text(response.cartCount);
                    // Меняем текст кнопки
                    button.innerHTML = '<i class="bi bi-check-lg"></i> Вже в кошику';
                    button.classList.remove('btn-primary');
                    button.classList.add('btn-success');
                    button.disabled = true;
                    showNotification('Товар додано до кошика', 'success');
                } else if (response.requireLogin) {
                    $('#loginModal').modal('show');
                    button.innerHTML = originalText;
                    button.disabled = false;
                } else {
                    button.innerHTML = originalText;
                    button.disabled = false;
                    showNotification(response.message || 'Помилка при додаванні до кошика', 'danger');
                }
            },
            error: function(xhr, status, error) {
                console.error('Error:', error);
                button.innerHTML = originalText;
                button.disabled = false;
                showNotification('Помилка при додаванні до кошика', 'danger');
            }
        });
    }

    function addToWishlist(element) {
        var itemId = $(element).data('item-id');
        var icon = $(element).find('i');
        var token = $('input[name="__RequestVerificationToken"]').val();

        $.ajax({
            url: '@Url.Action("AddToWishlist", "Site")',
            type: 'POST',
            data: {
                id: itemId,
                __RequestVerificationToken: token
            },
            success: function(response) {
                if (response.success) {
                    icon.toggleClass('text-danger');
                    $('#wishlistCount').text(response.wishlistCount);
                    showNotification('Товар додано до обраного', 'success');
                } else if (response.requireLogin) {
                    $('#loginModal').modal('show');
                } else {
                    showNotification(response.message || 'Помилка при додаванні до обраного', 'danger');
                }
            },
            error: function(xhr, status, error) {
                console.error('Error:', error);
                showNotification('Помилка при додаванні до обраного', 'danger');
            }
        });
    }

    function showNotification(message, type) {
        // Убираем старые уведомления
        $('.custom-notification').remove();

        // Создаем новое уведомление
        var notification = $('<div class="custom-notification position-fixed top-0 end-0 p-3" style="z-index: 9999;">' +
            '<div class="toast show align-items-center text-white bg-' + type + ' border-0" role="alert">' +
            '<div class="d-flex">' +
            '<div class="toast-body">' + message + '</div>' +
            '<button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>' +
            '</div>' +
            '</div>' +
            '</div>');

        $('body').append(notification);

        setTimeout(function() {
            notification.fadeOut(function() {
                $(this).remove();
            });
        }, 3000);
    }

    // Инициализация при загрузке страницы
    $(document).ready(function() {
        // Добавляем плавное появление карточек
        $('.item-card').each(function(index) {
            $(this).css({
                'animation': 'fadeInUp 0.5s ease forwards',
                'animation-delay': (index * 0.1) + 's'
            });
        });
    });
</script>

