@model BazaR.ViewModels.MobileMoreMenuViewModel

<div class="mobile-more-menu">
    <div class="mobile-more-card">
        <a asp-controller="Profile" asp-action="Profile" class="mobile-more-row mobile-more-row--user">
            <span class="mobile-more-row__icon" aria-hidden="true"><i class="bi bi-person-circle"></i></span>
            <span class="mobile-more-row__text">@Model.DisplayName</span>
        </a>
    </div>

    <div class="mobile-more-card">
        <a asp-controller="Profile" asp-action="BonusAccount" class="mobile-more-row">
            <span class="mobile-more-row__icon" aria-hidden="true"><i class="bi bi-star"></i></span>
            <span class="mobile-more-row__text">Мій бонусний рахунок</span>
        </a>
        <a asp-controller="Profile" asp-action="Premium" class="mobile-more-row">
            <span class="mobile-more-row__icon mobile-more-row__icon--p" aria-hidden="true">P</span>
            <span class="mobile-more-row__text">Підписка Premium</span>
        </a>
        <a asp-controller="Profile" asp-action="Orders" class="mobile-more-row">
            <span class="mobile-more-row__icon" aria-hidden="true"><i class="bi bi-file-earmark-text"></i></span>
            <span class="mobile-more-row__text">Мої замовлення</span>
        </a>
        <a asp-controller="Profile" asp-action="Wallet" class="mobile-more-row">
            <span class="mobile-more-row__icon" aria-hidden="true"><i class="bi bi-credit-card"></i></span>
            <span class="mobile-more-row__text">Мій гаманець</span>
        </a>
        <a asp-controller="Site" asp-action="Privacy" class="mobile-more-row">
            <span class="mobile-more-row__icon" aria-hidden="true"><i class="bi bi-shield-check"></i></span>
            <span class="mobile-more-row__text">Сервіс та повернення товару</span>
        </a>
        <a asp-controller="Profile" asp-action="Messages" class="mobile-more-row">
            <span class="mobile-more-row__icon" aria-hidden="true"><i class="bi bi-envelope"></i></span>
            <span class="mobile-more-row__text">Моє листування</span>
            @if (Model.UnreadMessages > 0)
            {
                <span class="mobile-more-badge">@Model.UnreadMessages</span>
            }
        </a>
        <a asp-controller="Site" asp-action="Browse" class="mobile-more-row">
            <span class="mobile-more-row__icon" aria-hidden="true"><i class="bi bi-sliders"></i></span>
            <span class="mobile-more-row__text">Порівняння</span>
        </a>
    </div>

    <div class="mobile-more-card">
        <a asp-controller="Profile" asp-action="Profile" class="mobile-more-row">
            <span class="mobile-more-row__icon" aria-hidden="true"><i class="bi bi-shop"></i></span>
            <span class="mobile-more-row__text">Адреси та час роботи</span>
        </a>
        <a asp-controller="Site" asp-action="Privacy" class="mobile-more-row">
            <span class="mobile-more-row__icon" aria-hidden="true"><i class="bi bi-info-circle"></i></span>
            <span class="mobile-more-row__text">Інформація</span>
        </a>
        <a asp-controller="Profile" asp-action="Profile" class="mobile-more-row">
            <span class="mobile-more-row__icon" aria-hidden="true"><i class="bi bi-gear"></i></span>
            <span class="mobile-more-row__text">Налаштування</span>
        </a>
    </div>
</div>
