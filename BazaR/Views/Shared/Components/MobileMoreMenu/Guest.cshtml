<div class="mobile-more-menu">
    <div class="mobile-more-card">
        <button type="button" class="mobile-more-row mobile-more-row--btn" data-auth-open="login" data-more-sheet-close-auth>
            <span class="mobile-more-row__icon" aria-hidden="true"><i class="bi bi-box-arrow-in-right"></i></span>
            <span class="mobile-more-row__text">Увійти</span>
        </button>
        <button type="button" class="mobile-more-row mobile-more-row--btn" data-auth-open="register" data-more-sheet-close-auth>
            <span class="mobile-more-row__icon" aria-hidden="true"><i class="bi bi-person-plus"></i></span>
            <span class="mobile-more-row__text">Зареєструватися</span>
        </button>
        <a asp-controller="Site" asp-action="Browse" class="mobile-more-row">
            <span class="mobile-more-row__icon" aria-hidden="true"><i class="bi bi-grid"></i></span>
            <span class="mobile-more-row__text">Каталог</span>
        </a>
    </div>
</div>