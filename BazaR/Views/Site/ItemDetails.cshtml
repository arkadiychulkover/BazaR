@model BazaR.ViewModels.ItemDetailsViewModel

@{
    ViewData["Title"] = Model.Item.Name ?? "Товар";
    var item = Model.Item;
    var images = Model.Images;
    var category = Model.Category;
    var related = Model.RelatedItems;
    var recommended = Model.RecommendedItems;
    var seller = Model.Seller;
    var isInCart = Model.IsInCart;
    var isInWishlist = Model.IsInWishlist;
    var isAuthenticated = Model.IsAuthenticated;
    var avgRating = Model.AverageRating;
    var reviewCount = Model.ReviewCount;

    var mainImage = images.FirstOrDefault() ?? WebPaths.DefaultItemImage;

    string SellerLabel(BazaR.Models.SellerType t) => t switch
    {
        BazaR.Models.SellerType.bazar => "BazaR",
        BazaR.Models.SellerType.otherSeller => "Інший продавець",
        BazaR.Models.SellerType.otherSellerOnSklad => "Інший продавець (зі складу)",
        _ => "Продавець"
    };

    string CharDisplayName(string key) => key?.ToLowerInvariant() switch
    {
        "processor" => "Процесор",
        "ram" => "Об'єм оперативної пам'яті",
        "storage" => "Накопичувач",
        "screen_size" => "Діагональ екрану",
        "color" => "Колір",
        "memory" => "Пам'ять",
        "graphics" => "Відеокарта",
        _ => string.IsNullOrEmpty(key) ? "" : System.Globalization.CultureInfo.InvariantCulture.TextInfo.ToTitleCase(key.Replace('_', ' '))
    };

    const int pdpCharsInitial = 5;
    var charsOrdered = item.Characteristics.OrderBy(c => c.Id).ToList();
    var charStorage = charsOrdered.FirstOrDefault(c => c.Key.Equals("storage", StringComparison.OrdinalIgnoreCase))?.Value;
    var charRam = charsOrdered.FirstOrDefault(c => c.Key.Equals("ram", StringComparison.OrdinalIgnoreCase))?.Value;
    var charProcessor = charsOrdered.FirstOrDefault(c => c.Key.Equals("processor", StringComparison.OrdinalIgnoreCase))?.Value;

    var descTrimmed = item.Desc?.Trim() ?? "";
    var hasDesc = descTrimmed.Length > 0;

    var uk = new System.Globalization.CultureInfo("uk-UA");
    var reviewsOrdered = item.Reviews.OrderByDescending(x => x.CreatedAt).ToList();
    var useDemoReviews = !reviewsOrdered.Any();
    // Лічильник завжди з БД; «три відгуки» без записів у БД — лише приклад верстки (див. блок нижче).
    var displayReviewCount = reviewCount;

    string[] demoPros = { "Корпус, додаткове місце під SSD", "Тиха робота в офісних задачах, гарна автономність", "Зручна клавіатура, приємне покриття корпусу" };
    string[] demoCons = { "Слабкий екран, один слот пам'яті", "Кулер чутно під навантаженням", "Порти лише з одного боку" };
    string[] demoBodies = {
        "Купував для роботи та навчання. За два тижні — без нарікань: швидко завантажується, Wi‑Fi стабільний. Вентилятор інколи шумить під навантаженням, але для документів і браузера майже не чутно.",
        "Добре зібраний ноутбук за свої гроші. Екран для фільмів підійде, для дизайну — беріть з кращою матрицею. Клавіатура приємна на дотик, тачпад точний.",
        "Доставка швидка, упаковка ціла. Користуюся щодня: зум, таблиці, листування — все літає. Єдине — хотілося б яскравішого дисплея на сонці."
    };
}

@Html.AntiForgeryToken()

<div class="pdp">

    <!-- ===== BREADCRUMB ===== -->
    <nav class="pdp-bc">
        <a href="@Url.Action("Index", "Site")"><i class="bi bi-house-door"></i></a>
        @if (category?.ParentCategory != null)
        {
            <span class="pdp-bc__sep">&rsaquo;</span>
            <a href="@Url.Action("Browse", "Site", new { categoryId = category.ParentCategoryId })">@category.ParentCategory.Name</a>
        }
        @if (category != null)
        {
            <span class="pdp-bc__sep">&rsaquo;</span>
            <a href="@Url.Action("Browse", "Site", new { categoryId = category.Id })">@category.Name</a>
        }
    </nav>

    <!-- ===== TITLE + CODE + SELLER (як на макеті) ===== -->
    <div class="pdp-hero">
        <div class="pdp-hero__left">
            <h1 class="pdp-h1">@item.Name</h1>
            <div class="pdp-code">Код: @item.Id</div>
        </div>
        <div class="pdp-hero__right">
            <div class="pdp-seller">
                <span class="pdp-seller__lbl">Продавець:</span>
                <a href="#" class="pdp-seller__name">@(SellerLabel(item.SellerType))</a>
            </div>
        </div>
    </div>

    <!-- ===== TAB BAR ===== -->
    <div class="pdp-tabs">
        <div class="pdp-tabs__left">
            <a href="#pdp-about" class="pdp-tabs__link pdp-tabs__link--active">Усе про товар</a>
            <a href="#pdp-chars-section" class="pdp-tabs__link">Характеристики</a>
            <a href="#pdp-reviews-section" class="pdp-tabs__link">Відгуки</a>
        </div>
    </div>

    <!-- ===== TOP: GALLERY + SPECS (left) | BUY PANEL (right) ===== -->
    <div class="pdp-top" id="pdp-about">

        <div class="pdp-top__left">
            <!-- Gallery -->
            <div class="pdp-gallery-shell">
            <div class="pdp-gallery">
                <div class="pdp-gallery__thumbs">
                    @for (int i = 0; i < images.Count; i++)
                    {
                        <button class="pdp-gallery__thumb @(i == 0 ? "pdp-gallery__thumb--act" : "")"
                                onclick="pdpImg(this,'@images[i]')">
                            <img src="@images[i]" alt="" onerror="this.onerror=null;this.src='@WebPaths.DefaultItemImage';" />
                        </button>
                    }
                    @if (!images.Any())
                    {
                        <button class="pdp-gallery__thumb pdp-gallery__thumb--act">
                            <img src="@WebPaths.DefaultItemImage" alt="" />
                        </button>
                    }
                </div>
                <div class="pdp-gallery__main">
                    <img id="pdpMainImg" src="@mainImage" alt="@item.Name"
                         onerror="this.onerror=null;this.src='@WebPaths.DefaultItemImage';" />
                </div>
            </div>
            </div>

            <!-- Характеристики — під галереєю, як на макеті -->
            @if (charsOrdered.Any())
            {
                <div class="pdp-chars-card" id="pdp-chars-section">
                    <div class="pdp-chars-card__inner">
                        <div class="pdp-chars-list-wrap">
                            <h2 class="pdp-chars-card__title">Основні характеристики:</h2>
                            <div class="pdp-chars-list">
                                @for (var ci = 0; ci < charsOrdered.Count; ci++)
                                {
                                    var ch = charsOrdered[ci];
                                    var rowClass = ci >= pdpCharsInitial ? "pdp-char-row pdp-char-row--extra" : "pdp-char-row";
                                    <div class="@rowClass" data-char-index="@ci">
                                        <span class="pdp-char-row__k">@CharDisplayName(ch.Key)</span>
                                        <span class="pdp-char-row__dots" aria-hidden="true"></span>
                                        <span class="pdp-char-row__v">@ch.Value</span>
                                    </div>
                                }
                            </div>
                            @if (charsOrdered.Count > pdpCharsInitial)
                            {
                                <button type="button" class="pdp-chars-toggle" id="pdpCharsToggle" aria-expanded="false">
                                    Показати ще
                                </button>
                            }
                            <button type="button"
                                    class="pdp-chars-all-btn"
                                    id="pdpCharsFullToggle"
                                    aria-expanded="false"
                                    aria-controls="pdpCharsFullPanel">
                                <span class="pdp-chars-all-btn__text">Всі характеристики</span>
                                <i class="bi bi-chevron-down pdp-chars-all-btn__chev" aria-hidden="true"></i>
                            </button>
                        </div>
                        @{
                            var hasBadges = !string.IsNullOrEmpty(charProcessor) || !string.IsNullOrEmpty(charRam) || !string.IsNullOrEmpty(charStorage);
                        }
                        @if (hasBadges)
                        {
                            <aside class="pdp-chars-badges" aria-label="Ключові особливості">
                                @if (!string.IsNullOrEmpty(charProcessor))
                                {
                                    <div class="pdp-chars-badge">
                                        <i class="bi bi-cpu-fill pdp-chars-badge__icon"></i>
                                        <span class="pdp-chars-badge__label">@charProcessor</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(charRam))
                                {
                                    <div class="pdp-chars-badge">
                                        <span class="pdp-chars-badge__num">8</span>
                                        <span class="pdp-chars-badge__unit">ядер</span>
                                        <span class="pdp-chars-badge__label">RAM @charRam</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(charStorage))
                                {
                                    <div class="pdp-chars-badge">
                                        <span class="pdp-chars-badge__chip-text">SSD</span>
                                        <span class="pdp-chars-badge__label">@charStorage</span>
                                    </div>
                                }
                            </aside>
                        }
                    </div>

                    <div class="pdp-chars-full-panel" id="pdpCharsFullPanel" hidden>
                        <div class="pdp-chars-full-panel__head">
                            <h3 class="pdp-chars-full-panel__title">@item.Name</h3>
                            <p class="pdp-chars-full-panel__sub">Повний перелік характеристик</p>
                        </div>
                        <div class="pdp-chars-full-panel__body">
                            <section class="pdp-chars-modal__section">
                                <h3 class="pdp-chars-modal__h">Технічні характеристики</h3>
                                <div class="pdp-chars-modal__list">
                                    @foreach (var ch in charsOrdered)
                                    {
                                        <div class="pdp-chars-modal__row">
                                            <span class="pdp-chars-modal__k">@CharDisplayName(ch.Key)</span>
                                            <span class="pdp-chars-modal__dots" aria-hidden="true"></span>
                                            <span class="pdp-chars-modal__v">@ch.Value</span>
                                        </div>
                                    }
                                </div>
                            </section>
                            @if (hasDesc)
                            {
                                <section class="pdp-chars-modal__section">
                                    <h3 class="pdp-chars-modal__h">Опис</h3>
                                    <div class="pdp-chars-modal__desc">@descTrimmed</div>
                                </section>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- RIGHT — Info panel -->
        <div class="pdp-right">

            <!-- Price row -->
            <div class="pdp-price-block">
                @if (item.Colors != null && item.Colors.Any())
                {
                    <div class="pdp-swatches" aria-label="Кольори">
                        @foreach (var c in item.Colors.Take(6))
                        {
                            var sw = c.Color?.Trim() ?? "";
                            <button type="button" class="pdp-swatch" title="Варіант">
                                @if (sw.StartsWith("http", StringComparison.OrdinalIgnoreCase) || sw.StartsWith("/", StringComparison.Ordinal) || sw.StartsWith("~", StringComparison.Ordinal))
                                {
                                    <span class="pdp-swatch__img" style="background-image:url('@sw')"></span>
                                }
                                else
                                {
                                    <span class="pdp-swatch__dot" style="background-color:@(sw.Length > 0 && sw.StartsWith("#") ? sw : "#ccc")"></span>
                                }
                            </button>
                        }
                    </div>
                }
                <div class="pdp-price-block__top">
                    <span class="pdp-price">@item.Price.ToString("N0")<span class="pdp-price__cur">₴</span></span>
                </div>

                <div class="pdp-price-block__cta">
                    <div class="pdp-price-block__cta-primary">
                        <button type="button"
                                class="pdp-btn pdp-btn--buy pdp-btn--buy-main @(!item.IsAvailable ? "pdp-btn--disabled" : "")"
                                data-item-id="@item.Id"
                                onclick="addToCart(this, @item.Id)"
                                @(!item.IsAvailable ? "disabled" : "")>
                            @(isInCart ? "У кошику" : "Купити")
                        </button>
                        <button type="button"
                                class="pdp-btn pdp-btn--credit pdp-btn--credit-main @(!item.IsAvailable ? "pdp-btn--disabled" : "")">
                            Купити в кредит
                        </button>
                    </div>
                    <div class="pdp-price-block__cta-tools" role="group" aria-label="Дії з товаром">
                        @if (isAuthenticated)
                        {
                            <button type="button"
                                    class="pdp-btn-icon pdp-btn-icon--tool @(isInWishlist ? "pdp-btn-icon--tool-active" : "")"
                                    data-item-id="@item.Id"
                                    onclick="addToWishlist(this)"
                                    title="В обране"
                                    aria-pressed="@(isInWishlist ? "true" : "false")">
                                <i class="bi @(isInWishlist ? "bi-heart-fill" : "bi-heart") pdp-icon-wish" aria-hidden="true"></i>
                            </button>
                        }
                        else
                        {
                            <button type="button"
                                    class="pdp-btn-icon pdp-btn-icon--tool"
                                    data-open-login="true"
                                    title="Увійдіть, щоб додати в обране"
                                    aria-pressed="false">
                                <i class="bi bi-heart pdp-icon-wish" aria-hidden="true"></i>
                            </button>
                        }
                        <button type="button" class="pdp-btn-icon pdp-btn-icon--tool" title="Порівняти">
                            <i class="bi bi-bar-chart-line pdp-icon-compare" aria-hidden="true"></i>
                        </button>
                    </div>
                </div>

                @if (item.IsAvailable)
                {
                    <div class="pdp-stock pdp-stock--yes"><i class="bi bi-check-circle-fill" aria-hidden="true"></i> Є в наявності</div>
                }
                else
                {
                    <div class="pdp-stock pdp-stock--no"><i class="bi bi-x-circle-fill" aria-hidden="true"></i> Немає в наявності</div>
                }

                <div class="pdp-pay-badges" aria-label="Способи оплати та кредитування">
                    @for (var creditIcon = 1; creditIcon <= 6; creditIcon++)
                    {
                        <span class="pdp-pay-badge pdp-pay-badge--img">
                            <img src="@WebPaths.PaymentCreditIcon(creditIcon)"
                                 alt=""
                                 width="36"
                                 height="36"
                                 loading="lazy"
                                 decoding="async" />
                        </span>
                    }
                </div>
            </div>

            <!-- Services block (макет) -->
            <div class="pdp-card pdp-card--services">
                <!-- Група 1: Гарантія -->
                <div class="pdp-svc-group" data-pdp-svc-group>
                    <div class="pdp-svc-group__head">
                        <label class="pdp-svc-group__toggle">
                            <input type="checkbox" class="pdp-svc-group__cb" name="pdp_svc_warranty_group" checked />
                            <span class="pdp-svc-group__cb-box"><i class="bi bi-check-lg"></i></span>
                            <span class="pdp-svc-group__title">Сервіси подовження гарантії</span>
                        </label>
                        <button type="button" class="pdp-svc-info" title="Детальніше" aria-label="Інформація про сервіс"><i class="bi bi-info-circle"></i></button>
                    </div>
                    <div class="pdp-svc-group__subs">
                        <label class="pdp-svc-sub">
                            <input type="radio" class="pdp-svc-sub__inp" name="pdp_warranty" value="1year" />
                            <span class="pdp-svc-sub__dot"></span>
                            <span class="pdp-svc-sub__text">Подовження гарантії на 1 рік</span>
                        </label>
                        <label class="pdp-svc-sub">
                            <input type="radio" class="pdp-svc-sub__inp" name="pdp_warranty" value="2years" />
                            <span class="pdp-svc-sub__dot"></span>
                            <span class="pdp-svc-sub__text">Подовження гарантії на 2 роки</span>
                        </label>
                    </div>
                </div>

                <!-- Група 2: Дистанційне налаштування ПК -->
                <div class="pdp-svc-group" data-pdp-svc-group>
                    <div class="pdp-svc-group__head">
                        <label class="pdp-svc-group__toggle">
                            <input type="checkbox" class="pdp-svc-group__cb" name="pdp_svc_remote_group" />
                            <span class="pdp-svc-group__cb-box"><i class="bi bi-check-lg"></i></span>
                            <span class="pdp-svc-group__title">Дистанційне налаштування ПК</span>
                        </label>
                        <button type="button" class="pdp-svc-info" title="Детальніше" aria-label="Інформація про сервіс"><i class="bi bi-info-circle"></i></button>
                    </div>
                    <div class="pdp-svc-group__subs">
                        <label class="pdp-svc-sub">
                            <input type="checkbox" class="pdp-svc-sub__inp" name="pdp_remote" value="gamers" />
                            <span class="pdp-svc-sub__box"><i class="bi bi-check-lg"></i></span>
                            <span class="pdp-svc-sub__text">Дистанційне налаштування ПК для геймерів</span>
                        </label>
                        <label class="pdp-svc-sub">
                            <input type="checkbox" class="pdp-svc-sub__inp" name="pdp_remote" value="office" />
                            <span class="pdp-svc-sub__box"><i class="bi bi-check-lg"></i></span>
                            <span class="pdp-svc-sub__text">Дистанційне налаштування ПК для офісу та роботи</span>
                        </label>
                        <label class="pdp-svc-sub">
                            <input type="checkbox" class="pdp-svc-sub__inp" name="pdp_remote" value="home" />
                            <span class="pdp-svc-sub__box"><i class="bi bi-check-lg"></i></span>
                            <span class="pdp-svc-sub__text">Дистанційне налаштування домашнього ПК</span>
                        </label>
                    </div>
                </div>

                <!-- Група 3: Динамічні послуги продавця -->
                @if (item.Uslugi != null && item.Uslugi.Any())
                {
                    foreach (var u in item.Uslugi)
                    {
                        <div class="pdp-svc-group" data-pdp-svc-group>
                            <div class="pdp-svc-group__head">
                                <label class="pdp-svc-group__toggle">
                                    <input type="checkbox" class="pdp-svc-group__cb pdp-svc-item__cb" name="uslugi" value="@u.Id" data-price="@u.Price" />
                                    <span class="pdp-svc-group__cb-box"><i class="bi bi-check-lg"></i></span>
                                    <span class="pdp-svc-group__title">@u.Name</span>
                                </label>
                                @if (!string.IsNullOrWhiteSpace(u.Description))
                                {
                                    <button type="button" class="pdp-svc-info" title="@u.Description" aria-label="@u.Description"><i class="bi bi-info-circle"></i></button>
                                }
                                <span class="pdp-svc-group__price">+@u.Price.ToString("N0")&nbsp;₴</span>
                            </div>
                        </div>
                    }
                }

                <div class="pdp-svc-total" id="pdpSvcTotal" style="display:none">
                    <span class="pdp-svc-total__label">Послуги:</span>
                    <span class="pdp-svc-total__val" id="pdpSvcTotalVal">0 ₴</span>
                </div>
            </div>

            <!-- Delivery block -->
            <div class="pdp-card">
                <div class="pdp-card__head">
                    <i class="bi bi-truck"></i> Доставка
                </div>
                <div class="pdp-card__row">
                    <div class="pdp-card__row-icon"><i class="bi bi-box-seam"></i></div>
                    <div class="pdp-card__row-body">
                        <div>Самовивіз з відділень поштових операторів</div>
                        <a href="#" class="pdp-card__link">Показати на карті</a>
                    </div>
                    <div class="pdp-card__row-meta">
                        <div>Відправимо завтра</div>
                        <div class="pdp-card__row-note">за тарифами перевізника</div>
                    </div>
                </div>
                <div class="pdp-card__row">
                    <div class="pdp-card__row-icon"><i class="bi bi-geo-alt"></i></div>
                    <div class="pdp-card__row-body">Доставка кур'єром</div>
                    <div class="pdp-card__row-meta">
                        <div>Відправимо завтра</div>
                        <div class="pdp-card__row-note">за тарифами перевізника</div>
                    </div>
                </div>
            </div>

            <!-- Payment block -->
            <div class="pdp-card">
                <div class="pdp-card__head">
                    <i class="bi bi-credit-card"></i> Оплата
                </div>
                <div class="pdp-card__text">
                    Оплата під час отримання товару, Картою онлайн, Google&nbsp;Pay,
                    -5% знижки від ПриватБанк та Mastercard від 500&nbsp;грн,
                    Покупка частинами monobank, PrivatPay, Apple&nbsp;Pay,
                    Кредит, Оплата частинами, Оплата карткою у відділенні
                </div>
            </div>

            <!-- Guarantee block -->
            <div class="pdp-card">
                <div class="pdp-card__head">
                    <i class="bi bi-arrow-counterclockwise"></i> Гарантія
                </div>
                <div class="pdp-card__text">
                    <strong>@item.Garantia місяців</strong> Обмін/повернення товару впродовж <strong>14 днів</strong>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== RECOMMENDED (Також вас може зацікавити) ===== -->
    @if (recommended.Any())
    {
        <section class="pdp-section">
            <h2 class="pdp-section-title">Також вас може зацікавити</h2>
            <div class="pdp-cards-scroll-wrap">
                <div class="pdp-cards-scroll">
                    @foreach (var ri in recommended)
                    {
                        <div class="pdp-cards-scroll__cell">
                            @await Html.PartialAsync("Card", ri)
                        </div>
                    }
                </div>
            </div>
        </section>
    }

    <!-- ===== BUNDLE (Разом дешевше) ===== -->
    @{
        var bundleItems = Model.BundleItems.Any() ? Model.BundleItems : Model.DemoBundleItems;
    }
    @if (bundleItems.Any())
    {
        var bundleTotal = item.Price + bundleItems.Sum(b => b.Price);
        var complectCode = item.Id + "-" + string.Join("-", bundleItems.Select(b => b.Id));
        <section class="pdp-section">
            <div class="pdp-bundle">
                <h2 class="pdp-bundle__title">Разом дешевше</h2>
                <div class="pdp-bundle__items">
                    <div class="pdp-bundle__item">
                        <a href="@Url.Action("ItemDetails", "Site", new { id = item.Id })">
                            <img src="@mainImage" alt="@item.Name"
                                 onerror="this.onerror=null;this.src='@WebPaths.DefaultItemImage';" />
                        </a>
                        <div class="pdp-bundle__item-info">
                            <div class="pdp-bundle__item-name">@item.Name</div>
                            <div class="pdp-bundle__item-price">@item.Price.ToString("N0") ₴</div>
                        </div>
                    </div>
                    @foreach (var bi in bundleItems)
                    {
                        var biImg = bi.Colors?.FirstOrDefault()?.Color ?? bi.ImageUrl ?? WebPaths.DefaultItemImage;
                        <div class="pdp-bundle__plus">+</div>
                        <div class="pdp-bundle__item">
                            <a href="@Url.Action("ItemDetails", "Site", new { id = bi.Id })">
                                <img src="@biImg" alt="@bi.Name"
                                     onerror="this.onerror=null;this.src='@WebPaths.DefaultItemImage';" />
                            </a>
                            <div class="pdp-bundle__item-info">
                                <div class="pdp-bundle__item-name">@bi.Name</div>
                                <div class="pdp-bundle__item-price">@bi.Price.ToString("N0") ₴</div>
                            </div>
                        </div>
                    }
                </div>
                <div class="pdp-bundle__footer">
                    <div class="pdp-bundle__code">Код комплекту: @complectCode</div>
                    <div class="pdp-bundle__total">
                        <span class="pdp-bundle__total-price">@bundleTotal.ToString("N0") ₴</span>
                        <button type="button" class="pdp-btn pdp-btn--lime pdp-bundle__buy-btn"
                                onclick="addToCart(this, @item.Id)">
                            Купити комплект
                        </button>
                    </div>
                </div>
            </div>
        </section>
    }

    <!-- ===== SPONSORED (Спонсорські товари) ===== -->
    @if (related.Any())
    {
        <section class="pdp-section">
            <h2 class="pdp-section-title">Спонсорські товари</h2>
            <div class="pdp-cards-scroll-wrap">
                <div class="pdp-cards-scroll">
                    @foreach (var ri in related)
                    {
                        <div class="pdp-cards-scroll__cell">
                            @await Html.PartialAsync("Card", ri)
                        </div>
                    }
                </div>
            </div>
        </section>
    }

    <!-- ===== DESCRIPTION + REVIEWS — two-column (макет) ===== -->
    <div class="pdp-bottom-cols pdp-bottom-cols--mock">
        <!-- LEFT: Description -->
        <div class="pdp-bottom-cols__left">
            <div class="pdp-desc-block">
                <h2 class="pdp-section-title pdp-section-title--plain">Опис</h2>
                <div class="pdp-desc-card">
                    <div class="pdp-desc-card__product">@(item.Name ?? "Товар")</div>
                    @if (hasDesc)
                    {
                        <div class="pdp-desc-card__body pdp-desc-card__body--raw">@descTrimmed</div>
                    }
                    else
                    {
                        <div class="pdp-desc-sections">
                            <section class="pdp-desc-section">
                                <h3 class="pdp-desc-section__title">Дисплей стандарту Full HD</h3>
                                <p class="pdp-desc-section__text">Яскравий екран діагоналлю 15,6" з роздільною здатністю 1920×1080 і матовим покриттям зручний для роботи в офісі та перегляду контенту без зайвих відблисків.</p>
                            </section>
                            <section class="pdp-desc-section">
                                <h3 class="pdp-desc-section__title">Продуктивність</h3>
                                <p class="pdp-desc-section__text">Сучасний процесор і достатній обсяг оперативної пам’яті забезпечують плавну роботу в браузері з багатьма вкладками, офісних пакетах і відеодзвінках.</p>
                            </section>
                            <section class="pdp-desc-section">
                                <h3 class="pdp-desc-section__title">Підтримка графіки з високою роздільною здатністю</h3>
                                <p class="pdp-desc-section__text">Роз’єм HDMI дозволяє підключити зовнішній монітор або телевізор для презентацій та роботи на двох екранах.</p>
                            </section>
                            <section class="pdp-desc-section">
                                <h3 class="pdp-desc-section__title">Висока швидкість передавання даних</h3>
                                <p class="pdp-desc-section__text">Порти USB 3.x прискорюють копіювання файлів на флешки та зовнішні диски — зручно для резервних копій і обміну документами.</p>
                            </section>
                            <section class="pdp-desc-section">
                                <h3 class="pdp-desc-section__title">Вбудована веб-камера</h3>
                                <p class="pdp-desc-section__text">Камера та мікрофон вже в корпусі — можна одразу підключатися до відеоконференцій без додаткових пристроїв.</p>
                            </section>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- RIGHT: Reviews -->
        <div class="pdp-bottom-cols__right" id="pdp-reviews-section">
            <div class="pdp-reviews-block">
                <div class="pdp-reviews-header">
                    <h2 class="pdp-section-title pdp-section-title--plain">Відгуки покупців <span class="pdp-reviews-count">@displayReviewCount</span></h2>
                    <button type="button" class="pdp-btn pdp-btn--lime pdp-rv-write-btn" onclick="document.getElementById('pdpRvForm').scrollIntoView({behavior:'smooth'})">
                        Написати відгук
                    </button>
                </div>

                <div class="pdp-reviews-list">
                    @if (useDemoReviews)
                    {
                        <p class="text-muted small mb-3" role="note">Нижче — лише приклад оформлення блоку. Реальних відгуків ще немає; після першого справжнього відгуку тут з’являться лише записи з бази.</p>
                        var demoNames = new[] { "Олег Сидоров", "Марія Коваленко", "Андрій Мельник" };
                        var demoDates = new[]
                        {
                            new DateTime(2022, 1, 9),
                            new DateTime(2022, 2, 14),
                            new DateTime(2022, 3, 3)
                        };
                        for (var di = 0; di < 3; di++)
                        {
                            <div class="pdp-rv">
                                <div class="pdp-rv__head">
                                    <div class="pdp-rv__head-main">
                                        <div class="pdp-rv__ava"><i class="bi bi-person-circle"></i></div>
                                        <div class="pdp-rv__name">@demoNames[di]</div>
                                    </div>
                                    <div class="pdp-rv__date-col">
                                        <div class="pdp-rv__date">@demoDates[di].ToString("dd MMMM yyyy", uk)</div>
                                        <div class="pdp-rv__actions-top">
                                            <i class="bi bi-share" title="Поділитися"></i>
                                            <i class="bi bi-chat-dots" title="Коментар"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="pdp-rv__seller-badge">Продавець: <strong>BAZA-R</strong></div>
                                <div class="pdp-rv__body">
                                    <div class="pdp-rv__text">@demoBodies[di]</div>
                                    @if (di == 1)
                                    {
                                        <div class="pdp-rv__thumb-wrap">
                                            <img class="pdp-rv__thumb" src="@mainImage" alt="" onerror="this.onerror=null;this.src='@WebPaths.DefaultItemImage';" />
                                        </div>
                                    }
                                    <div class="pdp-rv__pros-cons">
                                        <p class="pdp-rv__pc-line"><span class="pdp-rv__pc-label">Переваги:</span> @demoPros[di]</p>
                                        <p class="pdp-rv__pc-line"><span class="pdp-rv__pc-label">Недоліки:</span> @demoCons[di]</p>
                                    </div>
                                </div>
                                <div class="pdp-rv__footer">
                                    <a href="#" class="pdp-rv__reply-link"><i class="bi bi-reply"></i> Відповісти</a>
                                    <div class="pdp-rv__votes">
                                        <button type="button" class="pdp-rv__vote" title="Корисний відгук"><i class="bi bi-hand-thumbs-up"></i> <span>@(di == 0 ? 1 : 4 - di)</span></button>
                                        <button type="button" class="pdp-rv__vote" title="Не корисний"><i class="bi bi-hand-thumbs-down"></i> <span>@(di == 2 ? 1 : 0)</span></button>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        var idx = 0;
                        foreach (var r in reviewsOrdered.Take(5))
                        {
                            var commentText = string.IsNullOrWhiteSpace(r.Comment)
                                ? demoBodies[idx % demoBodies.Length]
                                : r.Comment;
                            <div class="pdp-rv">
                                <div class="pdp-rv__head">
                                    <div class="pdp-rv__head-main">
                                        <div class="pdp-rv__ava"><i class="bi bi-person-circle"></i></div>
                                        <div class="pdp-rv__name">@(r.User?.Name ?? "Користувач")</div>
                                    </div>
                                    <div class="pdp-rv__date-col">
                                        <div class="pdp-rv__date">@r.CreatedAt.ToString("dd MMMM yyyy", uk)</div>
                                        <div class="pdp-rv__actions-top">
                                            <i class="bi bi-share" title="Поділитися"></i>
                                            <i class="bi bi-chat-dots" title="Коментар"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="pdp-rv__seller-badge">Продавець: <strong>BAZA-R</strong></div>
                                <div class="pdp-rv__body">
                                    <div class="pdp-rv__text">@commentText</div>
                                </div>
                                <div class="pdp-rv__footer">
                                    <a href="#" class="pdp-rv__reply-link"><i class="bi bi-reply"></i> Відповісти</a>
                                    <div class="pdp-rv__votes">
                                        <button type="button" class="pdp-rv__vote" title="Корисний відгук"><i class="bi bi-hand-thumbs-up"></i> <span>0</span></button>
                                        <button type="button" class="pdp-rv__vote" title="Не корисний"><i class="bi bi-hand-thumbs-down"></i> <span>0</span></button>
                                    </div>
                                </div>
                            </div>
                            idx++;
                        }
                    }
                </div>

                @if (reviewCount > 5)
                {
                    <a href="#" class="pdp-rv-show-all">Дивитися всі відгуки <span class="pdp-rv-show-all__arr" aria-hidden="true">→</span></a>
                }

                <div class="pdp-rv-form" id="pdpRvForm">
                    <h3 class="pdp-rv-form__title">Залишити відгук</h3>
                    <form asp-action="AddReview" asp-controller="Site" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="itemId" value="@item.Id" />
                        <div class="pdp-rv-form__row">
                            <label>Оцінка:</label>
                            <div class="pdp-star-pick" id="starPicker">
                                @for (int s = 1; s <= 5; s++)
                                {
                                    <i class="bi bi-star pdp-star-pick__s" data-value="@s"></i>
                                }
                            </div>
                            <input type="hidden" name="review.Rating" id="reviewRating" value="5" required />
                        </div>
                        <textarea name="review.Comment" class="form-control pdp-rv-form__ta" rows="3" placeholder="Ваш відгук..." required></textarea>
                        <button type="submit" class="pdp-btn pdp-btn--lime" style="width:auto;padding:10px 28px;font-size:14px;">Надіслати</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function pdpImg(thumb, src) {
        document.getElementById('pdpMainImg').src = src;
        document.querySelectorAll('.pdp-gallery__thumb').forEach(function (t) {
            t.classList.remove('pdp-gallery__thumb--act');
        });
        thumb.classList.add('pdp-gallery__thumb--act');
    }

    (function () {
        var picker = document.getElementById('starPicker');
        if (!picker) return;
        var stars = picker.querySelectorAll('.pdp-star-pick__s');
        var input = document.getElementById('reviewRating');
        function set(val) {
            stars.forEach(function (s) {
                var v = +s.getAttribute('data-value');
                s.classList.toggle('bi-star-fill', v <= val);
                s.classList.toggle('bi-star', v > val);
            });
            input.value = val;
        }
        stars.forEach(function (s) {
            s.addEventListener('click', function () { set(+this.getAttribute('data-value')); });
            s.addEventListener('mouseenter', function () {
                var v = +this.getAttribute('data-value');
                stars.forEach(function (st) {
                    st.classList.toggle('bi-star-fill', +st.getAttribute('data-value') <= v);
                    st.classList.toggle('bi-star', +st.getAttribute('data-value') > v);
                });
            });
        });
        picker.addEventListener('mouseleave', function () { set(+input.value); });
        set(5);

        document.querySelectorAll('.pdp-tabs__link').forEach(function (link) {
            link.addEventListener('click', function (e) {
                document.querySelectorAll('.pdp-tabs__link').forEach(function (l) { l.classList.remove('pdp-tabs__link--active'); });
                this.classList.add('pdp-tabs__link--active');
            });
        });

        var toggle = document.getElementById('pdpCharsToggle');
        var charsCard = document.querySelector('.pdp-chars-card');
        if (toggle && charsCard) {
            toggle.addEventListener('click', function () {
                var open = charsCard.classList.toggle('pdp-chars-card--expanded');
                toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
                toggle.textContent = open ? 'Сховати' : 'Показати ще';
            });
        }

        var fullToggle = document.getElementById('pdpCharsFullToggle');
        var fullPanel = document.getElementById('pdpCharsFullPanel');
        if (fullToggle && fullPanel && charsCard) {
            fullToggle.addEventListener('click', function () {
                var open = fullPanel.hasAttribute('hidden');
                if (open) {
                    fullPanel.removeAttribute('hidden');
                } else {
                    fullPanel.setAttribute('hidden', '');
                }
                charsCard.classList.toggle('pdp-chars-card--full-open', open);
                fullToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
                var txt = fullToggle.querySelector('.pdp-chars-all-btn__text');
                if (txt) {
                    txt.textContent = open ? 'Згорнути' : 'Всі характеристики';
                }
            });
        }
    })();

    (function () {
        document.querySelectorAll('[data-pdp-svc-group]').forEach(function (g) {
            var headCb = g.querySelector('.pdp-svc-group__cb');
            var subs = g.querySelector('.pdp-svc-group__subs');
            if (!headCb || !subs) return;
            function syncGroup() {
                var on = headCb.checked;
                subs.classList.toggle('is-disabled', !on);
                subs.querySelectorAll('input').forEach(function (inp) {
                    inp.disabled = !on;
                    if (!on) inp.checked = false;
                });
                updateTotal();
            }
            headCb.addEventListener('change', syncGroup);
            syncGroup();
        });

        function updateTotal() {
            var sum = 0;
            document.querySelectorAll('.pdp-svc-item__cb').forEach(function (cb) {
                if (cb.checked) sum += parseFloat(cb.getAttribute('data-price')) || 0;
            });
            var totalWrap = document.getElementById('pdpSvcTotal');
            var totalVal = document.getElementById('pdpSvcTotalVal');
            if (totalWrap) totalWrap.style.display = sum > 0 ? 'flex' : 'none';
            if (totalVal) totalVal.textContent = sum.toLocaleString('uk-UA') + ' ₴';
        }

        document.querySelectorAll('.pdp-svc-item__cb').forEach(function (cb) {
            cb.addEventListener('change', updateTotal);
        });
    })();
</script>
}
