<!-- Views/Shared/Pagination.cshtml -->
@model dynamic

@{
    var page = Model.Page as int? ?? 1;
    var totalPages = Model.TotalPages as int? ?? 1;
    var query = Model.Query as string ?? "";
    var categoryIds = Model.CategoryIds as List<int> ?? new List<int>();
}

@if (totalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page == 1 ? "disabled" : "")">
                <a class="page-link" href="@GetPageUrl(page - 1, query, categoryIds)" aria-label="Previous">
                    <span aria-hidden="true">&laquo;</span>
                </a>
            </li>

            @for (int i = 1; i <= totalPages; i++)
            {
                if (i == 1 || i == totalPages || (i >= page - 2 && i <= page + 2))
                {
                    <li class="page-item @(i == page ? "active" : "")">
                        <a class="page-link" href="@GetPageUrl(i, query, categoryIds)">@i</a>
                    </li>
                }
                else if (i == page - 3 || i == page + 3)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }
            }

            <li class="page-item @(page == totalPages ? "disabled" : "")">
                <a class="page-link" href="@GetPageUrl(page + 1, query, categoryIds)" aria-label="Next">
                    <span aria-hidden="true">&raquo;</span>
                </a>
            </li>
        </ul>
    </nav>
}

@functions {
    string GetPageUrl(int pageNumber, string query, List<int> categoryIds)
    {
        var url = $"?page={pageNumber}";
        if (!string.IsNullOrEmpty(query))
        {
            url += $"&query={System.Net.WebUtility.UrlEncode(query)}";
        }
        foreach (var catId in categoryIds)
        {
            url += $"&categoryIds={catId}";
        }
        return url;
    }
}