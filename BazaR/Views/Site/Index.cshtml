@model List<BazaR.Models.Item>

@{
    ViewData["Title"] = "Главная";
    var user = ViewBag.User as BazaR.Models.User;
    var categories = ViewBag.Categories as List<BazaR.Models.Category> ?? new List<BazaR.Models.Category>();
    var featuredItems = ViewBag.FeaturedItems as List<BazaR.Models.Item> ?? new List<BazaR.Models.Item>();
    var newItems = ViewBag.NewItems as List<BazaR.Models.Item> ?? new List<BazaR.Models.Item>();
    var popularItems = ViewBag.PopularItems as List<BazaR.Models.Item> ?? new List<BazaR.Models.Item>();
}

<div class="container-fluid mt-3">

    <!-- Верхняя строка: Сайдбар + Баннер -->
    <div class="row mb-4">
        <!-- Сайдбар -->
        <div class="col-lg-3 col-md-4 d-none d-md-block">
            @await Html.PartialAsync("_SideBarOnIndex", categories)
        </div>

        <!-- Баннер -->
        <div class="col-lg-9 col-md-8">
            <div class="sale-banner d-flex align-items-center justify-content-center text-center p-4 bg-primary text-white rounded">
                <div>
                    <h1 class="fw-bold display-4">ТОТАЛЬНИЙ РОЗПРОДАЖ</h1>
                    <p class="lead">Знижки до -50% на тисячі товарів</p>
                    <a href="@Url.Action("Browse", "Site")" class="btn btn-light btn-lg mt-3">
                        <i class="bi bi-arrow-right"></i> Перейти до покупок
                    </a>
                </div>
            </div>
            <div class="row g-4">
                <!-- Сайдбар слева -->
                <div class="col-lg-3 col-md-4 d-none d-md-block">
                    <!-- Просто оставляем сайдбар пустым здесь, чтобы карточки выравнивались справа -->
                </div>

                <!-- Карточки -->
                <div class="col-lg-9 col-md-8">
                    @if (featuredItems.Any())
                    {
                        <section class="mb-5">
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <h2 class="mb-0">Тотальний розпродаж</h2>
                                <a href="@Url.Action("Browse", "Site", new { sort = "price_desc" })" class="btn btn-outline-primary">
                                    Всі товари <i class="bi bi-arrow-right"></i>
                                </a>
                            </div>
                            <div class="row g-4 justify-content-start">
                                @foreach (var item in featuredItems)
                                {
                                    <div class="col-lg-3 col-md-6 col-sm-12">
                                        @await Html.PartialAsync("Card", item)
                                    </div>
                                }
                            </div>
                        </section>
                    }

                    @if (newItems.Any())
                    {
                        <section class="mb-5">
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <h2 class="mb-0">Новинки</h2>
                                <a href="@Url.Action("Browse", "Site", new { sort = "newest" })" class="btn btn-outline-primary">
                                    Всі новинки <i class="bi bi-arrow-right"></i>
                                </a>
                            </div>
                            <div class="row g-4 justify-content-start">
                                @foreach (var item in newItems)
                                {
                                    <div class="col-lg-3 col-md-6 col-sm-12">
                                        @await Html.PartialAsync("Card", item)
                                    </div>
                                }
                            </div>
                        </section>
                    }

                    @if (popularItems.Any())
                    {
                        <section class="mb-5">
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <h2 class="mb-0">Найбільш очікувані товари</h2>
                                <a href="@Url.Action("Browse", "Site", new { sort = "rating_desc" })" class="btn btn-outline-primary">
                                    Всі популярні <i class="bi bi-arrow-right"></i>
                                </a>
                            </div>
                            <div class="row g-4 justify-content-start">
                                @foreach (var item in popularItems)
                                {
                                    <div class="col-lg-3 col-md-6 col-sm-12">
                                        @await Html.PartialAsync("Card", item)
                                    </div>
                                }
                            </div>
                        </section>
                    }

                    @if (!featuredItems.Any() && !newItems.Any() && !popularItems.Any())
                    {
                        <div class="alert alert-info text-center py-5">
                            <i class="bi bi-info-circle-fill display-4"></i>
                            <h3 class="mt-3">Наразі немає товарів для відображення</h3>
                            <p>Скоро ми додамо нові товари. Слідкуйте за оновленнями!</p>
                            <a href="@Url.Action("Browse", "Site")" class="btn btn-primary btn-lg mt-3">
                                <i class="bi bi-grid"></i> Перейти до каталогу
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>

    <!-- Карточки под баннером -->
    
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('.item-card').each(function(index) {
                $(this).css({
                    'animation': `fadeInUp 0.5s ease forwards ${index * 0.1}s`,
                    'opacity': 0
                });
            });
        });
    </script>

    <style>
        .item-card {
            animation-fill-mode: forwards;
        }
    </style>
}