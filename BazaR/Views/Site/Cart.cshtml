<!-- Views/Site/Cart.cshtml -->
@model List<BazaR.Models.Item>

@{
    ViewData["Title"] = "Корзина";
    var totalAmount = ViewBag.TotalAmount ?? 0;
    var totalQuantity = ViewBag.TotalQuantity ?? 0;
    var user = ViewBag.User as BazaR.Models.User;
    var cart = ViewBag.Cart as Dictionary<int, int> ?? new Dictionary<int, int>();
}

<div class="container mt-4">
    <h2 class="mb-4">Корзина</h2>

    @if (Model.Any())
    {
        <div class="row">
            <div class="col-md-8">
                @foreach (var item in Model)
                {
                    var quantity = cart.ContainsKey(item.Id) ? cart[item.Id] : 1;
                    <div class="card mb-3">
                        <div class="row g-0">
                            <div class="col-md-3">
                                <img src="@(item.Colors?.FirstOrDefault()?.Color ?? "/images/no-image.jpg")"
                                     class="img-fluid rounded-start" alt="@item.Name">
                            </div>
                            <div class="col-md-9">
                                <div class="card-body">
                                    <h5 class="card-title">@item.Name</h5>
                                    <p class="card-text">@item.Desc?.Substring(0, Math.Min(100, item.Desc?.Length ?? 0))...</p>
                                    <p class="card-text">
                                        <strong>Цена:</strong> @item.Price грн<br>
                                        <strong>Количество:</strong> @quantity<br>
                                        <strong>Сумма:</strong> @(item.Price* quantity) грн
                                    </p>
                                    <form asp-action="RemoveFromCart" method="post" style="display: inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="itemId" value="@item.Id" />
                                        <button type="submit" class="btn btn-danger btn-sm">Удалить</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="col-md-4">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Итого</h5>
                        <p class="card-text">
                            <strong>Товаров:</strong> @totalQuantity шт.<br>
                            <strong>Сумма:</strong> @totalAmount грн
                        </p>
                        <div class="d-grid gap-2">
                            <a href="@Url.Action("Checkout", "Site")" class="btn btn-success">Оформить заказ</a>
                            <form asp-action="ClearCart" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger w-100">Очистить корзину</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Ваша корзина пуста. <a href="@Url.Action("Browse", "Site")">Перейти к покупкам</a>
        </div>
    }
</div>