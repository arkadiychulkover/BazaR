@model List<BazaR.Models.Item>

@{
    ViewData["Title"] = "Кошик";
    var totalAmount = (int)(ViewBag.TotalAmount ?? 0);
    var cart = ViewBag.CartItems as Dictionary<int, int> ?? new Dictionary<int, int>();
}

<div class="container mt-4 mb-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Site" asp-action="Index">Головна</a></li>
            <li class="breadcrumb-item active">Кошик</li>
        </ol>
    </nav>

    <h2 class="mb-4 fw-bold">Кошик</h2>

    @if (Model.Any())
    {
        <div class="row g-4">
            <!-- Список товарів -->
            <div class="col-lg-8">
                <div class="cart-page-list">
                    @foreach (var item in Model)
                    {
                        var qty = cart.ContainsKey(item.Id) ? cart[item.Id] : 1;
                        var img = !string.IsNullOrEmpty(item.ImageUrl) ? item.ImageUrl
                                  : (item.Colors?.FirstOrDefault()?.Color ?? "/images/items/default.jpg");

                        <div class="cart-page-item" id="cart-page-item-@item.Id">
                            <div class="cart-page-item__img">
                                <img src="@img" alt="@item.Name"
                                     onerror="this.src='/images/items/default.jpg'">
                            </div>
                            <div class="cart-page-item__info">
                                <a href="@Url.Action("ItemDetails","Site", new { id=item.Id })" class="cart-page-item__name">
                                    @item.Name
                                </a>
                                @if (item.Garantia > 0)
                                {
                                    <span class="cart-page-item__garantia">
                                        <i class="bi bi-shield-check"></i> Гарантія @item.Garantia міс.
                                    </span>
                                }
                            </div>
                            <div class="cart-page-item__qty">
                                <button class="cart-page-qty-btn" onclick="pageCartStep(@item.Id, -1)">−</button>
                                <span class="cart-page-qty-num" id="page-qty-@item.Id">@qty</span>
                                <button class="cart-page-qty-btn" onclick="pageCartStep(@item.Id, 1)">+</button>
                            </div>
                            <div class="cart-page-item__price">
                                <span id="page-subtotal-@item.Id">@((item.Price * qty).ToString("N0"))</span> ₴
                            </div>
                            <button class="cart-page-item__remove" onclick="pageCartRemove(@item.Id)" title="Видалити">
                                <i class="bi bi-trash3"></i>
                            </button>
                        </div>
                    }
                </div>
            </div>

            <!-- Підсумок -->
            <div class="col-lg-4">
                <div class="cart-page-summary">
                    <h5 class="cart-page-summary__title">Ваше замовлення</h5>
                    <div class="cart-page-summary__row">
                        <span>Товарів:</span>
                        <span>@Model.Sum(i => cart.ContainsKey(i.Id) ? cart[i.Id] : 1) шт.</span>
                    </div>
                    <div class="cart-page-summary__total-row">
                        <span>Разом:</span>
                        <span id="page-total">@totalAmount.ToString("N0") ₴</span>
                    </div>
                    <a href="@Url.Action("Checkout", "Site")" class="btn cart-page-summary__btn-order w-100 mt-3">
                        <i class="bi bi-bag-check"></i> Оформити замовлення
                    </a>
                    <a href="@Url.Action("Browse","Site")" class="btn cart-page-summary__btn-continue w-100 mt-2">
                        Продовжити покупки
                    </a>
                    <form asp-action="ClearCart" method="post" class="mt-2">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger w-100 btn-sm">
                            <i class="bi bi-trash3"></i> Очистити кошик
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="cart-page-empty">
            <div class="cart-empty__icon"><img src="/images/items/shopping-cart.png" alt="Кошик порожній" style="width:140px;"></div>
            <div class="cart-empty__title">Ой! Кошик порожній!</div>
            <div class="cart-empty__sub">Але це легко виправити!</div>
            <a href="@Url.Action("Browse","Site")" class="btn cart-page-summary__btn-order mt-4 px-5">
                Перейти до каталогу
            </a>
        </div>
    }
</div>

@section Scripts {
    <style>
        .cart-page-list { display: flex; flex-direction: column; gap: 0; }

        .cart-page-item {
            display: flex; align-items: center; gap: 16px;
            padding: 16px 0; border-bottom: 1px solid #f0f0f0;
        }
        .cart-page-item__img {
            width: 80px; height: 80px; flex-shrink: 0;
            border-radius: 10px; border: 1px solid #ebebeb;
            display: flex; align-items: center; justify-content: center;
            background: #fafafa; overflow: hidden;
        }
        .cart-page-item__img img { width: 100%; height: 100%; object-fit: contain; }
        .cart-page-item__info { flex: 1; min-width: 0; }
        .cart-page-item__name {
            font-size: 14px; color: #1a1a1a; text-decoration: none;
            display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
            line-height: 1.4; font-weight: 500;
        }
        .cart-page-item__name:hover { color: #5a9a00; }
        .cart-page-item__garantia { font-size: 12px; color: #888; display: block; margin-top: 4px; }

        .cart-page-item__qty {
            display: flex; align-items: center;
            border: 1px solid #e0e0e0; border-radius: 8px; overflow: hidden;
        }
        .cart-page-qty-btn {
            width: 34px; height: 34px; background: none; border: none;
            font-size: 18px; color: #555; cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            transition: background 0.15s;
        }
        .cart-page-qty-btn:hover { background: #f0f0f0; }
        .cart-page-qty-num { width: 38px; text-align: center; font-size: 14px; font-weight: 600; }

        .cart-page-item__price { font-size: 16px; font-weight: 700; white-space: nowrap; min-width: 90px; text-align: right; }
        .cart-page-item__remove {
            background: none; border: none; color: #ccc; font-size: 18px;
            cursor: pointer; padding: 4px; transition: color 0.2s;
        }
        .cart-page-item__remove:hover { color: #dc3545; }

        .cart-page-summary {
            background: #fff; border: 1px solid #ebebeb; border-radius: 14px; padding: 24px;
            position: sticky; top: 20px;
        }
        .cart-page-summary__title { font-size: 18px; font-weight: 700; margin-bottom: 16px; }
        .cart-page-summary__row { display: flex; justify-content: space-between; font-size: 14px; color: #555; margin-bottom: 10px; }
        .cart-page-summary__total-row {
            display: flex; justify-content: space-between; font-size: 20px;
            font-weight: 800; padding-top: 12px; border-top: 1px solid #f0f0f0; margin-top: 4px;
        }
        .cart-page-summary__btn-order {
            background: #7ab800; color: #fff; border: none; border-radius: 10px;
            font-size: 15px; font-weight: 600; padding: 12px;
            text-decoration: none; display: block; text-align: center;
            transition: background 0.2s;
        }
        .cart-page-summary__btn-order:hover { background: #5a9a00; color: #fff; }
        .cart-page-summary__btn-continue {
            border: 1.5px solid #d0d0d0; background: #fff; color: #333;
            border-radius: 10px; font-size: 14px; padding: 10px;
            text-decoration: none; display: block; text-align: center;
            transition: all 0.2s;
        }
        .cart-page-summary__btn-continue:hover { border-color: #888; }

        .cart-page-empty {
            display: flex; flex-direction: column; align-items: center;
            justify-content: center; padding: 80px 0; text-align: center;
        }
        .cart-page-empty .cart-empty__icon { margin-bottom: 24px; }
        .cart-page-empty .cart-empty__title { font-size: 24px; font-weight: 700; color: #1a1a1a; margin-bottom: 8px; }
        .cart-page-empty .cart-empty__sub { font-size: 16px; color: #888; }
    </style>

    <script>
        var _prices = {
            @Html.Raw(string.Join(",\n            ", Model.Select(item => $"{item.Id}: {item.Price}")))
        };

        function pageCartStep(itemId, delta) {
            var current = parseInt($('#page-qty-' + itemId).text()) || 1;
            pageCartChangeQty(itemId, current + delta);
        }

        function pageCartChangeQty(itemId, newQty) {
            if (newQty < 1) newQty = 0;
            var token = $('input[name="__RequestVerificationToken"]').first().val();
            $.ajax({
                url: '@Url.Action("UpdateCartQuantity", "Site")',
                type: 'POST',
                traditional: true,
                data: { itemId: itemId, quantity: newQty, __RequestVerificationToken: token },
                success: function(r) {
                    if (r.success) {
                        if (newQty === 0) {
                            $('#cart-page-item-' + itemId).fadeOut(200, function() {
                                $(this).remove();
                                if ($('.cart-page-item').length === 0) location.reload();
                            });
                        } else {
                            $('#page-qty-' + itemId).text(newQty);
                            var p = _prices[itemId] || 0;
                            $('#page-subtotal-' + itemId).text((p * newQty).toLocaleString('uk-UA'));
                        }
                        $('#page-total').text(r.totalAmount.toLocaleString('uk-UA') + ' ₴');
                        if (typeof updateCartBadge === 'function') {
                            updateCartBadge(r.cartCount);
                        } else {
                            $('.cart-header-badge').each(function () {
                                var $b = $(this);
                                $b.text(r.cartCount);
                                $b.toggle(r.cartCount > 0);
                            });
                        }
                    }
                }
            });
        }

        function pageCartRemove(itemId) {
            pageCartChangeQty(itemId, 0);
        }
    </script>
}
