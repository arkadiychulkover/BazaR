<!-- Views/Shared/SideBarInSearch.cshtml -->
@model List<BazaR.Models.Category>

<div class="card mb-3">
    <div class="card-header bg-bazaar-accent">
        <h5 class="mb-0">Категории</h5>
    </div>
    <div class="card-body">
        <form asp-action="Browse" method="get" id="categoryForm">
            <input type="hidden" name="query" value="@ViewBag.Query" />
            <input type="hidden" name="page" value="1" />

            <div class="list-group">
                @foreach (var category in Model)
                {
                    <div class="list-group-item">
                        <div class="form-check">
                            <input type="checkbox"
                                   class="form-check-input category-checkbox"
                                   name="categoryIds"
                                   value="@category.Id"
                                   id="cat_@category.Id"
                                   @(ViewBag.SelectedCategoryIds?.Contains(category.Id) == true ? "checked" : "") />
                            <label class="form-check-label" for="cat_@category.Id">
                                @category.Name
                            </label>
                        </div>
                    </div>
                }
            </div>

            <button type="submit" class="btn btn-bazaar-auth w-100 mt-3">Применить фильтры</button>
        </form>
    </div>
</div>

<script>
    document.querySelectorAll('.category-checkbox').forEach(checkbox => {
        checkbox.addEventListener('change', function() {
            document.getElementById('categoryForm').submit();
        });
    });
</script>