<!-- Views/Shared/SortBar.cshtml -->
@model dynamic

@{
    var currentSort = ViewBag.CurrentSort as string ?? "default";
    var query = ViewBag.Query as string ?? "";
    var categoryIds = ViewBag.CategoryIds as List<int> ?? new List<int>();
}

<div class="card mb-4">
    <div class="card-body">
        <div class="d-flex align-items-center">
            <label class="me-3 mb-0"><strong>Сортировка:</strong></label>
            <select class="form-select w-auto" id="sortSelect">
                <option value="default" selected="@(currentSort == "default")">По умолчанию</option>
                <option value="price_asc" selected="@(currentSort == "price_asc")">Сначала дешевле</option>
                <option value="price_desc" selected="@(currentSort == "price_desc")">Сначала дороже</option>
                <option value="name_asc" selected="@(currentSort == "name_asc")">По названию (А-Я)</option>
                <option value="name_desc" selected="@(currentSort == "name_desc")">По названию (Я-А)</option>
                <option value="rating_desc" selected="@(currentSort == "rating_desc")">По рейтингу</option>
                <option value="newest" selected="@(currentSort == "newest")">Сначала новые</option>
            </select>
        </div>
    </div>
</div>

<script>
    document.getElementById('sortSelect').addEventListener('change', function() {
        var url = new URL(window.location.href);
        url.searchParams.set('sort', this.value);
        window.location.href = url.toString();
    });
</script>