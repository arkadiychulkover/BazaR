@model List<BazaR.Models.Category>

@{
    ViewData["Title"] = "Категорія";

    string name = ViewBag.CategotyName;

    var popularItems = ViewBag.PopularItems as List<BazaR.Models.Item> ?? new List<BazaR.Models.Item>();
}

<div class="container mt-4">

    <!-- Название категории -->
    <h3 class="mb-3">@name</h3>


    <!-- БАННЕР -->
    <div class="category-banner mb-4">

        <div class="banner-content">

            <div class="sale-box">
                SALE
            </div>

            <div class="banner-text">

                <h4>Неонове освітлення</h4>

                <div class="discount">
                    Знижки до -40%
                </div>

            </div>

        </div>

    </div>



    <!-- СЕТКА КАТЕГОРИЙ -->

    <div class="category-grid mb-5">

        @foreach (var category in Model)
        {

            <a asp-controller="Site"
               asp-action="Browse"
               asp-route-categoryIds="@category.Id"
               class="category-card">

                <div class="cat-img">

                    @if (!string.IsNullOrEmpty(category.IconUrl))
                    {
                        <img src="@category.IconUrl" />
                    }

                </div>

                <div class="cat-name">

                    @category.Name

                </div>

            </a>

        }

    </div>



    <!-- ПОПУЛЯРНЫЕ ТОВАРЫ -->
    @if (popularItems.Any())
    {

        <section class="mb-5">

            <div class="d-flex justify-content-between align-items-center mb-4">

                <h2 class="mb-0">
                    Популярні товари
                </h2>

                <a href="@Url.Action("Browse", "Site", new { sort = "rating_desc" })"
                   class="btn btn-outline-primary">

                    Всі популярні
                    <i class="bi bi-arrow-right"></i>

                </a>

            </div>


            <div class="row g-4">

                @foreach (var item in popularItems)
                {

                    <div class="col-lg-3 col-md-4 col-sm-6">

                        @await Html.PartialAsync("Card", item)

                    </div>

                }

            </div>

        </section>

    }

</div>



<style>

    /* ===== БАННЕР ===== */

    .category-banner {
        height: 210px;
        background: linear-gradient(90deg,#2c004d,#5b1c87);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
    }


    .banner-content {
        display: flex;
        align-items: center;
        gap: 40px;
    }


    .sale-box {
        font-size: 60px;
        font-weight: 700;
        letter-spacing: 6px;
        border: 4px solid #d77cff;
        padding: 10px 30px;
        border-radius: 10px;
    }


    .banner-text h4 {
        font-size: 28px;
        margin-bottom: 10px;
    }

    .discount {
        font-size: 26px;
        font-weight: 600;
    }



    /* ===== GRID КАТЕГОРИЙ ===== */

    .category-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(150px,1fr));
        gap: 12px;
    }



    /* ===== КАРТОЧКА КАТЕГОРИИ ===== */

    .category-card {
        background: white;
        border: 1px solid #e5e5e5;
        border-radius: 10px;
        height: 120px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        text-decoration: none;
        color: #333;
        transition: all .15s ease;
    }



        .category-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 16px rgba(0,0,0,0.08);
            border-color: #d0d0d0;
        }



    .cat-img {
        height: 45px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 6px;
    }



        .cat-img img {
            max-height: 40px;
        }



    .cat-name {
        font-size: 13px;
        line-height: 16px;
        padding: 0 8px;
    }



    /* ===== POPULAR ITEMS ===== */

    section h2 {
        font-size: 22px;
        font-weight: 600;
    }


</style>
