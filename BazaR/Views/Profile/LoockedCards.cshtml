@model BazaR.ViewModels.LookedCardsViewModel

@{
    ViewData["Title"] = "Переглянуті товари";
}

<div class="profile-page">
    <div class="profile-page__layout">
        @await Html.PartialAsync("_ProfileSidebar", Model.Profile)

        <section class="profile-page__content">
            <h1 class="profile-page__title">Переглянуті товари</h1>
            <p class="profile-page__subtitle">Товари, на які ви дивилися останнім часом.</p>

            @if (Model.LookedCards.Any())
            {
                <div class="looked-cards-grid">
                    @foreach (var card in Model.LookedCards)
                    {
                        <div class="looked-card-item" data-item-id="@card.ItemId" data-looked-card-id="@card.Id">
                            <div class="looked-card-item__image">
                                <img src="@card.ItemImageUrl" alt="@card.ItemName" style="height:180px;"/>
                                @if (card.IsLooked)
                                {
                                    <span class="looked-badge">
                                        <i class="icon-eye">
                                            <svg width="18" height="18" viewBox="0 0 25 25" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                <path d="M2.35938 12.5C2.35938 12.5 6.14937 5.44 12.6994 5.44C19.2494 5.44 22.6394 12.5 22.6394 12.5" stroke="white" stroke-miterlimit="10" stroke-linecap="round"/>
                                                <path d="M2.35938 12.5C2.35938 12.5 6.14937 19.56 12.6994 19.56C19.2494 19.56 22.6394 12.5 22.6394 12.5" stroke="white" stroke-miterlimit="10" stroke-linecap="round"/>
                                                <path d="M12.5008 16.45C14.6823 16.45 16.4508 14.6815 16.4508 12.5C16.4508 10.3185 14.6823 8.54999 12.5008 8.54999C10.3193 8.54999 8.55078 10.3185 8.55078 12.5C8.55078 14.6815 10.3193 16.45 12.5008 16.45Z" stroke="white" stroke-miterlimit="10" stroke-linecap="round"/>
                                            </svg>
                                        </i> Переглянуто        
                                    </span>
                                }
                            </div>
                            <div class="looked-card-item__content">
                                <h3 class="looked-card-item__title">@card.ItemName</h3>
                                <p class="looked-card-item__price">@card.Price.ToString("F2") ₴</p>
                                <div class="looked-card-item__meta">
                                    <span class="looked-card-item__views">@card.ViewCount переглядів</span>
                                    <span class="looked-card-item__date">@card.LookedAt.ToString("dd.MM.yyyy")</span>
                                </div>
                            </div>
                            <a href="@Url.Action("ItemDetails", "Site", new { id = @card.ItemId })" class="looked-card-item__link">Переглянути товар</a>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <p>Ви ще не переглядали жодних товарів.</p>
                </div>
            }
        </section>
    </div>
</div>

<link rel="stylesheet" href="~/css/profile-lookedcards.css" />
<script src="~/js/lookedcards.js"></script>
