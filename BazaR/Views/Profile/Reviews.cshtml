@model BazaR.ViewModels.AccountReviewsViewModel

@{
    ViewData["Title"] = "Мої відгуки";
}

<div class="profile-page">
    <div class="profile-page__layout">
        @await Html.PartialAsync("_ProfileSidebar", Model.Profile)

        <section class="profile-page__content">
            <h1 class="profile-page__title">Мої відгуки</h1>
            <p class="profile-page__subtitle">Усі ваші залишені відгуки в одному місці.</p>

            @if (!Model.Reviews.Any())
            {
                <div class="empty-state">
                    <p>Ви ще не залишали жодного відгуку.</p>
                </div>
            }
            else
            {
                <div class="reviews-list">
                    @foreach (var review in Model.Reviews)
                    {
                        <div class="review-item">
                            <div class="review-item__head">
                                <div class="review-item__product">
                                    @if (!string.IsNullOrEmpty(review.ItemImageUrl))
                                    {
                                        <img src="@review.ItemImageUrl" alt="@review.ItemName" class="review-item__img" />
                                    }
                                    <div class="review-item__name">@review.ItemName</div>
                                </div>
                                <div class="review-item__date">@review.CreatedAt.ToString("dd.MM.yyyy")</div>
                            </div>
                            <div class="review-item__stars">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <span class="@(i <= review.Rating ? "star star--filled" : "star")">★</span>
                                }
                            </div>
                            <div class="review-item__text">@review.Text</div>
                        </div>
                    }
                </div>
            }
        </section>
    </div>
</div>
