        </a>

        <a asp-controller="Profile" asp-action="Reviews" class="account-menu__item @(activeMenu == "Reviews" ? "account-menu__item--active" : "")">
            <span class="account-menu__icon">
                <svg width="25" height="25" viewBox="0 0 25 25" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M6.1 18.8401H4.15C2.79 18.8401 1.75 17.8001 1.75 16.4501V5.67005C1.75 4.32005 2.79 3.28005 4.15 3.28005H20.42C21.77 3.28005 22.82 4.32005 22.82 5.67005V16.4501C22.82 17.8001 21.77 18.8401 20.42 18.8401H10.7" stroke="#1D1D1B" stroke-miterlimit="10" stroke-linecap="round"/>
