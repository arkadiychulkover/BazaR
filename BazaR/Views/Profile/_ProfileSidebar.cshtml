@model BazaR.ViewModels.AccountProfileViewModel

@{
    var activeMenu = ViewBag.ActiveMenu as string;
}
<aside class="account-sidebar">
    <div class="account-user-card @(activeMenu == "Profile" ? "account-menu__item--active" : "")">
        <div class="account-user-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.982 18.725A7.488 7.488 0 0 0 12 15.75a7.488 7.488 0 0 0-5.982 2.975m11.963 0a9 9 0 1 0-11.963 0m11.963 0A8.966 8.966 0 0 1 12 21a8.966 8.966 0 0 1-5.982-2.275M15 9.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
            </svg>
        </div>
        <a asp-controller="Profile" asp-action="Profile">
            <div class="account-user-card__info">
                <div class="account-user-card__name">@(Model?.FullName)</div>
                <div class="account-user-card__email">@(Model?.Email)</div>
            </div>
        </a>
    </div>

    <nav class="account-menu">
