                <svg width="25" height="25" viewBox="0 0 25 25" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12.5017 23.49C18.5713 23.49 23.4917 18.5696 23.4917 12.5C23.4917 6.4304 18.5713 1.51001 12.5017 1.51001C6.43211 1.51001 1.51172 6.4304 1.51172 12.5C1.51172 18.5696 6.43211 23.49 12.5017 23.49Z" stroke="#1E1E1C" stroke-miterlimit="10"/>
