                    <path d="M7.60938 12.37H19.9794" stroke="#1D1D1B" stroke-miterlimit="10" stroke-linecap="round"/>
                    <path d="M7.60938 17.28H19.9794" stroke="#1D1D1B" stroke-miterlimit="10" stroke-linecap="round"/>
                    <path d="M5.38984 8.25997C5.83167 8.25997 6.18984 7.9018 6.18984 7.45997C6.18984 7.01815 5.83167 6.65997 5.38984 6.65997C4.94802 6.65997 4.58984 7.01815 4.58984 7.45997C4.58984 7.9018 4.94802 8.25997 5.38984 8.25997Z" fill="#1D1D1B"/>
                    <path d="M5.38984 13.17C5.83167 13.17 6.18984 12.8118 6.18984 12.37C6.18984 11.9282 5.83167 11.57 5.38984 11.57C4.94802 11.57 4.58984 11.9282 4.58984 12.37C4.58984 12.8118 4.94802 13.17 5.38984 13.17Z" fill="#1D1D1B"/>
