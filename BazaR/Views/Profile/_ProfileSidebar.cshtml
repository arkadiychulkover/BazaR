        </a>

        <a asp-controller="Profile" asp-action="Messages" class="account-menu__item account-menu__item--messages @(activeMenu == "Messages" ? "account-menu__item--active" : "")">
            <span class="account-menu__icon">
                <svg width="25" height="25" viewBox="0 0 25 25" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M21.1914 4.88H3.82141C2.50697 4.88 1.44141 5.94557 1.44141 7.26V17.65C1.44141 18.9644 2.50697 20.03 3.82141 20.03H21.1914C22.5058 20.03 23.5714 18.9644 23.5714 17.65V7.26C23.5714 5.94557 22.5058 4.88 21.1914 4.88Z" stroke="#1E1E1C" stroke-miterlimit="10" stroke-linecap="round"/>
