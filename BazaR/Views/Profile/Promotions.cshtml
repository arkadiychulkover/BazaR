@model BazaR.ViewModels.PromotionsViewModel
@{
    ViewData["Title"] = "Акції";
}

<div class="profile-page">
    <div class="profile-page__layout">
        @await Html.PartialAsync("_ProfileSidebar", Model.Profile)

        <section class="profile-page__content">
            <h1 class="profile-page__title">Акції</h1>
            <p class="profile-page__subtitle">Підписуйтесь на акції та отримуйте знижки на категорії товарів.</p>

            @if (Model.Promotions.Any())
            {
                <div class="settings-list">
                    @foreach (var promo in Model.Promotions)
                    {
                        <div class="settings-item">
                            <div class="settings-item__top">
                                <div>
                                    <h3 class="settings-item__title">@promo.Title</h3>
                                    <p class="settings-item__text">
                                        @promo.Description
                                        @if (!string.IsNullOrEmpty(promo.CategoryName))
                                        {
                                            <span class="promo-category">@promo.CategoryName</span>
                                        }
                                    </p>
                                    <p class="settings-item__text promo-meta">
                                        <span class="promo-discount">−@promo.DiscountPercent%</span>
                                        <span class="promo-dates">
                                            З @promo.StartsAt.ToString("dd.MM.yyyy")
                                            @if (promo.EndsAt.HasValue)
                                            {
                                                <text>до @promo.EndsAt.Value.ToString("dd.MM.yyyy")</text>
                                            }
                                            else
                                            {
                                                <text>— безстроково</text>
                                            }
                                        </span>
                                    </p>
                                </div>
                                <form method="post" action="@Url.Action("TogglePromotion", "Profile", new { id = promo.Id })">
                                    @Html.AntiForgeryToken()
                                    <label class="switch" title="@(promo.IsSubscribed ? "Відписатись" : "Підписатись")">
                                        <input type="checkbox"
                                               @(promo.IsSubscribed ? "checked" : "")
                                               onchange="this.form.submit()" />
                                        <span class="slider"></span>
                                    </label>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <p>Наразі активних акцій немає.</p>
                </div>
            }
        </section>
    </div>
</div>