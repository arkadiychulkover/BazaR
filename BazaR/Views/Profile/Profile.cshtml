@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager
@model BazaR.ViewModels.AccountProfileViewModel

@{
    ViewData["Title"] = "Особисті данні";

    var externalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).ToList();
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var currentLogins = await UserManager.GetLoginsAsync(await UserManager.GetUserAsync(User));
    var isGoogleLinked = currentLogins.Any(l => l.LoginProvider == "Google");
}

<div class="profile-page">
    <div class="profile-page__layout">
        @await Html.PartialAsync("_ProfileSidebar", Model)

        <main class="profile-page__content">
            <h1 class="profile-page__title">Особисті данні</h1>

            @Html.AntiForgeryToken()

            <div class="profile-accordion">

                <!-- Особисті данні -->
                <section class="profile-block is-open">
                    <button class="profile-block__head" type="button" aria-expanded="true" aria-controls="personal-data">
                        <div class="profile-block__left">
                            <span class="profile-block__icon">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.982 18.725A7.488 7.488 0 0 0 12 15.75a7.488 7.488 0 0 0-5.982 2.975m11.963 0a9 9 0 1 0-11.963 0m11.963 0A8.966 8.966 0 0 1 12 21a8.966 8.966 0 0 1-5.982-2.275M15 9.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                                </svg>
                            </span>
                            <span class="profile-block__title">Особисті данні</span>
                        </div>
                        <span class="profile-block__arrow"></span>
                    </button>

                    <div class="profile-block__body" id="personal-data">
                        <div class="profile-info-grid profile-info-grid--3">

                            <!-- Ім'я -->
                            <div class="profile-info-item">
                                <div class="profile-info-item__label">Ім'я</div>
                                <div class="profile-info-item__value" id="val-firstName">@(string.IsNullOrWhiteSpace(Model.FirstName) ? "Не вказано" : Model.FirstName)</div>
                                <button type="button" class="profile-edit-link border-0 bg-transparent" onclick="startEdit('firstName', 'text')">
                                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                                        <path d="M3 13h10" stroke="#3E77AA" stroke-width="1" stroke-linecap="round" />
                                        <path d="M2 14h12M11.5 2.5l2.5 2.5M2.5 11.5l7-7" stroke="#3E77AA" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
                                    </svg>
                                    <span>Редагувати</span>
                                </button>
                            </div>

                            <!-- Призвіще -->
                            <div class="profile-info-item">
                                <div class="profile-info-item__label">Призвіще</div>
                                <div class="profile-info-item__value" id="val-lastName">@(string.IsNullOrWhiteSpace(Model.LastName) ? "Не вказано" : Model.LastName)</div>
                                <button type="button" class="profile-edit-link border-0 bg-transparent" onclick="startEdit('lastName', 'text')">
                                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                                        <path d="M3 13h10" stroke="#3E77AA" stroke-width="1" stroke-linecap="round" />
                                        <path d="M2 14h12M11.5 2.5l2.5 2.5M2.5 11.5l7-7" stroke="#3E77AA" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
                                    </svg>
                                    <span>Редагувати</span>
                                </button>
                            </div>

                            <!-- По батькові -->
                            <div class="profile-info-item">
                                <div class="profile-info-item__label">По батькові</div>
                                <div class="profile-info-item__value" id="val-middleName">@(string.IsNullOrWhiteSpace(Model.MiddleName) ? "Не вказано" : Model.MiddleName)</div>
                                <button type="button" class="profile-edit-link border-0 bg-transparent" onclick="startEdit('middleName', 'text')">
                                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                                        <path d="M3 13h10" stroke="#3E77AA" stroke-width="1" stroke-linecap="round" />
                                        <path d="M2 14h12M11.5 2.5l2.5 2.5M2.5 11.5l7-7" stroke="#3E77AA" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
                                    </svg>
                                    <span>Редагувати</span>
                                </button>
                            </div>

                            <!-- Дата народження -->
                            <div class="profile-info-item">
                                <div class="profile-info-item__label">Дата народження</div>
                                <div class="profile-info-item__value" id="val-birthDate">@(Model.BirthDate.HasValue? Model.BirthDate.Value.ToString("dd.MM.yyyy") : "Не вказано")</div>
                                <button type="button" class="profile-edit-link border-0 bg-transparent" onclick="startEdit('birthDate', 'date')">
                                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                                        <path d="M3 13h10" stroke="#3E77AA" stroke-width="1" stroke-linecap="round" />
                                        <path d="M2 14h12M11.5 2.5l2.5 2.5M2.5 11.5l7-7" stroke="#3E77AA" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
                                    </svg>
                                    <span>Редагувати</span>
                                </button>
                            </div>

                            <!-- Стать -->
                            <div class="profile-info-item">
                                <div class="profile-info-item__label">Стать</div>
                                <div class="profile-info-item__value" id="val-gender">@(string.IsNullOrWhiteSpace(Model.Gender) ? "Не вказано" : Model.Gender)</div>
                                <button type="button" class="profile-edit-link border-0 bg-transparent" onclick="startEdit('gender', 'select')">
                                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                                        <path d="M3 13h10" stroke="#3E77AA" stroke-width="1" stroke-linecap="round" />
                                        <path d="M2 14h12M11.5 2.5l2.5 2.5M2.5 11.5l7-7" stroke="#3E77AA" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
                                    </svg>
                                    <span>Редагувати</span>
                                </button>
                            </div>

                            <!-- Мова -->
                            <div class="profile-info-item">
                                <div class="profile-info-item__label">Мова спілкування з Baza-R</div>
                                <div class="profile-info-item__value">Українська</div>
                            </div>

                        </div>
                    </div>
                </section>

                <!-- Мої отримувачі замовлень -->
                <section class="profile-block">
                    <button class="profile-block__head" type="button" aria-expanded="false" aria-controls="recipients-data">
                        <div class="profile-block__left">
                            <span class="profile-block__icon">
                                <svg width="30" height="30" viewBox="0 0 30 30" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M27.2179 9.23999H3.42188V28.236H27.2179V9.23999Z" stroke="#1E1E1C" stroke-miterlimit="10" />
                                    <path d="M27.3128 8.99999L22.2488 1.67999H8.88078L3.30078 9.01199" stroke="#1E1E1C" stroke-miterlimit="10" />
                                    <path d="M17.7718 15.876L15.4678 13.836L13.1758 15.876V1.88397H17.7718V15.876Z" stroke="#1E1E1C" stroke-linejoin="round" />
                                    <path d="M6.13281 21.552H11.4848" stroke="#1E1E1C" stroke-linecap="round" stroke-linejoin="round" />
                                    <path d="M6.13281 24.156H9.39681" stroke="#1E1E1C" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                            </span>
                            <span class="profile-block__title">Мої отримувачі замовлень</span>
                        </div>
                        <span class="profile-block__arrow"></span>
                    </button>
                    <div class="profile-block__body" id="recipients-data" hidden>
                        @if (Model.OrderRecipients.Count == 0)
                        {
                            <div class="profile-empty">У вас ще немає доданих отримувачів.</div>
                        }
                        else
                        {
                            <div class="profile-info-grid profile-info-grid--3">
                                @foreach (var r in Model.OrderRecipients)
                                {
                                    <div class="profile-info-item">
                                        <div class="profile-info-item__label">@r.LastName @r.FirstName @r.MiddleName</div>
                                        <div class="profile-info-item__value">@(r.Phone ?? "Не вказано")</div>
                                        <button type="button" class="profile-edit-link profile-delete-btn border-0 bg-transparent"
                                                onclick="deleteItem('recipient', @r.Id, this)">
                                            <span>Видалити</span>
                                        </button>
                                    </div>
                                }
                            </div>
                        }
                        <button type="button" class="profile-add-btn border-0 bg-transparent" onclick="showAddRecipientForm()">
                            + Додати отримувача
                        </button>
                        <div id="add-recipient-form" style="display:none; margin-top:12px;">
                            <div class="profile-info-grid profile-info-grid--3">
                                <div class="profile-info-item">
                                    <div class="profile-info-item__label">Ім'я</div>
                                    <input type="text" id="rec-firstName" class="profile-inline-input" placeholder="Ім'я" />
                                </div>
                                <div class="profile-info-item">
                                    <div class="profile-info-item__label">Призвіще</div>
                                    <input type="text" id="rec-lastName" class="profile-inline-input" placeholder="Призвіще" />
                                </div>
                                <div class="profile-info-item">
                                    <div class="profile-info-item__label">По батькові</div>
                                    <input type="text" id="rec-middleName" class="profile-inline-input" placeholder="По батькові" />
                                </div>
                                <div class="profile-info-item">
                                    <div class="profile-info-item__label">Телефон</div>
                                    <input type="text" id="rec-phone" class="profile-inline-input" placeholder="+380..." />
                                </div>
                            </div>
                            <button type="button" class="profile-save-btn" onclick="saveRecipient()">Зберегти</button>
                            <button type="button" class="profile-cancel-btn" onclick="document.getElementById('add-recipient-form').style.display='none'">Скасувати</button>
                        </div>
                    </div>
                </section>

                <!-- Контакти -->
                <section class="profile-block">
                    <button class="profile-block__head" type="button" aria-expanded="false" aria-controls="contacts-data">
                        <div class="profile-block__left">
                            <span class="profile-block__icon">
                                <svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M17.9984 18C19.9867 18 21.5984 16.3883 21.5984 14.4C21.5984 12.4118 19.9867 10.8 17.9984 10.8C16.0102 10.8 14.3984 12.4118 14.3984 14.4C14.3984 16.3883 16.0102 18 17.9984 18Z" stroke="#1E1E1C" stroke-width="0.79" stroke-miterlimit="10" />
                                    <path d="M23.4 22.2784C23.2877 21.0675 22.7098 19.9467 21.7873 19.1505C20.8647 18.3542 19.669 17.9442 18.45 18.0061C17.2185 17.9453 16.0118 18.3661 15.0872 19.1788C14.1625 19.9915 13.593 21.1319 13.5 22.3569V24.3203C13.5 24.5536 13.593 24.7773 13.7586 24.9422C13.9241 25.1072 14.1487 25.1999 14.3828 25.1999H22.5014C22.7352 25.1999 22.9598 25.1072 23.1253 24.9422C23.2909 24.7773 23.4 24.5536 23.4 24.3203V22.2784Z" stroke="#1E1E1C" stroke-width="0.79" stroke-miterlimit="10" />
                                    <path d="M26.6023 2.69995H9.3961C8.1828 2.69995 7.19922 3.6674 7.19922 4.86081V30.2391C7.19922 31.4325 8.1828 32.3999 9.3961 32.3999H26.6023C27.8156 32.3999 28.7992 31.4325 28.7992 30.2391V4.86081C28.7992 3.6674 27.8156 2.69995 26.6023 2.69995Z" stroke="#1E1E1C" stroke-miterlimit="10" />
                                    <path d="M4.5 8.09998H9.9" stroke="#1E1E1C" stroke-miterlimit="10" stroke-linecap="round" />
                                    <path d="M4.5 18H9.9" stroke="#1E1E1C" stroke-miterlimit="10" stroke-linecap="round" />
                                    <path d="M4.5 27.9H9.9" stroke="#1E1E1C" stroke-miterlimit="10" stroke-linecap="round" />
                                </svg>
                            </span>
                            <span class="profile-block__title">Контакти</span>
                        </div>
                        <span class="profile-block__arrow"></span>
                    </button>
                    <div class="profile-block__body" id="contacts-data" hidden>
                        <div class="profile-info-grid profile-info-grid--2">
                            <div class="profile-login-item">
                                <div class="profile-login-item__label">Мобільний телефон</div>
                                <div class="profile-info-item__value" id="val-phoneNumber">@(string.IsNullOrWhiteSpace(Model.PhoneNumber) ? "Не вказано" : Model.PhoneNumber)</div>
                                <button type="button" class="profile-edit-link border-0 bg-transparent" onclick="startEdit('phoneNumber', 'text')">
                                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                                        <path d="M3 13h10" stroke="#3E77AA" stroke-width="1" stroke-linecap="round" />
                                        <path d="M2 14h12M11.5 2.5l2.5 2.5M2.5 11.5l7-7" stroke="#3E77AA" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
                                    </svg>
                                    <span>Редагувати</span>
                                </button>
                            </div>
                            <div class="profile-login-item">
                                <div class="profile-login-item__label">Email</div>
                                <div class="profile-info-item__value" id="val-email">@(string.IsNullOrWhiteSpace(Model.Email) ? "Не вказано" : Model.Email)</div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Адреса доставки -->
                <section class="profile-block">
                    <button class="profile-block__head" type="button" aria-expanded="false" aria-controls="delivery-data">
                        <div class="profile-block__left">
                            <span class="profile-block__icon">
                                <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M14.1125 25H11V9H29V25H18.9048" stroke="#1E1E1C" stroke-miterlimit="10" />
                                    <path d="M16.5 28C17.8807 28 19 26.8807 19 25.5C19 24.1193 17.8807 23 16.5 23C15.1193 23 14 24.1193 14 25.5C14 26.8807 15.1193 28 16.5 28Z" stroke="#1E1E1C" stroke-miterlimit="10" />
                                    <path d="M32.5 28C33.8807 28 35 26.8807 35 25.5C35 24.1193 33.8807 23 32.5 23C31.1193 23 30 24.1193 30 25.5C30 26.8807 31.1193 28 32.5 28Z" stroke="#1E1E1C" stroke-miterlimit="10" />
                                    <path d="M29 13.0001H34.4421C34.639 12.9971 34.8338 13.0454 35.0111 13.1413C35.1884 13.2372 35.3433 13.3781 35.4636 13.5528L37.7179 16.7501C37.9058 17.0052 38.0058 17.3273 37.9997 17.658V24.5066C37.9997 24.6374 37.9534 24.7629 37.8708 24.8555C37.7882 24.948 37.6762 25 37.5594 25H35.3755" stroke="#1E1E1C" stroke-miterlimit="10" />
                                    <path d="M32 13V19H38" stroke="#1E1E1C" stroke-miterlimit="10" />
                                    <path d="M9 9H1" stroke="#1E1E1C" stroke-miterlimit="10" stroke-linecap="round" />
                                    <path d="M9 13H3" stroke="#1E1E1C" stroke-miterlimit="10" stroke-linecap="round" />
                                    <path d="M9 16H4" stroke="#1E1E1C" stroke-miterlimit="10" stroke-linecap="round" />
                                    <path d="M9 20H6" stroke="#1E1E1C" stroke-miterlimit="10" stroke-linecap="round" />
                                </svg>
                            </span>
                            <span class="profile-block__title">Адреса доставки</span>
                        </div>
                        <span class="profile-block__arrow"></span>
                    </button>
                    <div class="profile-block__body" id="delivery-data" hidden>
                        @if (Model.DeliveryAddresses.Count == 0)
                        {
                            <div class="profile-empty">Адреси доставки не додані.</div>
                        }
                        else
                        {
                            <div class="profile-info-grid profile-info-grid--3">
                                @foreach (var a in Model.DeliveryAddresses)
                                {
                                    <div class="profile-info-item">
                                        <div class="profile-info-item__label">@a.City, @a.Street</div>
                                        <div class="profile-info-item__value">
                                            @a.Building@(a.Apartment != null ? $", кв. {a.Apartment}" : "")
                                            @(a.PostalCode != null ? $", {a.PostalCode}" : "")
                                        </div>
                                        <button type="button" class="profile-edit-link profile-delete-btn border-0 bg-transparent"
                                                onclick="deleteItem('address', @a.Id, this)">
                                            <span>Видалити</span>
                                        </button>
                                    </div>
                                }
                            </div>
                        }
                        <button type="button" class="profile-add-btn border-0 bg-transparent" onclick="showAddAddressForm()">
                            + Додати адресу
                        </button>
                        <div id="add-address-form" style="display:none; margin-top:12px;">
                            <div class="profile-info-grid profile-info-grid--3">
                                <div class="profile-info-item">
                                    <div class="profile-info-item__label">Місто</div>
                                    <input type="text" id="addr-city" class="profile-inline-input" placeholder="Місто" />
                                </div>
                                <div class="profile-info-item">
                                    <div class="profile-info-item__label">Вулиця</div>
                                    <input type="text" id="addr-street" class="profile-inline-input" placeholder="Вулиця" />
                                </div>
                                <div class="profile-info-item">
                                    <div class="profile-info-item__label">Будинок</div>
                                    <input type="text" id="addr-building" class="profile-inline-input" placeholder="Будинок" />
                                </div>
                                <div class="profile-info-item">
                                    <div class="profile-info-item__label">Квартира</div>
                                    <input type="text" id="addr-apartment" class="profile-inline-input" placeholder="Квартира" />
                                </div>
                                <div class="profile-info-item">
                                    <div class="profile-info-item__label">Поштовий індекс</div>
                                    <input type="text" id="addr-postal" class="profile-inline-input" placeholder="00000" />
                                </div>
                            </div>
                            <button type="button" class="profile-save-btn" onclick="saveAddress()">Зберегти</button>
                            <button type="button" class="profile-cancel-btn" onclick="document.getElementById('add-address-form').style.display='none'">Скасувати</button>
                        </div>
                    </div>
                </section>

                <!-- Логін -->
                <section class="profile-block is-open">
                    <button class="profile-block__head" type="button" aria-expanded="true" aria-controls="login-data">
                        <div class="profile-block__left">
                            <span class="profile-block__icon">
                                <svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M27.7347 14.5946H8.26217C6.38501 14.5946 4.86328 16.2001 4.86328 18.1805V29.4952C4.86328 31.4756 6.38501 33.0811 8.26217 33.0811H27.7347C29.6118 33.0811 31.1336 31.4756 31.1336 29.4952V18.1805C31.1336 16.2001 29.6118 14.5946 27.7347 14.5946Z" stroke="#1E1E1C" stroke-miterlimit="10" />
                                    <path d="M12.6484 14.5945V9.62794C12.6484 8.10664 13.2635 6.64765 14.3583 5.57192C15.4531 4.4962 16.938 3.89186 18.4863 3.89186V3.89186C19.2534 3.89002 20.0134 4.03713 20.7225 4.32474C21.4317 4.61235 22.076 5.0348 22.6184 5.56781C23.1609 6.10082 23.5908 6.73389 23.8835 7.43066C24.1763 8.12743 24.326 8.87415 24.3241 9.62794V14.5945" stroke="#1E1E1C" stroke-width="0.97" stroke-miterlimit="10" />
                                    <path d="M18.0993 27.9072C19.2047 27.9072 20.1009 25.857 20.1009 23.328C20.1009 20.799 19.2047 18.7488 18.0993 18.7488C16.9938 18.7488 16.0977 20.799 16.0977 23.328C16.0977 25.857 16.9938 27.9072 18.0993 27.9072Z" fill="#1E1E1C" />
                                </svg>
                            </span>
                            <span class="profile-block__title">Логін</span>
                        </div>
                        <span class="profile-block__arrow"></span>
                    </button>
                    <div class="profile-block__body" id="login-data">
                        <div class="profile-info-grid profile-info-grid--2">
                            <div class="profile-login-item">
                                <div class="profile-login-item__label">Логін (ел.пошта)</div>
                                <div class="profile-info-item__value" id="val-email">@(string.IsNullOrWhiteSpace(Model.Email) ? "Не вказано" : Model.Email)</div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Домашні тварини -->
                <section class="profile-block">
                    <button class="profile-block__head" type="button" aria-expanded="false" aria-controls="pets-data">
                        <div class="profile-block__left">
                            <span class="profile-block__icon">
                                <svg width="37" height="37" viewBox="0 0 37 37" fill="none" xmlns="http://www.w3.org/2000/svg">
