6.1119 21.6542 25.5342 21.1696 25.0678 20.5865C24.6013 20.0034 24.2554 19.3335 24.05 18.6156C23.6998 17.4148 22.9695 16.3599 21.9688 15.6094C20.968 14.8588 19.7509 14.4531 18.5 14.4531C17.2491 14.4531 16.032 14.8588 15.0313 15.6094C14.0305 16.3599 13.3003 17.4148 12.95 18.6156C12.7463 19.3323 12.4026 20.0015 11.9387 20.5845C11.4748 21.1674 10.8999 21.6527 10.2473 22.0121C9.22657 22.5615 8.41855 23.436 7.95139 24.4968C7.48423 25.5576 7.38469 26.7441 7.66856 27.868C7.95243 28.9918 8.60345 29.9887 9.51834 30.7005C10.4332 31.4122 11.5596 31.7981 12.7188 31.7969C13.4132 31.7954 14.1006 31.6579 14.7422 31.3922C15.9335 30.8984 17.2104 30.6442 18.5 30.6442C19.7896 30.6442 21.0665 30.8984 22.2578 31.3922C22.8994 31.6579 23.5868 31.7954 24.2813 31.7969C25.4417 31.8013 26.5702 31.4178 27.4876 30.7072C28.405 29.9965 29.0585 28.9997 29.3442 27.875C29.6299 26.7503 29.5315 25.5624 29.0646 24.5001C28.5976 23.4378 27.789 22.5621 26.7672 22.0121ZM24.2813 30.6406C23.7352 30.6442 23.1941 30.536 22.6914 30.3227C21.3637 29.7682 19.9389 29.4832 18.5 29.4844C17.0566 29.4844 15.6273 29.7692 14.2941 30.3227C13.7969 30.5372 13.2603 30.6455 12.7188 30.6406C11.8199 30.6383 10.9474 30.3368 10.2389 29.7836C9.53042 29.2305 9.02624 28.4572 8.80589 27.5858C8.58555 26.7144 8.6616 25.7944 9.02203 24.971C9.38247 24.1476 10.0068 23.4676 10.7965 23.0383C12.3817 22.1585 13.5556 20.6886 14.0629 18.948C14.3447 17.9897 14.9293 17.1483 15.7291 16.5498C16.5289 15.9513 17.5011 15.6279 18.5 15.6279C19.499 15.6279 20.4711 15.9513 21.2709 16.5498C22.0707 17.1483 22.6553 17.9897 22.9371 18.948C23.4444 20.6886 24.6183 22.1585 26.2035 23.0383C26.9932 23.4676 27.6175 24.1476 27.978 24.971C28.3384 25.7944 28.4145 26.7144 28.1941 27.5858C27.9738 28.4572 27.4696 29.2305 26.7611 29.7836C26.0526 30.3368 25.1801 30.6383 24.2813 30.6406Z" fill="black" />
                                </svg>
                            </span>
                            <span class="profile-block__title">Домашні тварини</span>
                        </div>
                        <span class="profile-block__arrow"></span>
                    </button>
                    <div class="profile-block__body" id="pets-data" hidden>
                        @if (Model.Pets.Count == 0)
                        {
                            <div class="profile-empty">Інформація про домашніх тварин не додана.</div>
                        }
                        else
                        {
                            <div class="profile-info-grid profile-info-grid--3">
                                @foreach (var p in Model.Pets)
                                {
                                    <div class="profile-info-item">
                                        <div class="profile-info-item__label">@p.Name</div>
                                        <div class="profile-info-item__value">@(p.Type ?? "Не вказано")@(p.Breed != null ? $", {p.Breed}" : "")</div>
                                        <button type="button" class="profile-edit-link profile-delete-btn border-0 bg-transparent"
                                                onclick="deleteItem('pet', @p.Id, this)">
                                            <span>Видалити</span>
                                        </button>
                                    </div>
                                }
                            </div>
                        }
                        <button type="button" class="profile-add-btn border-0 bg-transparent" onclick="showAddPetForm()">
                            + Додати тварину
                        </button>
                        <div id="add-pet-form" style="display:none; margin-top:12px;">
                            <div class="profile-info-grid profile-info-grid--3">
                                <div class="profile-info-item">
                                    <div class="profile-info-item__label">Кличка</div>
                                    <input type="text" id="pet-name" class="profile-inline-input" placeholder="Кличка" />
                                </div>
                                <div class="profile-info-item">
                                    <div class="profile-info-item__label">Вид</div>
                                    <input type="text" id="pet-type" class="profile-inline-input" placeholder="Кіт, Собака..." />
                                </div>
                                <div class="profile-info-item">
                                    <div class="profile-info-item__label">Порода</div>
                                    <input type="text" id="pet-breed" class="profile-inline-input" placeholder="Порода" />
                                </div>
                            </div>
                            <button type="button" class="profile-save-btn" onclick="savePet()">Зберегти</button>
                            <button type="button" class="profile-cancel-btn" onclick="document.getElementById('add-pet-form').style.display='none'">Скасувати</button>
                        </div>
                    </div>
                </section>

                <!-- Додаткова інформація -->
                <section class="profile-block">
                    <button class="profile-block__head" type="button" aria-expanded="false" aria-controls="additional-data">
                        <div class="profile-block__left">
                            <span class="profile-block__icon">
                                <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M9.56797 19.84C11.998 19.84 13.968 17.8701 13.968 15.44C13.968 13.01 11.998 11.04 9.56797 11.04C7.13792 11.04 5.16797 13.01 5.16797 15.44C5.16797 17.8701 7.13792 19.84 9.56797 19.84Z" stroke="#1E1E1C" stroke-miterlimit="10" />
                                    <path d="M15.9032 25.312C15.7347 23.7737 14.9919 22.3555 13.8232 21.341C12.6545 20.3266 11.146 19.7905 9.59922 19.84C8.01669 19.7596 6.46478 20.297 5.27079 21.3387C4.0768 22.3805 3.33406 23.8452 3.19922 25.424V27.936C3.19922 28.5463 3.69922 29.072 4.33522 29.072H14.7672C15.4032 29.072 15.9032 28.5463 15.9032 27.936V25.312Z" stroke="#1E1E1C" stroke-miterlimit="10" />
                                    <path d="M20 12.528H37.888" stroke="#1E1E1C" stroke-miterlimit="10" stroke-linecap="round" />
                                    <path d="M20 20H30.432" stroke="#1E1E1C" stroke-miterlimit="10" stroke-linecap="round" />
                                    <path d="M20.2227 27.472H35.1987" stroke="#1E1E1C" stroke-miterlimit="10" stroke-linecap="round" />
                                </svg>
                            </span>
                            <span class="profile-block__title">Додаткова інформація</span>
                        </div>
                        <span class="profile-block__arrow"></span>
                    </button>
                    <div class="profile-block__body" id="additional-data" hidden>
                        @if (Model.AdditionalInfos.Count == 0)
                        {
                            <div class="profile-empty">Додаткова інформація відсутня.</div>
                        }
                        else
                        {
                            <div class="profile-info-grid profile-info-grid--3">
                                @foreach (var info in Model.AdditionalInfos)
                                {
                                    <div class="profile-info-item">
                                        <div class="profile-info-item__label">@info.Key</div>
                                        <div class="profile-info-item__value">@(string.IsNullOrWhiteSpace(info.Value) ? "Не вказано" : info.Value)</div>
                                        <button type="button" class="profile-edit-link profile-delete-btn border-0 bg-transparent"
                                                onclick="deleteItem('additionalinfo', @info.Id, this)">
                                            <span>Видалити</span>
                                        </button>
                                    </div>
                                }
                            </div>
                        }
                        <button type="button" class="profile-add-btn border-0 bg-transparent" onclick="showAddInfoForm()">
                            + Додати інформацію
                        </button>
                        <div id="add-info-form" style="display:none; margin-top:12px;">
                            <div class="profile-info-grid profile-info-grid--2">
                                <div class="profile-info-item">
                                    <div class="profile-info-item__label">Назва</div>
                                    <input type="text" id="info-key" class="profile-inline-input" placeholder="Наприклад: Алергія" />
                                </div>
                                <div class="profile-info-item">
                                    <div class="profile-info-item__label">Значення</div>
                                    <input type="text" id="info-value" class="profile-inline-input" placeholder="Значення" />
                                </div>
                            </div>
                            <button type="button" class="profile-save-btn" onclick="saveAdditionalInfo()">Зберегти</button>
                            <button type="button" class="profile-cancel-btn" onclick="document.getElementById('add-info-form').style.display='none'">Скасувати</button>
                        </div>
                    </div>
                </section>

            </div>

            <section class="profile-social">
                <p class="profile-social__text">
                    Зв'язуйте обліковий запис Розетки з обліковими записами соцмереж і заходьте на сайт, як користувач Facebook або Google
                </p>
                <div class="profile-social__list">
                    @{
                        if (externalLogins.Count == 0)
                        {
                            <div>No external logins configured</div>
                        }
                        else
                        {
                            <form method="post" asp-controller="Account" asp-action="LinkLogin" asp-route-returnUrl="@returnUrl" class="externalLogin-form-profile">
                                <button class="social-connect-card social-connect-card__left">
                                    <div class="social-connect-card__icon">
                                        <svg width="34" height="34" viewBox="0 0 34 34" fill="none">
                                            <path d="M32.1235 34.0001C33.1597 34.0001 34 33.16 34 32.1236V1.87651C34 0.840039 33.1597 0 32.1235 0H1.87651C0.839906 0 0 0.840039 0 1.87651V32.1236C0 33.16 0.839906 34.0001 1.87651 34.0001H32.1235Z" fill="#395185" />
                                            <path d="M23.4602 33.9997V20.8331H27.8798L28.5415 15.7019H23.4602V12.4256C23.4602 10.94 23.8728 9.92757 26.0033 9.92757L28.7205 9.92637V5.33704C28.2503 5.27448 26.6375 5.13477 24.7611 5.13477C20.8434 5.13477 18.1614 7.52605 18.1614 11.9176V15.7019H13.7305V20.8331H18.1614V33.9997H23.4602Z" fill="white" />
                                        </svg>
                                    </div>
                                    <div class="social-connect-card__content">
                                        <div class="social-connect-card__title">Facebook</div>
                                        <div class="social-connect-card__link">Зв'язати з соц.мережею</div>
                                    </div>
                                </button>
                                @foreach (var provider in externalLogins)
                                {
                                    if (provider.DisplayName == "Google")
                                    {
                                        <button class="social-connect-card">
                                            <div class="social-connect-card__icon">
                                                <svg width="38" height="38" viewBox="0 0 48 48" fill="none">
                                                    <path fill="#FFC107" d="M43.6 20.5H42V20H24v8h11.3C33.7 32.7 29.3 36 24 36c-6.6 0-12-5.4-12-12S17.4 12 24 12c3 0 5.7 1.1 7.8 3l5.7-5.7C34.1 6.1 29.3 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20 20-8.9 20-20c0-1.3-.1-2.3-.4-3.5z" />
                                                    <path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.7 15.2 19 12 24 12c3 0 5.7 1.1 7.8 3l5.7-5.7C34.1 6.1 29.3 4 24 4c-7.7 0-14.4 4.3-17.7 10.7z" />
                                                    <path fill="#4CAF50" d="M24 44c5.2 0 10-2 13.5-5.2l-6.2-5.2C29.2 35.1 26.7 36 24 36c-5.2 0-9.6-3.3-11.2-8l-6.5 5C9.6 39.5 16.3 44 24 44z" />
                                                    <path fill="#1976D2" d="M43.6 20.5H42V20H24v8h11.3c-1.1 3.1-3.3 5.1-6.2 6.4l6.2 5.2C38.5 37 44 31.2 44 24c0-1.3-.1-2.3-.4-3.5z" />
                                                </svg>
                                            </div>
                                            <div class="social-connect-card__content">
                                                <div class="social-connect-card__title">Google</div>
                                                <div class="social-connect-card__link">Зв'язати з соц.мережею</div>
                                            </div>
                                        </button>
                                    }
                                }
                            </form>
                        }
                    }
                </div>
            </section>

            <div class="profile-bottom-links">
                <div class="profile-bottom-links__left">
                    <a asp-action="ForgotPassword" asp-controller="Account" class="profile-bottom-links__item">Змінити пароль</a>
                    <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="profile-bottom-links__item" style="background:none;border:none;padding:0;cursor:pointer;">Вихід</button>
                    </form>
                </div>
                <div class="profile-bottom-links__right">
                    <form asp-action="DeleteAccount" asp-controller="Account" method="post">
                        @Html.AntiForgeryToken()
                        <button class="profile-bottom-links__item bg-transparent border-0">Видалити аккаунт</button>
                    </form>
                </div>
            </div>
        </main>
    </div>
</div>

<script src="~/js/profile.js" asp-append-version="true"></script>