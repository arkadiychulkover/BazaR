@model AccountOrderDetailViewModel

@{
    ViewData["Title"] = $"Замовлення №{Model.Order.Number}";
    var items = ViewBag.Items as List<BazaR.Models.OrderItem> ?? Model.Order.OrderItems ?? new List<BazaR.Models.OrderItem>();
    var city = ViewBag.City as BazaR.Models.City ?? Model.Order.City;
    var user = ViewBag.User as BazaR.Models.User;
    var initial = !string.IsNullOrEmpty(user?.Name) ? user.Name[0].ToString().ToUpper() : "?";

    var statusClass = Model.Order.Status switch
    {
        BazaR.Models.OrderStatus.New        => "os--new",
        BazaR.Models.OrderStatus.Processing => "os--processing",
        BazaR.Models.OrderStatus.Shipped    => "os--shipped",
        BazaR.Models.OrderStatus.Delivered  => "os--delivered",
        BazaR.Models.OrderStatus.Cancelled  => "os--cancelled",
        _                                   => "os--new"
    };
}
<style>
    body { background: #f0f4f8 !important; }

    .od-page {
        max-width: 1140px;
        margin: 28px auto;
        padding: 0 16px;
        display: grid;
        grid-template-columns: 250px 1fr;
        gap: 20px;
        align-items: start;
    }

    .psb { background: #fff; border-radius: 14px; box-shadow: 0 2px 14px rgba(20,60,120,.09); overflow: hidden; }
    .psb__user { background: linear-gradient(135deg,#1565c0,#1e88e5); padding: 22px 18px; display: flex; align-items: center; gap: 13px; }
    .psb__avatar { width: 50px; height: 50px; border-radius: 50%; background: rgba(255,255,255,.25); border: 2px solid rgba(255,255,255,.5); color: #fff; font-size: 22px; font-weight: 800; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .psb__name { font-size: 14px; font-weight: 700; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .psb__email { font-size: 11px; color: rgba(255,255,255,.72); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 2px; }
    .psb__nav { list-style: none; padding: 6px 0; margin: 0; }
    .psb__nav li a { display: flex; align-items: center; gap: 10px; padding: 10px 18px; font-size: 13.5px; color: #333; text-decoration: none; transition: background .15s, color .15s; }
    .psb__nav li a:hover { background: #e8f0fe; color: #1565c0; }
    .psb__nav li a.active { background: #e3eefe; color: #1565c0; font-weight: 700; border-left: 3px solid #1565c0; }
    .psb__divider { border: none; border-top: 1px solid #f0f0f0; margin: 4px 0; }

    .od-panel { background: #fff; border-radius: 14px; box-shadow: 0 2px 14px rgba(20,60,120,.09); overflow: hidden; }

    .od-head {
        padding: 24px 28px;
        background: linear-gradient(135deg,#1565c0,#1e88e5);
        display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px;
    }
    .od-head__left {}
    .od-head__number { font-size: 22px; font-weight: 800; color: #fff; }
    .od-head__date { font-size: 13px; color: rgba(255,255,255,.7); margin-top: 4px; }

    .order-status { display: inline-block; padding: 5px 16px; border-radius: 20px; font-size: 13px; font-weight: 600; }
    .os--new { background: rgba(255,255,255,.22); color: #fff; }
    .os--processing { background: #fff3cd; color: #856404; }
    .os--shipped { background: #d0f0e0; color: #1a7a45; }
    .os--delivered { background: #d4edda; color: #155724; }
    .os--cancelled { background: #fde8e8; color: #c62828; }

    .od-info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; padding: 24px 28px; border-bottom: 1px solid #f0f4f8; }
    .od-info-card { background: #f8fafd; border-radius: 10px; padding: 18px; }
    .od-info-card__title { font-size: 14px; font-weight: 700; color: #1565c0; margin-bottom: 10px; display: flex; align-items: center; gap: 8px; }
    .od-info-card__row { font-size: 13px; color: #555; line-height: 1.8; }
    .od-info-card__row b { color: #333; }

    .od-items { padding: 24px 28px; }
    .od-items__title { font-size: 16px; font-weight: 700; color: #1a1a1a; margin-bottom: 16px; }

    .od-item {
        display: flex; align-items: center; gap: 16px;
        padding: 14px 0; border-bottom: 1px solid #f4f4f4;
    }
    .od-item:last-child { border-bottom: none; }

    .od-item__img {
        width: 60px; height: 60px; border-radius: 10px; border: 1px solid #ebebeb;
        overflow: hidden; background: #fafafa; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
    }
    .od-item__img img { width: 100%; height: 100%; object-fit: contain; }

    .od-item__info { flex: 1; min-width: 0; }
    .od-item__name { font-size: 14px; color: #1a1a1a; text-decoration: none; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; font-weight: 500; }
    .od-item__name:hover { color: #1565c0; }
    .od-item__qty { font-size: 12px; color: #999; margin-top: 2px; }

    .od-item__price { font-size: 15px; font-weight: 700; white-space: nowrap; min-width: 100px; text-align: right; }

    .od-total-row {
        display: flex; justify-content: flex-end; align-items: center; gap: 8px;
        padding: 18px 28px;
        border-top: 1px solid #f0f0f0;
        font-size: 20px; font-weight: 800; color: #1a1a1a;
    }
    .od-total-row small { font-size: 14px; font-weight: 400; color: #888; }

    .od-actions { padding: 0 28px 24px; display: flex; gap: 12px; flex-wrap: wrap; }
    .od-btn { padding: 10px 24px; border-radius: 10px; font-size: 14px; font-weight: 600; text-decoration: none; border: none; cursor: pointer; transition: all .18s; }
    .od-btn--back { background: #e3eefe; color: #1565c0; border: 1.5px solid #90caf9; }
    .od-btn--back:hover { background: #1565c0; color: #fff; border-color: #1565c0; }
    .od-btn--cancel { background: #fff; color: #c62828; border: 1.5px solid #ffcdd2; }
    .od-btn--cancel:hover { background: #c62828; color: #fff; border-color: #c62828; }

    @@media (max-width: 820px) {
        .od-page { grid-template-columns: 1fr; }
        .od-info-grid { grid-template-columns: 1fr; }
    }
</style>
<div class="profile-page">
    <div class="profile-page__layout">
        @await Html.PartialAsync("_ProfileSidebar", Model.Profile)

        <main class="od-panel">
            <div class="od-head">
                <div class="od-head__left">
                    <div class="od-head__number">Замовлення №@Model.Order.Number</div>
                    <div class="od-head__date">від @Model.Order.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</div>
                </div>
                <span class="order-status @statusClass">@Model.Order.Status</span>
            </div>

            <div class="od-info-grid">
                <div class="od-info-card">
                    <div class="od-info-card__title"><i class="bi bi-truck"></i> Доставка</div>
                    <div class="od-info-card__row">
                        <b>Місто:</b> @(city?.Name ?? "—")<br/>
                        <b>Адреса:</b> @Model.Order.Address<br/>
                        <b>Спосіб:</b> @Model.Order.DeliveryMethod
                    </div>
                </div>
                <div class="od-info-card">
                    <div class="od-info-card__title"><i class="bi bi-credit-card"></i> Оплата</div>
                    <div class="od-info-card__row">
                        <b>Спосіб:</b> @Model.Order.PaymentMethod<br/>
                        <b>Статус:</b> @Model.Order.PaymentStatus<br/>
                        <b>Сума:</b> <span style="font-weight:700;">@Model.Order.TotalAmount.ToString("N0") ₴</span>
                    </div>
                </div>
            </div>

            <div class="od-items">
                <div class="od-items__title">Товари у замовленні</div>
                @if (items.Any())
                {
                    foreach (var oi in items)
                    {
                        var img = oi.Item?.ImageUrl
                               ?? oi.Item?.Colors?.FirstOrDefault()?.Color
                               ?? "/images/items/default.jpg";
                        <div class="od-item">
                            <div class="od-item__img">
                                <img src="@img" alt="@oi.Item?.Name" onerror="this.src='/images/items/default.jpg'" />
                            </div>
                            <div class="od-item__info">
                                <a class="od-item__name" href="@Url.Action("ItemDetails","Profile", new { id = oi.ItemId })">
                                    @oi.Item?.Name
                                </a>
                                <div class="od-item__qty">@oi.Quantity шт. × @oi.PriceAtMoment.ToString("N0") ₴</div>
                            </div>
                            <div class="od-item__price">@((oi.PriceAtMoment * oi.Quantity).ToString("N0")) ₴</div>
                        </div>
                    }
                }
                else
                {
                    <div style="color:#999; padding: 20px 0;">Позиції замовлення не знайдено.</div>
                }
            </div>

            <div class="od-total-row">
                <small>Разом:</small> @Model.Order.TotalAmount.ToString("N0") ₴
            </div>

            <div class="od-actions">
                <a href="@Url.Action("Orders","Profile")" class="od-btn od-btn--back">
                    <i class="bi bi-arrow-left me-1"></i> Всі замовлення
                </a>
                @if (Model.Order.Status != BazaR.Models.OrderStatus.Cancelled && Model.Order.Status != BazaR.Models.OrderStatus.Delivered)
                {
                    <form asp-action="CancelOrder" asp-controller="Profile" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Order.Id" />
                        <button type="submit" class="od-btn od-btn--cancel"
                                onclick="return confirm('Скасувати замовлення №@Model.Order.Number?')">
                            Скасувати замовлення
                        </button>
                    </form>
                }
            </div>
        </main>
    </div>
</div>