@model BazaR.ViewModels.PremiumViewModel
@{
    ViewData["Title"] = "Підписка Premium";
}
<div class="profile-page">
    <div class="profile-page__layout">
        @await Html.PartialAsync("_ProfileSidebar", Model.Profile)
        <section class="profile-page__content">
            <h1 class="profile-page__title">Підписка Premium</h1>
            <p class="profile-page__subtitle">Більше переваг, ексклюзивні пропозиції та пріоритетне обслуговування.</p>

            @if (TempData["PremiumError"] != null)
            {
                <div class="alert alert--error">@TempData["PremiumError"]</div>
            }
            @if (TempData["PremiumSuccess"] != null)
            {
                <div class="alert alert--success">@TempData["PremiumSuccess"]</div>
            }

            @if (Model.IsActive)
            {
                <div class="premium-banner premium-banner--active">
                    <h2>Premium активовано</h2>
                    <p>Ваш поточний план діє до @Model.EndDate?.ToString("dd.MM.yyyy")</p>
                    <p class="premium-banner__plan">План: @Model.PlanType | @Model.MonthlyPrice.ToString("F2") ₴/місяць</p>
                </div>
            }
            else
            {
                <div class="premium-banner premium-banner--inactive">
                    <h2>Активуйте Premium</h2>
                    <p>Користуйтеся всіма перевагами преміум-підписки</p>
                    <p class="premium-banner__plan">Від @Model.MonthlyPrice.ToString("F2") ₴/місяць</p>
                    <form asp-action="ActivatePremium" asp-controller="Profile" method="post">
                        @Html.AntiForgeryToken()
                        <button class="btn-main" type="submit">Активувати Premium</button>
                    </form>
                </div>
            }

            <div class="premium-features">
                @foreach (var feature in Model.Features)
                {
                    <div class="premium-feature @(feature.IsAvailable ? "premium-feature--available" : "premium-feature--unavailable")">
                        <div class="premium-feature__icon">
                            @if (feature.IsAvailable)
                            {
                                <span class="icon">✓</span>
                            }
                            else
                            {
                                <span class="icon">✕</span>
                            }
                        </div>
                        <div class="premium-feature__content">
                            <h3>@feature.Name</h3>
                            <p>@feature.Description</p>
                        </div>
                    </div>
                }
            </div>
        </section>
    </div>
</div>