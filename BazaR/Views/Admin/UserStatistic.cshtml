@model BazaR.Models.User
@{
    ViewData["Title"] = $"Статистика пользователя {Model.Email}";
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">Статистика пользователя</h1>
            <p class="text-muted mb-0">@Model.Email</p>
        </div>
        <div>
            <a asp-action="EditUser" asp-route-id="@Model.Id" class="btn btn-outline-primary me-2">
                <i class="bi bi-pencil"></i> Редактировать
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Назад
            </a>
        </div>
    </div>

    <!-- User Info Cards -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <h6 class="card-title">ID пользователя</h6>
                    <h2 class="mb-0">@Model.Id</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h6 class="card-title">Товары</h6>
                    <h2 class="mb-0">@(Model.SellingItems?.Count ?? 0)</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <h6 class="card-title">Отзывы</h6>
                    <h2 class="mb-0">@(Model.Reviews?.Count ?? 0)</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-white">
                <div class="card-body">
                    <h6 class="card-title">Заказы</h6>
                    <h2 class="mb-0">@(Model.Orders?.Count ?? 0)</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabs -->
    <ul class="nav nav-tabs mb-4" id="statisticTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="items-tab" data-bs-toggle="tab" data-bs-target="#items" type="button">
                Товары (@(Model.SellingItems?.Count ?? 0))
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="reviews-tab" data-bs-toggle="tab" data-bs-target="#reviews" type="button">
                Отзывы (@(Model.Reviews?.Count ?? 0))
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="orders-tab" data-bs-toggle="tab" data-bs-target="#orders" type="button">
                Заказы (@(Model.Orders?.Count ?? 0))
            </button>
        </li>
    </ul>

    <!-- Tab Content -->
    <div class="tab-content" id="statisticTabsContent">
        <!-- Items Tab -->
        <div class="tab-pane fade show active" id="items" role="tabpanel">
            @if (Model.SellingItems != null && Model.SellingItems.Any())
            {
                <div class="card shadow-sm">
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>ID</th>
                                        <th>Изображение</th>
                                        <th>Название</th>
                                        <th>Цена</th>
                                        <th>Категория</th>
                                        <th>Бренд</th>
                                        <th>Наличие</th>
                                        <th>Гарантия</th>
                                        <th class="text-end">Действия</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.SellingItems)
                                    {
                                        <tr>
                                            <td>@item.Id</td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                                {
                                                    <img src="@item.ImageUrl" alt="@item.Name" style="width: 50px; height: 50px; object-fit: cover;" class="rounded">
                                                }
                                                else
                                                {
                                                    <div class="bg-secondary bg-opacity-10 rounded" style="width: 50px; height: 50px;"></div>
                                                }
                                            </td>
                                            <td>@item.Name</td>
                                            <td>@item.Price.ToString("C")</td>
                                            <td>@item.Category?.Name</td>
                                            <td>@item.Brand?.Name</td>
                                            <td>
                                                @if (item.IsAvailable)
                                                {
                                                    <span class="badge bg-success">В наличии</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger">Нет в наличии</span>
                                                }
                                            </td>
                                            <td>@item.Garantia мес.</td>
                                            <td class="text-end">
                                                <div class="btn-group btn-group-sm">
                                                    <a asp-action="EditItem" asp-route-id="@item.Id"
                                                       class="btn btn-outline-primary" title="Редактировать">
                                                        <i class="bi bi-pencil"></i>
                                                    </a>
                                                    <button type="button" class="btn btn-outline-danger"
                                                            data-bs-toggle="modal" data-bs-target="#deleteItemModal@(item.Id)"
                                                            title="Удалить">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>

                                                <!-- Modal for item deletion -->
                                                <div class="modal fade" id="deleteItemModal@(item.Id)" tabindex="-1">
                                                    <div class="modal-dialog">
                                                        <div class="modal-content">
                                                            <div class="modal-header">
                                                                <h5 class="modal-title">Подтверждение удаления товара</h5>
                                                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                            </div>
                                                            <div class="modal-body text-start">
                                                                <p>Вы уверены, что хотите удалить товар <strong>@item.Name</strong>?</p>
                                                            </div>
                                                            <div class="modal-footer">
                                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                                                                <form asp-action="DeleteUserItem" asp-route-id="@item.Id" method="post">
                                                                    @Html.AntiForgeryToken()
                                                                    <button type="submit" class="btn btn-danger">Удалить</button>
                                                                </form>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    У пользователя пока нет товаров.
                </div>
            }
        </div>

        <!-- Reviews Tab -->
        <div class="tab-pane fade" id="reviews" role="tabpanel">
            @if (Model.Reviews != null && Model.Reviews.Any())
            {
                <div class="card shadow-sm">
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>ID</th>
                                        <th>Товар</th>
                                        <th>Рейтинг</th>
                                        <th>Комментарий</th>
                                        <th>Дата</th>
                                        <th class="text-end">Действия</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var review in Model.Reviews.OrderByDescending(r => r.CreatedAt))
                                    {
                                        <tr>
                                            <td>@review.Id</td>
                                            <td>@review.Item?.Name</td>
                                            <td>
                                                @for (int i = 1; i <= 5; i++)
                                                {
                                                    if (i <= review.Rating)
                                                    {
                                                        <i class="bi bi-star-fill text-warning"></i>
                                                    }
                                                    else
                                                    {
                                                        <i class="bi bi-star text-warning"></i>
                                                    }
                                                }
                                            </td>
                                            <td>
                                                <div style="max-width: 300px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                                    @review.Comment
                                                </div>
                                            </td>
                                            <td>@review.CreatedAt.ToString("dd.MM.yyyy")</td>
                                            <td class="text-end">
                                                <div class="btn-group btn-group-sm">
                                                    <a asp-action="EditReview" asp-route-id="@review.Id"
                                                       class="btn btn-outline-primary" title="Редактировать">
                                                        <i class="bi bi-pencil"></i>
                                                    </a>
                                                    <button type="button" class="btn btn-outline-danger"
                                                            data-bs-toggle="modal" data-bs-target="#deleteReviewModal@(review.Id)"
                                                            title="Удалить">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>

                                                <!-- Modal for review deletion -->
                                                <div class="modal fade" id="deleteReviewModal@(review.Id)" tabindex="-1">
                                                    <div class="modal-dialog">
                                                        <div class="modal-content">
                                                            <div class="modal-header">
                                                                <h5 class="modal-title">Подтверждение удаления отзыва</h5>
                                                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                            </div>
                                                            <div class="modal-body text-start">
                                                                <p>Вы уверены, что хотите удалить этот отзыв?</p>
                                                            </div>
                                                            <div class="modal-footer">
                                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                                                                <form asp-action="DeleteUserReview" asp-route-id="@review.Id" method="post">
                                                                    @Html.AntiForgeryToken()
                                                                    <button type="submit" class="btn btn-danger">Удалить</button>
                                                                </form>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    У пользователя пока нет отзывов.
                </div>
            }
        </div>

        <!-- Orders Tab -->
        <div class="tab-pane fade" id="orders" role="tabpanel">
            @if (Model.Orders != null && Model.Orders.Any())
            {
                <div class="card shadow-sm">
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Номер заказа</th>
                                        <th>Дата</th>
                                        <th>Сумма</th>
                                        <th>Статус</th>
                                        <th>Оплата</th>
                                        <th>ТТН</th>
                                        <th class="text-end">Действия</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in Model.Orders.OrderByDescending(o => o.CreatedAt))
                                    {
                                        <tr>
                                            <td>@order.Number</td>
                                            <td>@order.CreatedAt.ToString("dd.MM.yyyy")</td>
                                            <td>@order.TotalAmount.ToString("C")</td>
                                            <td>
                                                @switch (order.Status)
                                                {
                                                    case "Нове":
                                                        <span class="badge bg-info">Новый</span>
                                                        break;
                                                    case "В обробці":
                                                        <span class="badge bg-primary">В обработке</span>
                                                        break;
                                                    case "Відправлено":
                                                        <span class="badge bg-success">Отправлен</span>
                                                        break;
                                                    case "Доставлено":
                                                        <span class="badge bg-success">Доставлен</span>
                                                        break;
                                                    case "Скасовано":
                                                        <span class="badge bg-danger">Отменен</span>
                                                        break;
                                                    default:
                                                        <span class="badge bg-secondary">@order.Status</span>
                                                        break;
                                                }
                                            </td>
                                            <td>
                                                @if (order.PaymentStatus?.ToLower() == "paid" || order.PaymentStatus == "Оплачено")
                                                {
                                                    <span class="badge bg-success">Оплачен</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning">Не оплачен</span>
                                                }
                                            </td>
                                            <td>@order.Ttn</td>
                                            <td class="text-end">
                                                <div class="btn-group btn-group-sm">
                                                    <a asp-action="OrderDetails" asp-route-id="@order.Id"
                                                       class="btn btn-outline-primary" title="Просмотр">
                                                        <i class="bi bi-eye"></i>
                                                    </a>
                                                    <a asp-action="EditOrder" asp-route-id="@order.Id"
                                                       class="btn btn-outline-secondary" title="Редактировать">
                                                        <i class="bi bi-pencil"></i>
                                                    </a>
                                                    <form asp-action="DeleteOrder" asp-route-id="@order.Id"
                                                          method="post" style="display: inline;">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="btn btn-outline-danger"
                                                                title="Удалить"
                                                                onclick="return confirm('Вы уверены, что хотите удалить заказ №@order.Number?');">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    У пользователя пока нет заказов.
                </div>
            }
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}