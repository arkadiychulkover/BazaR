@model List<Promotion>

<div class="container py-4" style="max-width: 560px;">

    <div class="d-flex align-items-center gap-2 mb-3">
        <span class="text-muted small fw-semibold text-uppercase">Промокоди</span>
        <hr class="flex-grow-1 my-0" />
        <a href="@Url.Action("Index", "Admin")" class="btn btn-outline-info btn-sm ms-3">
            <i class="bi bi-arrow-90deg-left"></i> Повернутись
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center text-muted py-5">
            <i class="bi bi-upc-scan fs-1 d-block mb-2 opacity-25"></i>
            <p class="mb-0">Промокодів поки немає</p>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-2">
            @foreach (var prm in Model)
            {
                <div class="card border-0 shadow-sm border-start border-4 
                    @(prm.DiscountAmount > 500 ? "border-danger" 
                    : prm.DiscountAmount > 100 ? "border-success" 
                    : "border-primary")">
                    <div class="card-body py-2 px-3">
                        <div class="d-flex align-items-center gap-3">

                            <i class="bi bi-upc-scan text-primary fs-5"></i>

                            <div class="flex-grow-1">
                                <span class="fw-semibold">@prm.Number</span>
                            </div>

                            <span class="badge bg-primary">-@prm.DiscountAmount₴</span>

                            <form asp-action="DeletePromotion" method="post"
                                  onsubmit="return confirm('Видалити промокод?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@prm.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Видалити">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>

                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>