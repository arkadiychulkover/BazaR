@model BazaR.Models.Item
@{
    ViewData["Title"] = "Редактирование товара";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Редактирование товара</h1>
        <a asp-action="UserStatistic" asp-route-id="@Model.UserId" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Назад к пользователю
        </a>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-body">
                    <form asp-action="EditItem" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="UserId" />
                        <input type="hidden" asp-for="CategoryId" />
                        <input type="hidden" asp-for="BrandId" />

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Название товара</label>
                            <input asp-for="Name" class="form-control" required />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Desc" class="form-label">Описание</label>
                            <textarea asp-for="Desc" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Desc" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Price" class="form-label">Цена (грн)</label>
                                <input asp-for="Price" class="form-control" type="number" min="0" />
                                <span asp-validation-for="Price" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Garantia" class="form-label">Гарантия (месяцев)</label>
                                <input asp-for="Garantia" class="form-control" type="number" min="0" />
                                <span asp-validation-for="Garantia" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <input asp-for="IsAvailable" class="form-check-input" type="checkbox" />
                                <label asp-for="IsAvailable" class="form-check-label">Товар в наличии</label>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ImageUrl" class="form-label">URL изображения</label>
                            <input asp-for="ImageUrl" class="form-control" />
                            <small class="text-muted">Или загрузите новое изображение</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Загрузить новое изображение</label>
                            <input type="file" name="imageFile" class="form-control" accept="image/*" />
                        </div>

                        <hr />

                        <h5 class="mb-3">Категория и бренд</h5>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Категория</label>
                                <input class="form-control" value="@Model.Category?.Name" readonly disabled />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Бренд</label>
                                <input class="form-control" value="@Model.Brand?.Name" readonly disabled />
                            </div>
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save"></i> Сохранить изменения
                            </button>
                            <a asp-action="UserStatistic" asp-route-id="@Model.UserId" class="btn btn-light">
                                Отмена
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-light">
                    <h5 class="card-title mb-0">Текущее изображение</h5>
                </div>
                <div class="card-body text-center">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded" style="max-height: 200px;">
                    }
                    else
                    {
                        <div class="bg-secondary bg-opacity-10 rounded d-flex align-items-center justify-content-center" style="height: 200px;">
                            <span class="text-muted">Нет изображения</span>
                        </div>
                    }
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="card-title mb-0">Информация</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-5">ID товара:</dt>
                        <dd class="col-sm-7">@Model.Id</dd>

                        <dt class="col-sm-5">Продавец:</dt>
                        <dd class="col-sm-7">@Model.User?.Email</dd>

                        <dt class="col-sm-5">Категория:</dt>
                        <dd class="col-sm-7">@Model.Category?.Name</dd>

                        <dt class="col-sm-5">Бренд:</dt>
                        <dd class="col-sm-7">@Model.Brand?.Name</dd>

                        <dt class="col-sm-5">Отзывов:</dt>
                        <dd class="col-sm-7">@Model.Reviews?.Count ?? 0</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}