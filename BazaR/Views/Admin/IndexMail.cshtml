@model AdminMessageViewModel
@{
    ViewData["Title"] = "Сообщения — " + Model.UserName;
    int unread = Model.Messages.Count(m => !m.IsRead);
}

<div class="container py-4" style="max-width: 760px;">

    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-action="Index">Пользователи</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="UserStatistic" asp-route-id="@Model.UserId">@Model.UserName</a>
            </li>
            <li class="breadcrumb-item active">Сообщения</li>
        </ol>
    </nav>

    <div class="d-flex align-items-center gap-3 mb-4">
        <div class="bg-primary bg-opacity-10 border border-primary rounded-circle d-flex align-items-center justify-content-center fw-bold text-primary"
             style="width:48px;height:48px;font-size:1.2rem;flex-shrink:0;">
            @Model.UserName[0].ToString().ToUpper()
        </div>
        <div>
            <h4 class="mb-0 fw-bold">@Model.UserName</h4>
            <small class="text-muted">
                Всего сообщений: @Model.Messages.Count
                @if (unread > 0)
                {
                    <span class="badge bg-warning text-dark ms-1">@unread не прочитано</span>
                }
            </small>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2" role="alert">
            <i class="bi bi-check-circle-fill"></i>
            @TempData["Success"]
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-dark text-white fw-semibold">
            <i class="bi bi-pencil-square me-2"></i>Новое сообщение
        </div>
        <div class="card-body">
            <form asp-action="SendMessage" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="UserId" value="@Model.UserId" />

                <div class="mb-3">
                    <label class="form-label fw-semibold">Тема</label>
                    <input name="Name"
                           class="form-control @(ViewData.ModelState["Name"]?.Errors.Count > 0 ? "is-invalid" : "")"
                           value="@Model.NewMessage?.Name"
                           placeholder="Например: Предупреждение об активности" />
                    @if (ViewData.ModelState["Name"]?.Errors.Count > 0)
                    {
                        <div class="invalid-feedback">
                            @ViewData.ModelState["Name"].Errors[0].ErrorMessage
                        </div>
                    }
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Текст сообщения</label>
                    <textarea name="Content" rows="4"
                              class="form-control @(ViewData.ModelState["Content"]?.Errors.Count > 0 ? "is-invalid" : "")"
                              placeholder="Введите текст...">@Model.NewMessage?.Content</textarea>
                    @if (ViewData.ModelState["Content"]?.Errors.Count > 0)
                    {
                        <div class="invalid-feedback">
                            @ViewData.ModelState["Content"].Errors[0].ErrorMessage
                        </div>
                    }
                </div>

                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-send me-1"></i>Отправить
                </button>
            </form>
        </div>
    </div>

    <div class="d-flex align-items-center gap-2 mb-3">
        <span class="text-muted small fw-semibold text-uppercase">История сообщений</span>
        <hr class="flex-grow-1 my-0" />
    </div>

    @if (!Model.Messages.Any())
    {
        <div class="text-center text-muted py-5">
            <i class="bi bi-envelope fs-1 d-block mb-2 opacity-25"></i>
            <p class="mb-0">Сообщений пока нет</p>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-2">
            @foreach (var msg in Model.Messages)
            {
                <div class="card border-0 shadow-sm @(!msg.IsRead ? "border-start border-4 border-warning" : "border-start border-4 border-secondary")">
                    <div class="card-body py-3">
                        <div class="d-flex align-items-start gap-3">

                            <div class="pt-1">
                                @if (!msg.IsRead)
                                {
                                    <i class="bi bi-envelope-fill text-warning fs-5"></i>
                                }
                                else
                                {
                                    <i class="bi bi-envelope-open text-secondary fs-5"></i>
                                }
                            </div>

                            <div class="flex-grow-1">
                                <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                                    <span class="fw-semibold">@msg.Name</span>
                                    @if (!msg.IsRead)
                                    {
                                        <span class="badge bg-warning text-dark">Не прочитано</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Прочитано</span>
                                    }
                                    <span class="text-muted small ms-auto">
                                        <i class="bi bi-clock me-1"></i>
                                        @msg.DateTime.ToLocalTime().ToString("dd.MM.yyyy · HH:mm")
                                    </span>
                                </div>
                                <p class="mb-0 text-muted small" style="white-space: pre-wrap;">@msg.Content</p>
                            </div>

                            <form asp-action="DeleteMessage" method="post"
                                  onsubmit="return confirm('Удалить это сообщение?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@msg.Id" />
                                <input type="hidden" name="userId" value="@Model.UserId" />
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Удалить">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>

                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>