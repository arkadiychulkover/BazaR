@model BazaR.Models.Review
@{
    ViewData["Title"] = "Редактирование отзыва";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Редактирование отзыва</h1>
        <a asp-action="UserStatistic" asp-route-id="@Model.UserId" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Назад к пользователю
        </a>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-body">
                    <form asp-action="EditReview" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="UserId" />
                        <input type="hidden" asp-for="ItemId" />
                        <input type="hidden" asp-for="CreatedAt" />

                        <div class="mb-3">
                            <label class="form-label">Товар</label>
                            <input class="form-control" value="@Model.Item?.Name" readonly disabled />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Пользователь</label>
                            <input class="form-control" value="@Model.User?.Email" readonly disabled />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Rating" class="form-label">Рейтинг</label>
                            <div class="rating-input">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <div class="form-check form-check-inline">
                                        <input type="radio" asp-for="Rating" value="@i" class="form-check-input" id="rating@(i)">
                                        <label class="form-check-label" for="rating@(i)">@i</label>
                                    </div>
                                }
                            </div>
                            <span asp-validation-for="Rating" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Comment" class="form-label">Комментарий</label>
                            <textarea asp-for="Comment" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Comment" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Дата создания</label>
                            <input class="form-control" value="@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")" readonly disabled />
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save"></i> Сохранить изменения
                            </button>
                            <a asp-action="UserStatistic" asp-route-id="@Model.UserId" class="btn btn-light">
                                Отмена
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="card-title mb-0">Информация о товаре</h5>
                </div>
                <div class="card-body">
                    @if (Model.Item != null)
                    {
                        <div class="text-center mb-3">
                            @if (!string.IsNullOrEmpty(Model.Item.ImageUrl))
                            {
                                <img src="@Model.Item.ImageUrl" alt="@Model.Item.Name" class="img-fluid rounded" style="max-height: 100px;">
                            }
                            else
                            {
                                <div class="bg-secondary bg-opacity-10 rounded d-flex align-items-center justify-content-center" style="height: 100px;">
                                    <span class="text-muted small">Нет изображения</span>
                                </div>
                            }
                        </div>
                        <p class="mb-1"><strong>Название:</strong> @Model.Item.Name</p>
                        <p class="mb-0"><strong>Цена:</strong> @Model.Item.Price.ToString("C")</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        .rating-input .form-check-inline {
            margin-right: 0.5rem;
        }
        .rating-input .form-check-input {
            margin-top: 0.3rem;
        }
    </style>
}