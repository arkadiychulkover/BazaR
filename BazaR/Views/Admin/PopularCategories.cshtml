@model Dictionary<BazaR.Models.Category, int>
@{
    ViewData["Title"] = "Популярные категории";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Популярные категории</h1>
        <div>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left"></i> Вернуться к пользователям
            </a>
        </div>
    </div>

    <div class="row">
        @if (Model != null && Model.Any())
        {
            foreach (var kvp in Model.OrderByDescending(x => x.Value))
            {
                var category = kvp.Key;
                var visits = kvp.Value;
                <div class="col-md-3 mb-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-body text-center">
                            @if (CategoryDisplayHelper.IsWebImagePath(category.IconUrl))
                            {
                                <img src="@category.IconUrl" class="img-fluid mb-2" style="max-height: 60px;object-fit:contain;" alt="" />
                            }
                            else if (!string.IsNullOrEmpty(category.IconUrl))
                            {
                                <i class="bi @category.IconUrl fs-1 mb-2"></i>
                            }
                            else if (!string.IsNullOrEmpty(category.ImgUrl))
                            {
                                <img src="@category.ImgUrl" class="img-fluid mb-2" style="max-height: 60px;" alt="" />
                            }
                            <h5 class="card-title">@category.Name</h5>
                            <p class="text-muted mb-2">Просмотров: @visits</p>
                            <a asp-controller="Site" asp-action="CategoryPage" asp-route-category="@category.Id" class="btn btn-outline-primary btn-sm">
                                Перейти
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <p class="text-muted">Нет данных о популярных категориях.</p>
            </div>
        }
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}