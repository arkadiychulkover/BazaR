@model BazaR.Models.Order

@{
    ViewData["Title"] = $"Замовлення №{Model.Number}";
    var items = Model.OrderItems ?? new List<BazaR.Models.OrderItem>();
    var city = Model.City;
    var user = Model.User;

    var statusClass = Model.Status switch
    {
        BazaR.Models.OrderStatus.New        => "os--new",
        BazaR.Models.OrderStatus.Processing => "os--processing",
        BazaR.Models.OrderStatus.Shipped    => "os--shipped",
        BazaR.Models.OrderStatus.Delivered  => "os--delivered",
        BazaR.Models.OrderStatus.Cancelled  => "os--cancelled",
        _                                   => "os--new"
    };
}

@if (Model == null)
{
    <div class="alert alert-danger">Замовлення не знайдено</div>
    return;
}

<style>
    body {
        background: #f0f4f8 !important;
    }

    .od-page {
        max-width: 1000px;
        margin: 28px auto;
        padding: 0 16px;
    }

    .od-panel {
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 2px 14px rgba(20,60,120,.09);
        overflow: hidden;
    }

    .od-head {
        padding: 24px 28px;
        background: linear-gradient(135deg,#1565c0,#1e88e5);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 12px;
    }

    .od-head__number {
        font-size: 22px;
        font-weight: 800;
        color: #fff;
    }

    .od-head__date {
        font-size: 13px;
        color: rgba(255,255,255,.7);
        margin-top: 4px;
    }

    .order-status {
        display: inline-block;
        padding: 5px 16px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
    }

    .os--new {
        background: rgba(255,255,255,.22);
        color: #fff;
    }

    .os--processing {
        background: #fff3cd;
        color: #856404;
    }

    .os--shipped {
        background: #d0f0e0;
        color: #1a7a45;
    }

    .os--delivered {
        background: #d4edda;
        color: #155724;
    }

    .os--cancelled {
        background: #fde8e8;
        color: #c62828;
    }

    .od-info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        padding: 24px 28px;
        border-bottom: 1px solid #f0f4f8;
    }

    .od-info-card {
        background: #f8fafd;
        border-radius: 10px;
        padding: 18px;
    }

    .od-info-card__title {
        font-size: 14px;
        font-weight: 700;
        color: #1565c0;
        margin-bottom: 10px;
    }

    .od-info-card__row {
        font-size: 13px;
        color: #555;
        line-height: 1.8;
    }

    .od-items {
        padding: 24px 28px;
    }

    .od-items__title {
        font-size: 16px;
        font-weight: 700;
        margin-bottom: 16px;
    }

    .od-item {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 14px 0;
        border-bottom: 1px solid #f4f4f4;
    }

        .od-item:last-child {
            border-bottom: none;
        }

    .od-item__img {
        width: 60px;
        height: 60px;
        border-radius: 10px;
        border: 1px solid #ebebeb;
        overflow: hidden;
        background: #fafafa;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .od-item__img img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

    .od-item__info {
        flex: 1;
    }

    .od-item__name {
        font-size: 14px;
        color: #1a1a1a;
        text-decoration: none;
    }

        .od-item__name:hover {
            color: #1565c0;
        }

    .od-item__qty {
        font-size: 12px;
        color: #999;
    }

    .od-item__price {
        font-size: 15px;
        font-weight: 700;
        white-space: nowrap;
    }

    .od-total-row {
        display: flex;
        justify-content: flex-end;
        padding: 18px 28px;
        border-top: 1px solid #f0f0f0;
        font-size: 20px;
        font-weight: 800;
    }

    .back-button {
        margin-top: 20px;
        text-align: center;
    }

        .back-button a {
            display: inline-block;
            padding: 10px 24px;
            background: #6c757d;
            color: white;
            text-decoration: none;
            border-radius: 8px;
            font-weight: 500;
            transition: background 0.2s;
        }

            .back-button a:hover {
                background: #5a6268;
            }

    @@media (max-width: 820px) {
        .od-info-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="od-page">
    <main class="od-panel">
        <div class="od-head">
            <div>
                <div class="od-head__number">Замовлення №@Model.Number</div>
                <div class="od-head__date">
                    від @Model.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                </div>
            </div>
            <span class="order-status @statusClass">@Model.Status.DisplayStatus()</span>
        </div>

        <div class="od-info-grid">
            <div class="od-info-card">
                <div class="od-info-card__title">Доставка</div>
                <div class="od-info-card__row">
                    <b>Місто:</b> @(city?.Name ?? "—")<br />
                    <b>Адреса:</b> @Model.Address<br />
                    <b>Спосіб:</b> @Model.DeliveryMethod.DisplayDeliveryMethod()
                    @if (!string.IsNullOrEmpty(Model.Ttn))
                    {
                        <br />
                        <b>ТТН:</b>
 
                        @Model.Ttn
                    }
                </div>
            </div>

            <div class="od-info-card">
                <div class="od-info-card__title">Оплата</div>
                <div class="od-info-card__row">
                    <b>Спосіб:</b> @Model.PaymentMethod.DisplayPaymentMethod()<br />
                    <b>Статус:</b> @Model.PaymentStatus.DisplayPaymentStatus()<br />
                    <b>Сума:</b> @Model.TotalAmount.ToString("N0") ₴
                </div>
            </div>
        </div>

        <div class="od-items">
            <div class="od-items__title">Товари у замовленні</div>

            @if (items != null && items.Any())
            {
                foreach (var oi in items)
                {
                    var img = oi.Item?.ImageUrl ?? "/images/items/default.jpg";

                    <div class="od-item">
                        <div class="od-item__img">
                            <img src="@img" alt="@oi.Item?.Name" />
                        </div>

                        <div class="od-item__info">
                            @if (oi.Item != null)
                            {
                                <a class="od-item__name"
                                   href="@Url.Action("ItemDetails", "Site", new { id = oi.ItemId })">
                                    @oi.Item.Name
                                </a>
                            }
                            else
                            {
                                <span class="od-item__name">Товар видалено</span>
                            }
                            <div class="od-item__qty">
                                @oi.Quantity × @oi.PriceAtMoment.ToString("N0") ₴
                            </div>
                        </div>

                        <div class="od-item__price">
                            @((oi.PriceAtMoment * oi.Quantity).ToString("N0")) ₴
                        </div>
                    </div>
                }
            }
            else
            {
                <div style="color:#999; padding:20px 0;">
                    Позиції замовлення не знайдено.
                </div>
            }
        </div>

        <div class="od-total-row">
            Разом: @Model.TotalAmount.ToString("N0") ₴
        </div>
    </main>

    <div class="back-button" style="display:flex;gap:10px;justify-content:center;">
        <a asp-action="EditOrder" asp-route-id="@Model.Id"
           style="background:#1e88e5;">
            ✏️ Редагувати
        </a>
        <a href="javascript:history.back()">← Повернутися назад</a>
    </div>
</div>