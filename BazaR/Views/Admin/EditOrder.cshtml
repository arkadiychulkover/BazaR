@model BazaR.Models.Order

@{
    ViewData["Title"] = "Edit Order";
}

<h2>Edit Order #@Model.Number</h2>

<form asp-action="EditOrder" method="post">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="Id" />

    <div class="row">
        <div class="col-md-6">

            <div class="mb-3">
                <label class="form-label">City</label>
                <input asp-for="CityId" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Address</label>
                <input asp-for="Address" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Status</label>
                <input asp-for="Status" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Payment Method</label>
                <input asp-for="PaymentMethod" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Payment Status</label>
                <input asp-for="PaymentStatus" class="form-control" />
            </div>

        </div>

        <div class="col-md-6">

            <div class="mb-3">
                <label class="form-label">Delivery Method</label>
                <input asp-for="DeliveryMethod" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">TTN</label>
                <input asp-for="Ttn" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Total Amount</label>
                <input asp-for="TotalAmount" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Created At</label>
                <input asp-for="CreatedAt" class="form-control" readonly />
            </div>

        </div>
    </div>

    <button type="submit" class="btn btn-success">
        Save
    </button>

    <a asp-action="UserStatistic" asp-route-id="@Model.UserId"
       class="btn btn-secondary ms-2">
        Back
    </a>
</form>