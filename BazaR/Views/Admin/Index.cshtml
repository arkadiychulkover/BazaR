@model IEnumerable<BazaR.Models.User>
@{
    ViewData["Title"] = "Управление пользователями";
    int act = ViewBag.Active;
}

<div class="container-fluid py-4">
    <!-- Заголовок и статистика -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Управление пользователями</h1>
        <div>
            <span class="badge bg-primary">Всего пользователей: @Model.Count()</span>
            <span class="badge bg-primary">Онлайн сейчас: @act</span>
            <a asp-action="PopularCategories" class="btn btn-outline-info btn-sm ms-3">
                <i class="bi bi-bar-chart-line"></i> Популярные категории
            </a>
            <a asp-action="GetLog" class="btn btn-outline-info btn-sm ms-3">
                <i class="bi bi-bar-chart-line"></i> Логи пользователей
            </a>
        </div>
    </div>

    <!-- Карточки с активностью пользователей -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <h6 class="text-muted">За 24 часа</h6>
                    <h4>@ViewBag.ForDay</h4>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <h6 class="text-muted">За неделю</h6>
                    <h4>@ViewBag.ForWeek</h4>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <h6 class="text-muted">За месяц</h6>
                    <h4>@ViewBag.ForMonth</h4>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <h6 class="text-muted">Онлайн сейчас</h6>
                    <h4>@ViewBag.Active</h4>
                </div>
            </div>
        </div>
    </div>

    <!-- Таблица пользователей -->
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Имя</th>
                            <th>Email</th>
                            <th>Телефон</th>
                            <th>Админ</th>
                            <th class="text-end">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td>@user.Id</td>
                                <td>@(user.Name ?? "—")</td>
                                <td>@user.Email</td>
                                <td>@(user.PhoneNumber ?? "—")</td>
                                <td>
                                    @if (user.IsAdmin)
                                    {
                                        <span class="badge bg-success">Да</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Нет</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="UserStatistic" asp-route-id="@user.Id"
                                           class="btn btn-outline-primary" title="Статистика">
                                            <i class="bi bi-bar-chart"></i>
                                        </a>
                                        <a asp-action="GetLogByUserId" asp-route-id="@user.Id"
                                           class="btn btn-outline-secondary" title="Логи">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <button type="button" class="btn btn-outline-danger"
                                                data-bs-toggle="modal" data-bs-target="#deleteUserModal@(user.Id)"
                                                title="Удалить">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                        @if (user.LockoutEnd != null && user.LockoutEnd > DateTimeOffset.UtcNow)
                                        {
                                            <form asp-action="UnblockUser" asp-route-id="@user.Id" method="post" class="d-inline">
                                                <button class="btn btn-outline-success btn-sm">Разблокировать</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-action="BlockUser" asp-route-id="@user.Id" method="post" class="d-inline">
                                                <button class="btn btn-outline-danger btn-sm">Заблокировать</button>
                                            </form>
                                        }
                                    </div>

                                    <!-- Модальное окно подтверждения удаления -->
                                    <div class="modal fade" id="deleteUserModal@(user.Id)" tabindex="-1">
                                        <div class="modal-dialog">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <h5 class="modal-title">Подтверждение удаления</h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                </div>
                                                <div class="modal-body text-start">
                                                    <p>Вы уверены, что хотите удалить пользователя <strong>@(user.Email)</strong>?</p>
                                                    <p class="text-danger mb-0">
                                                        <small>Это действие также удалит все связанные данные</small>
                                                    </p>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                                                    <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="btn btn-danger">Удалить</button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}