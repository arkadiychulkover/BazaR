@model BazaR.Models.User
@{
    ViewData["Title"] = "Редактирование пользователя";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Редактирование пользователя</h1>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Назад к списку
        </a>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-body">
                    <form asp-action="EditUser" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Имя</label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">Email</label>
                            <input asp-for="Email" class="form-control" type="email" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PhoneNumber" class="form-label">Телефон</label>
                            <input asp-for="PhoneNumber" class="form-control" />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="IsAdmin" class="form-check-input" type="checkbox" />
                            <label asp-for="IsAdmin" class="form-check-label">Администратор</label>
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> Сохранить
                            </button>
                            <a asp-action="Index" class="btn btn-light">Отмена</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="card-title mb-0">Информация</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-5">ID пользователя:</dt>
                        <dd class="col-sm-7">@Model.Id</dd>

                        <dt class="col-sm-5">Товаров:</dt>
                        <dd class="col-sm-7">@(Model.SellingItems?.Count ?? 0)</dd>

                        <dt class="col-sm-5">Отзывов:</dt>
                        <dd class="col-sm-7">@(Model.Reviews?.Count ?? 0)</dd>

                        <dt class="col-sm-5">Заказов:</dt>
                        <dd class="col-sm-7">@(Model.Orders?.Count ?? 0)</dd>
                    </dl>
                </div>
                <div class="card-footer">
                    <a asp-action="UserStatistic" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary w-100">
                        <i class="bi bi-bar-chart"></i> Подробная статистика
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}